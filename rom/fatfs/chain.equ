
; *** fatfs/chain.equ ***

; offsets for the chain handle data structure (see chain.inc).
; Extension types (dir, file) add their own fields after fatfs_chain_size.

.equ	fatfs_chain_first,	0;..3	first cluster number (uint32)
.equ	fatfs_chain_current,	4;..7	current cluster number (uint32)
.equ	fatfs_chain_size,	8
