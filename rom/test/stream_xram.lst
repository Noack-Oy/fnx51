                         ; ==== ../print/int.inc ====
0139                        1  
0139                        2  ; *** print/int.inc ***
0139                        3  
0139                        4  ; >> void print_int_s8(char a) <<
0139                        5  
0139                        6  ; Print signed integer from accumulator.
0139                        7  
0139                        8  print_int_s8:
0139  C0 E0                 9  	push	ACC
013B  C0 F0                10  	push	B
013D  C0 00                11  	push	0
013F  30 E7 10             12  	jnb	ACC.7,	print_int_u8__1
0142  F8                   13  	mov	r0,	a	; save a in r0 (just pushed) while we print '-'
0143  74 2D                14  	mov	a,	#'-'
0145  11 EF                15  	acall	print_char
0147  E8                   16  	mov	a,	r0
0148  F4                   17  	cpl	a
0149  04                   18  	inc	a
014A  80 06                19  	sjmp	print_int_u8__1
014C                       20  
014C                       21  ; >> void print_int_u8(char a) <<
014C                       22  
014C                       23  ; Print unsingned integer from accumulator.
014C                       24  
014C                       25  print_int_u8:
014C  C0 E0                26  	push	ACC
014E  C0 F0                27  	push	B
0150  C0 00                28  	push	0
0152                       29  print_int_u8__1:
0152  78 00                30  	mov	r0,	#0
0154  75 F0 64             31  	mov	b,	#100
0157  84                   32  	div	ab
0158  60 05                33  	jz	print_int_u8__tens
015A  24 30                34  	add	a,	#'0'
015C  11 EF                35  	acall	print_char
015E  08                   36  	inc	r0	; stop skipping leading zeroes
015F                       37  print_int_u8__tens:
015F  E5 F0                38  	mov	a,	b
0161  75 F0 0A             39  	mov	b,	#10
0164  84                   40  	div	ab
0165  28                   41  	add	a,	r0
0166  60 05                42  	jz	print_int_u8__ones
0168  98                   43  	subb	a,	r0
0169  24 30                44  	add	a,	#'0'
016B  11 EF                45  	acall	print_char
016D                       46  print_int_u8__ones:
016D  E5 F0                47  	mov	a,	b
016F  24 30                48  	add	a,	#'0'
0171  11 EF                49  	acall	print_char
0173                       50  
0173  D0 00                51  	pop	0
0175  D0 F0                52  	pop	B
0177  D0 E0                53  	pop	ACC
0179  22                   54  	ret
017A                       55  
017A                       56  ; >> void print_int_s16(int r0r1) <<
017A                       57  
017A                       58  ; Print signed integer from r0-r1.
017A                       59  
017A                       60  print_int_s16:
017A  C0 E0                61  	push	ACC
017C  C0 00                62  	push	0
017E  C0 01                63  	push	1
0180  E9                   64  	mov	a,	r1
0181  30 E7 16             65  	jnb	ACC.7,	print_int_u16__1
0184  74 2D                66  	mov	a,	#'-'
0186  11 EF                67  	acall	print_char
0188  E8                   68  	mov	a,	r0
0189  F4                   69  	cpl	a
018A  24 01                70  	add	a,	#1
018C  F8                   71  	mov	r0,	a
018D  E9                   72  	mov	a,	r1
018E  F4                   73  	cpl	a
018F  34 00                74  	addc	a,	#0
0191  F9                   75  	mov	r1,	a
0192  80 06                76  	sjmp	print_int_u16__1
0194                       77  
0194                       78  ; >> void print_int_u16(int r0r1) <<
0194                       79  
0194                       80  ; Print unsigned integer from r0-r1.
0194                       81  
0194                       82  print_int_u16:
0194  C0 E0                83  	push	ACC
0196  C0 00                84  	push	0
0198  C0 01                85  	push	1
019A                       86  print_int_u16__1:
019A  C0 02                87  	push	2
019C  C0 F0                88  	push	B
019E                       89  
019E  7A 00                90  	mov	r2,	#0 ; flag for leading zeroes
01A0                       91  
01A0                       92  	; divide by 10000 (0x2710)
01A0                       93  	; collect quotient in b
01A0  75 F0 FF             94  	mov	b,	#-1
01A3  C3                   95  	clr	c
01A4                       96  print_int_u16__10k_loop:
01A4  E8                   97  	mov	a,	r0
01A5  94 10                98  	subb	a,	#0x10
01A7  F8                   99  	mov	r0,	a
01A8  E9                  100  	mov	a,	r1
01A9  94 27               101  	subb	a,	#0x27
01AB  F9                  102  	mov	r1,	a
01AC  05 F0               103  	inc	b
01AE  50 F4               104  	jnc	print_int_u16__10k_loop
01B0                      105  	; undo last subtraction to restore remainder
01B0  E8                  106  	mov	a,	r0
01B1  24 10               107  	add	a,	#0x10
01B3  F8                  108  	mov	r0,	a
01B4  E9                  109  	mov	a,	r1
01B5  34 27               110  	addc	a,	#0x27
01B7  F9                  111  	mov	r1,	a
01B8                      112  	; print tenthousands digit
01B8  E5 F0               113  	mov	a,	b
01BA  60 05               114  	jz	print_int_u16__1k
01BC  24 30               115  	add	a,	#'0'
01BE  11 EF               116  	acall	print_char
01C0  0A                  117  	inc	r2
01C1                      118  print_int_u16__1k:
01C1                      119  	; divide by 1000 (0x03e8)
01C1                      120  	; collect quotient in b
01C1  75 F0 FF            121  	mov	b,	#-1
01C4  C3                  122  	clr	c
01C5                      123  print_int_u16__1k_loop:
01C5  E8                  124  	mov	a,	r0
01C6  94 E8               125  	subb	a,	#0xe8
01C8  F8                  126  	mov	r0,	a
01C9  E9                  127  	mov	a,	r1
01CA  94 03               128  	subb	a,	#0x03
01CC  F9                  129  	mov	r1,	a
01CD  05 F0               130  	inc	b
01CF  50 F4               131  	jnc	print_int_u16__1k_loop
01D1                      132  	; undo last subtraction to restore remainder
01D1  E8                  133  	mov	a,	r0
01D2  24 E8               134  	add	a,	#0xe8
01D4  F8                  135  	mov	r0,	a
01D5  E9                  136  	mov	a,	r1
01D6  34 03               137  	addc	a,	#0x03
01D8  F9                  138  	mov	r1,	a
01D9                      139  	; print thousands digit
01D9  E5 F0               140  	mov	a,	b
01DB  2A                  141  	add	a,	r2
01DC  60 06               142  	jz	print_int_u16__100
01DE  9A                  143  	subb	a,	r2
01DF  24 30               144  	add	a,	#'0'
01E1  11 EF               145  	acall	print_char
01E3  0A                  146  	inc	r2
01E4                      147  print_int_u16__100:
01E4                      148  	; divide by 100 (0x0064)
01E4                      149  	; collect quotient in b
01E4  75 F0 FF            150  	mov	b,	#-1
01E7  C3                  151  	clr	c
01E8                      152  print_int_u16__100_loop:
01E8  E8                  153  	mov	a,	r0
01E9  94 64               154  	subb	a,	#0x64
01EB  F8                  155  	mov	r0,	a
01EC  E9                  156  	mov	a,	r1
01ED  94 00               157  	subb	a,	#0x00
01EF  F9                  158  	mov	r1,	a
01F0  05 F0               159  	inc	b
01F2  50 F4               160  	jnc	print_int_u16__100_loop
01F4                      161  	; undo last subtraction to restore remainder
01F4  E8                  162  	mov	a,	r0
01F5  24 64               163  	add	a,	#0x64
01F7  F8                  164  	mov	r0,	a
01F8  E9                  165  	mov	a,	r1
01F9  34 00               166  	addc	a,	#0x00
01FB  F9                  167  	mov	r1,	a
01FC                      168  	; print hundreds digit
01FC  E5 F0               169  	mov	a,	b
01FE  2A                  170  	add	a,	r2
01FF  60 06               171  	jz	print_int_u16__tens
0201  9A                  172  	subb	a,	r2
0202  24 30               173  	add	a,	#'0'
0204  11 EF               174  	acall	print_char
0206  0A                  175  	inc	r2
0207                      176  print_int_u16__tens:
0207                      177  	; divide by 10 (using div instruction)
0207  E8                  178  	mov	a,	r0
0208  75 F0 0A            179  	mov	b,	#10
020B  84                  180  	div	ab
020C                      181  	; print tens digit
020C  2A                  182  	add	a,	r2
020D  60 05               183  	jz	print_int_u16__ones
020F  9A                  184  	subb	a,	r2
0210  24 30               185  	add	a,	#'0'
0212  11 EF               186  	acall	print_char
0214                      187  print_int_u16__ones:
0214                      188  	; print ones digit
0214  E5 F0               189  	mov	a,	b
0216  24 30               190  	add	a,	#'0'
0218  11 EF               191  	acall	print_char
021A                      192  
021A  D0 F0               193  	pop	B
021C  D0 02               194  	pop	2
021E  D0 01               195  	pop	1
0220  D0 00               196  	pop	0
0222  D0 E0               197  	pop	ACC
0224  22                  198  	ret
0225                      199  
0225                      200  ; >> void print_int_s32(long r0r1r2r3) <<
0225                      201  
0225                      202  ; Print signed integer from r0-r3.
0225                      203  
0225                      204  print_int_s32:
0225  C0 E0               205  	push	acc
0227  C0 F0               206  	push	b
0229  C0 82               207  	push	dpl
022B  C0 83               208  	push	dph
022D  C0 00               209  	push	0
022F  C0 01               210  	push	1
0231  C0 02               211  	push	2
0233  C0 03               212  	push	3
0235  C0 04               213  	push	4
0237  C0 05               214  	push	5
0239  C0 06               215  	push	6
023B  C0 07               216  	push	7
023D                      217  	; check sign bit (high byte of value is in r3)
023D  EB                  218  	mov	a,r3
023E  30 E7 32            219  	jnb	ACC.7,	print_int_u32__1
0241  74 2D               220  	mov	a,#'-'
0243  11 EF               221  	acall	print_char
0245                      222  	; negate r0-r3
0245  E8                  223  	mov	a,r0
0246  F4                  224  	cpl	a
0247  24 01               225  	add	a,#1
0249  F8                  226  	mov	r0,a
024A  E9                  227  	mov	a,r1
024B  F4                  228  	cpl	a
024C  34 00               229  	addc	a,#0
024E  F9                  230  	mov	r1,a
024F  EA                  231  	mov	a,r2
0250  F4                  232  	cpl	a
0251  34 00               233  	addc	a,#0
0253  FA                  234  	mov	r2,a
0254  EB                  235  	mov	a,r3
0255  F4                  236  	cpl	a
0256  34 00               237  	addc	a,#0
0258  FB                  238  	mov	r3,a
0259  80 18               239  	sjmp	print_int_u32__1
025B                      240  
025B                      241  
025B                      242  ; >> void print_int_u32(long r0r1r2r3) <<
025B                      243  
025B                      244  ; Print unsigned integer from r0-r3.
025B                      245  
025B                      246  print_int_u32:
025B  C0 E0               247  	push	acc
025D  C0 F0               248  	push	b
025F  C0 82               249  	push	dpl
0261  C0 83               250  	push	dph
0263  C0 00               251  	push	0
0265  C0 01               252  	push	1
0267  C0 02               253  	push	2
0269  C0 03               254  	push	3
026B  C0 04               255  	push	4
026D  C0 05               256  	push	5
026F  C0 06               257  	push	6
0271  C0 07               258  	push	7
0273                      259  print_int_u32__1:
0273                      260  	; value to print stays in r0-r3 throughout;
0273                      261  	; each digit's divisor is loaded into r4-r7.
0273  75 F0 00            262  	mov	b,#0 ; flag for leading zeroes
0276  90 02 B8            263  	mov	dptr,#print_int_u32__divisors
0279                      264  print_int_u32__loop:
0279                      265  	; load divisor into r4-r7
0279  E4                  266  	clr	a
027A  93                  267  	movc	a,@a+dptr
027B  FC                  268  	mov	r4,a
027C  A3                  269  	inc	dptr
027D  E4                  270  	clr	a
027E  93                  271  	movc	a,@a+dptr
027F  FD                  272  	mov	r5,a
0280  A3                  273  	inc	dptr
0281  E4                  274  	clr	a
0282  93                  275  	movc	a,@a+dptr
0283  FE                  276  	mov	r6,a
0284  A3                  277  	inc	dptr
0285  E4                  278  	clr	a
0286  93                  279  	movc	a,@a+dptr
0287  FF                  280  	mov	r7,a
0288  A3                  281  	inc	dptr
0289                      282  	; divide r0-r3 by r4-r7 (quotient in a, remainder in r0-r3)
0289  51 DC               283  	acall	print_int_u32__divide
028B  25 F0               284  	add	a,b
028D  60 08               285  	jz	print_int_u32__skip ; leading zero
028F  95 F0               286  	subb	a,b
0291  24 30               287  	add	a,#'0'
0293  05 F0               288  	inc	b
0295  11 EF               289  	acall	print_char
0297                      290  print_int_u32__skip:
0297  BC 0A DF            291  	cjne	r4,#0x0a,	print_int_u32__loop
029A  E8                  292  	mov	a,r0
029B  24 30               293  	add	a,#'0'
029D  11 EF               294  	acall	print_char
029F                      295  
029F  D0 07               296  	pop	7
02A1  D0 06               297  	pop	6
02A3  D0 05               298  	pop	5
02A5  D0 04               299  	pop	4
02A7  D0 03               300  	pop	3
02A9  D0 02               301  	pop	2
02AB  D0 01               302  	pop	1
02AD  D0 00               303  	pop	0
02AF  D0 83               304  	pop	dph
02B1  D0 82               305  	pop	dpl
02B3  D0 F0               306  	pop	b
02B5  D0 E0               307  	pop	acc
02B7  22                  308  	ret
02B8                      309  ; Divisor table:
02B8                      310  print_int_u32__divisors:
02B8                      311  	; 1,000,000,000 = 3b9aca00
02B8  00 CA 9A 3B         312  	.db	0x00, 0xca, 0x9a, 0x3b
02BC                      313  	;   100,000,000 = 05f5e100
02BC  00 E1 F5 05         314  	.db	0x00, 0xe1, 0xf5, 0x05
02C0                      315  	;    10,000,000 = 00989680
02C0  80 96 98 00         316  	.db	0x80, 0x96, 0x98, 0x00
02C4                      317  	;     1,000,000 = 000f4240
02C4  40 42 0F 00         318  	.db	0x40, 0x42, 0x0f, 0x00
02C8                      319  	;       100,000 = 000186a0
02C8  A0 86 01 00         320  	.db	0xa0, 0x86, 0x01, 0x00
02CC                      321  	;        10,000 = 00002710
02CC  10 27 00 00         322  	.db	0x10, 0x27, 0x00, 0x00
02D0                      323  	;         1,000 = 000003e8
02D0  E8 03 00 00         324  	.db	0xe8, 0x03, 0x00, 0x00
02D4                      325  	;           100 = 00000064
02D4  64 00 00 00         326  	.db	0x64, 0x00, 0x00, 0x00
02D8                      327  	;            10 = 0000000a
02D8  0A 00 00 00         328  	.db	0x0a, 0x00, 0x00, 0x00
02DC                      329  ; Divide r0-r3 by r4-r7 using repeated subtraction.
02DC                      330  ; Quotient returned in a, remainder in r0-r3.
02DC                      331  ; Since the quotient is at most 9,
02DC                      332  ; this is faster than 'proper' division.
02DC                      333  print_int_u32__divide:
02DC  C0 F0               334  	push	b
02DE  C3                  335  	clr	c
02DF  75 F0 FF            336  	mov	b,#-1
02E2                      337  print_int_u32__divide_loop:
02E2  E8                  338  	mov	a,r0
02E3  9C                  339  	subb	a,r4
02E4  F8                  340  	mov	r0,a
02E5  E9                  341  	mov	a,r1
02E6  9D                  342  	subb	a,r5
02E7  F9                  343  	mov	r1,a
02E8  EA                  344  	mov	a,r2
02E9  9E                  345  	subb	a,r6
02EA  FA                  346  	mov	r2,a
02EB  EB                  347  	mov	a,r3
02EC  9F                  348  	subb	a,r7
02ED  FB                  349  	mov	r3,a
02EE  05 F0               350  	inc	b
02F0  50 F0               351  	jnc	print_int_u32__divide_loop
02F2                      352  	; restore remainder
02F2  E8                  353  	mov	a,r0
02F3  2C                  354  	add	a,r4
02F4  F8                  355  	mov	r0,a
02F5  E9                  356  	mov	a,r1
02F6  3D                  357  	addc	a,r5
02F7  F9                  358  	mov	r1,a
02F8  EA                  359  	mov	a,r2
02F9  3E                  360  	addc	a,r6
02FA  FA                  361  	mov	r2,a
02FB  EB                  362  	mov	a,r3
02FC  3F                  363  	addc	a,r7
02FD  FB                  364  	mov	r3,a
02FE  E5 F0               365  	mov	a,b
0300  D0 F0               366  	pop	b
0302  22                  367  	ret
0303                      368  
