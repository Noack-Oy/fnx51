001D                       24  ; *** test/stream_xram.asm ***
001D                       25  
001D  11 81                26  	acall	serial_init
001F                       27  
001F  C0 8E                28  	push	auxr
0021                       29  	; use xram
0021  53 8E E1             30  	anl	auxr,#0xe1	; clear extram, xrs0-2
0024  43 8E 10             31  	orl	auxr,#0x10	; set xrs2 (size 1792 bytes)
0027                       32  
0027                       33  	; clear xram with dummy value
0027  90 00 00             34  	mov	dptr,#0
002A                       35  memory_init__1:
002A  74 24                36  	mov	a,#0x24
002C  F0                   37  	movx	@dptr,a
002D  A3                   38  	inc	dptr
002E  74 07                39  	mov	a,#0x07 ; xram goes up to 0x06ff
0030  B5 83 F7             40  	cjne	a,dph,memory_init__1
0033                       41  
0033                       42  	; disable xram again, stram_xram should enable it temporarily
0033  43 8E 02             43  	orl	auxr,#0x02	; set EXTRAM bit
0036                       44  
0180                       45  .equ	scratch,	0x180
0036                       46  
0036  C0 32                47  	push	out
0038  C0 33                48  	push	out+1
003A  90 00 CE             49  	mov	dptr,	#stream_xram_write
003D  85 82 32             50  	mov	out,	dpl
0040  85 83 33             51  	mov	out+1,	dph
0043  90 01 80             52  	mov	dptr,	#scratch
0046  85 82 36             53  	mov	stream_out,	dpl
0049  85 83 37             54  	mov	stream_out+1,	dph
004C  90 00 73             55  	mov	dptr,	#test_message
004F  11 F4                56  	acall	print_text
0051  A8 36                57  	mov	r0,	stream_out
0053  A9 37                58  	mov	r1,	stream_out+1
0055  31 94                59  	acall	print_int_u16
0057  D0 33                60  	pop	out+1
0059  D0 32                61  	pop	out
005B                       62  
005B  E4                   63  	clr	a
005C  FB                   64  	mov	r3,	a
005D  FA                   65  	mov	r2,	a
005E  F9                   66  	mov	r1,	a
005F  F8                   67  	mov	r0,	a
0060  F5 34                68  	mov	stream_in,	a
0062  F5 35                69  	mov	stream_in+1,	a
0064  90 00 AD             70  	mov	dptr,	#stream_xram_read
0067  85 82 30             71  	mov	in,	dpl
006A  85 83 31             72  	mov	in+1,	dph
006D  71 08                73  	acall	dump
006F  71 08                74  	acall	dump
0071                       75  
0071  80 FE                76  	sjmp	*
0073                       77  
