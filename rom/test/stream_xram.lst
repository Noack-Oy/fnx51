                         ; ==== ../serial/init.inc ====
0081                        1  
0081                        2  ; *** serial/init.inc ***
0081                        3  
0081                        4  ; >> void serial_init() <<
0081                        5  
0081                        6  ; Initialize serial interface.
0081                        7  ; - assumes 20MHz clock and X2 mode
0081                        8  ; - uses internal baud rate generator
0081                        9  ; - speed: 9600 bits per second
0081                       10  ; Formula: BRL = 256 - (F_clk / (32 * Baud_Rate))
0081                       11  ; ---
0081                       12  ; See datasheet page 52 for details,
0081                       13  ; also note oscillator diagram on page 16!
0081                       14  
0081                       15  serial_init:
0081  75 98 52             16  	mov	SCON,	#0x52	; SM1, REN, TI
0084  75 9A BF             17  	mov	BRL,	#191	; 9600 @20MHz CLK
0087  75 9B 1E             18  	mov	BDRCON, #0x1e	; BRR, RBCK, TBCK, SPD
008A                       19  
008A  90 00 9D             20  	mov	dptr,	#serial_rx
008D  85 82 30             21  	mov	IN,	DPL
0090  85 83 31             22  	mov	IN+1,	DPH
0093                       23  
0093  90 00 A5             24  	mov	dptr,	#serial_tx
0096  85 82 32             25  	mov	OUT,	DPL
0099  85 83 33             26  	mov	OUT+1,	DPH
009C                       27  
009C  22                   28  	ret
009D                       29  
                         ; ==== stream_xram.asm ====
009D                       88  .include ../serial/rx.inc
                         ; ==== ../serial/rx.inc ====
009D                        1  
009D                        2  ; *** serial/rx.inc ***
009D                        3  
009D                        4  ; >> char serial_rx <<
009D                        5  
009D                        6  ; Receive byte into accumulator.
009D                        7  
009D                        8  serial_rx:
009D  30 98 FD              9  	jnb	RI,	serial_rx
00A0  C2 98                10  	clr	RI
00A2  E5 99                11  	mov	a,	SBUF
00A4  22                   12  	ret
00A5                       13  
                         ; ==== stream_xram.asm ====
00A5                       89  .include ../serial/tx.inc
                         ; ==== ../serial/tx.inc ====
00A5                        1  
00A5                        2  ; *** serial/tx.inc ***
00A5                        3  
00A5                        4  ; >> void serial_tx(char a) <<
00A5                        5  
00A5                        6  ; Transmit byte from accumulator.
00A5                        7  
00A5                        8  serial_tx:
00A5  30 99 FD              9  	jnb	TI,	serial_tx
00A8  C2 99                10  	clr	TI
00AA  F5 99                11  	mov	SBUF,	a
00AC  22                   12  	ret
00AD                       13  
                         ; ==== stream_xram.asm ====
00AD                       90  .include ../stream/xram_read.inc
                         ; ==== ../stream/xram_read.inc ====
00AD                        1  
00AD                        2  ; *** stream/xram_read.inc ***
00AD                        3  
00AD                        4  ; >> char{a} stream_xram_read() <<
00AD                        5  
00AD                        6  ; Read byte from on-chip expanded RAM at stream input pointer.
00AD                        7  ; 16 bit value of the stream pointer is used and incremented.
00AD                        8  
00AD                        9  stream_xram_read:
00AD  C0 8E                10  	push	auxr
00AF  C0 82                11  	push	dpl
00B1  C0 83                12  	push	dph
00B3                       13  
00B3  53 8E E1             14  	anl	auxr,#0xe1	; clear extram, xrs0-2
00B6  43 8E 10             15  	orl	auxr,#0x10	; set xrs2 (size 1792 bytes)
00B9                       16  
00B9  85 34 82             17  	mov	dpl,stream_in
00BC  85 35 83             18  	mov	dph,stream_in+1
00BF                       19  
00BF  E0                   20  	movx	a,@dptr
00C0  A3                   21  	inc	dptr
00C1  85 82 34             22  	mov	stream_in,dpl
00C4  85 83 35             23  	mov	stream_in+1,dph
00C7                       24  
00C7  D0 83                25  	pop	dph
00C9  D0 82                26  	pop	dpl
00CB  D0 8E                27  	pop	auxr
00CD  22                   28  	ret
00CE                       29  
                         ; ==== stream_xram.asm ====
00CE                       91  .include ../stream/xram_write.inc
                         ; ==== ../stream/xram_write.inc ====
00CE                        1  
00CE                        2  ; *** stream/xram_write.inc ***
00CE                        3  
00CE                        4  ; >> void stream_xram_write(char a) <<
00CE                        5  
00CE                        6  ; Write byte to on-chip expanded RAM at stream output pointer.
00CE                        7  ; 16-bit value of the stream pointer is used and incremented.
00CE                        8  
00CE                        9  stream_xram_write:
00CE  C0 8E                10  	push	auxr
00D0  C0 82                11  	push	dpl
00D2  C0 83                12  	push	dph
00D4                       13  
00D4  53 8E E1             14  	anl	auxr,#0xe1	; clear extram, xrs0-2
00D7  43 8E 10             15  	orl	auxr,#0x10	; set xrs2 (size 1792 bytes)
00DA                       16  
00DA  85 36 82             17  	mov	dpl,stream_out
00DD  85 37 83             18  	mov	dph,stream_out+1
00E0                       19  
00E0  F0                   20  	movx	@dptr,a
00E1  A3                   21  	inc	dptr
00E2  85 82 36             22  	mov	stream_out,dpl
00E5  85 83 37             23  	mov	stream_out+1,dph
00E8                       24  
00E8  D0 83                25  	pop	dph
00EA  D0 82                26  	pop	dpl
00EC  D0 8E                27  	pop	auxr
00EE  22                   28  	ret
00EF                       29  
                         ; ==== stream_xram.asm ====
