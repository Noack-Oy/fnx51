0216: E5 F0                mov     a,      b
0218: 24 30                add     a,      #'0'
021A: 11 EF                acall   print_char
                   
021C: D0 F0                pop     B
021E: D0 02                pop     2
0220: D0 01                pop     1
0222: D0 00                pop     0
0224: D0 E0                pop     ACC
0226: 22                   ret
                   
                   ; >> void print_int_s32(long r0r1r2r3) <<
                   
