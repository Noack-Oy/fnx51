0303                        2  ; *** read/char.inc ***
0303                        3  
0303                        4  ; >> char read_char() <<
0303                        5  
0303                        6  ; Read char into accumulator.
0303                        7  ; Indirect call to function behind IN pointer.
0303                        8  
0303                        9  read_char:
0303  C0 30                10  	push	IN
0305  C0 31                11  	push	IN+1
0307  22                   12  	ret
0308                       13  
