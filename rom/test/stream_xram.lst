0308                       97  .include ../util/dump.inc
                         ; ==== ../util/dump.inc ====
0308                        1  
0308                        2  ; *** util/dump.inc ***
0308                        3  
0308                        4  ; >> uint32{r0-r3} dump(uint32{r0-r3} addr, uint8{a} count) <<
0308                        5  
0308                        6  ; Print hexdump from standard input to standard output.
0308                        7  ; Starting value for address column in r0-r3.
0308                        8  ; Number of bytes to print in a (0 means 256).
0308                        9  ; r0-r3 contains next address upon exit.
0308                       10  
0308                       11  dump:
0308  C0 F0                12  	push	b
030A  C0 E0                13  	push	acc
030C  F5 F0                14  	mov	b,	a
030E  C0 04                15  	push	4
0310  C0 05                16  	push	5
0312  C0 06                17  	push	6
0314  C0 07                18  	push	7
0316                       19  
0316                       20  	; b: total bytes remaining
0316                       21  	; r0: buffer pointer
0316                       22  	; r1: read loop counter / padding size
0316                       23  	; r2: print loop counter
0316                       24  
0316                       25  	; r4-7: address label
0316  71 BC                26  	acall	xch_r0123_r4567
0318                       27  
0318                       28  	; allocate 16 byte array on stack
0318  E5 81                29  	mov	a,	sp
031A  F8                   30  	mov	r0,	a
031B  24 10                31  	add	a,	#16
031D  F5 81                32  	mov	sp,	a
031F                       33  
031F                       34  dump__line_loop:
031F                       35  	; read into buffer
031F  79 10                36  	mov	r1,	#16
0321                       37  dump__read_loop:
0321  71 03                38  	acall	read_char
0323  08                   39  	inc	r0
0324  F6                   40  	mov	@r0,	a
0325  D5 F0 03             41  	djnz	b,	dump__read_continue
0328  19                   42  	dec	r1
0329  80 02                43  	sjmp	dump__read_end
032B                       44  dump__read_continue:
032B  D9 F4                45  	djnz	r1,	dump__read_loop
032D                       46  dump__read_end:
032D                       47  
032D                       48  	; print address column
032D  71 BC                49  	acall	xch_r0123_r4567
032F  31 28                50  	acall	print_hex_32
0331  71 BC                51  	acall	xch_r0123_r4567
0333  74 3A                52  	mov	a,	#':'
0335  11 EF                53  	acall	print_char
0337                       54  
0337                       55  	; if r1 is nonzero here, we have a shorter line
0337                       56  	; the value in r1 is the number of padding bytes
0337                       57  
0337                       58  	; wind back pointer
0337  E8                   59  	mov	a,	r0
0338  24 F0                60  	add	a,	#-16
033A  29                   61  	add	a,	r1
033B  F8                   62  	mov	r0,	a
033C                       63  
033C                       64  	; print hex
033C  7A 10                65  	mov	r2,	#16
033E                       66  dump__print_hex_loop:
033E  08                   67  	inc	r0
033F  EA                   68  	mov	a,	r2
0340  54 03                69  	anl	a,	#3	; mod 4
0342  70 04                70  	jnz	dump__print_hex_no_gap
0344  74 20                71  	mov	a,	#' ' ; gap after every 4 bytes
0346  11 EF                72  	acall	print_char
0348                       73  dump__print_hex_no_gap:
0348  EA                   74  	mov	a,	r2
0349  D3                   75  	setb	c
034A  99                   76  	subb	a,	r1
034B  50 08                77  	jnc	dump__print_hex_no_padding
034D  74 20                78  	mov	a,	#' ' ; padding for shorter line
034F  11 EF                79  	acall	print_char
0351  11 EF                80  	acall	print_char
0353  80 03                81  	sjmp	dump__print_hex_next
0355                       82  dump__print_hex_no_padding:
0355  E6                   83  	mov	a,	@r0
0356  31 08                84  	acall	print_hex_8
0358                       85  dump__print_hex_next:
0358  74 20                86  	mov	a,	#' ' ; space between bytes
035A  11 EF                87  	acall	print_char
035C  DA E0                88  	djnz	r2,	dump__print_hex_loop
035E                       89  
035E                       90  	; wind back again
035E  E8                   91  	mov	a,	r0
035F  24 F0                92  	add	a,	#-16
0361  F8                   93  	mov	r0,	a
0362                       94  
0362                       95  	; print ascii
0362  74 20                96  	mov	a,	#' '
0364  11 EF                97  	acall	print_char
0366  74 7C                98  	mov	a,	#'|'
0368  11 EF                99  	acall	print_char
036A  74 10               100  	mov	a,	#16
036C  C3                  101  	clr	c
036D  99                  102  	subb	a,	r1
036E  F9                  103  	mov	r1,	a ; number of bytes to print
036F  FA                  104  	mov	r2,	a
0370                      105  dump__print_ascii_loop:
0370  08                  106  	inc	r0
0371  E6                  107  	mov	a,	@r0
0372  B4 20 00            108  	cjne	a,	#0x20,	dump__print_ascii_check1
0375                      109  dump__print_ascii_check1:
0375  40 05               110  	jc	dump__print_ascii_replace
0377  B4 7F 00            111  	cjne	a,	#0x7f,	dump__print_ascii_check2
037A                      112  dump__print_ascii_check2:
037A  40 02               113  	jc	dump__print_ascii_continue
037C                      114  dump__print_ascii_replace:
037C  74 2E               115  	mov	a,	#'.'
037E                      116  dump__print_ascii_continue:
037E  11 EF               117  	acall	print_char
0380  DA EE               118  	djnz	r2,	dump__print_ascii_loop
0382  74 7C               119  	mov	a,	#'|'
0384  11 EF               120  	acall	print_char
0386  74 0D               121  	mov	a,	#13
0388  11 EF               122  	acall	print_char
038A  74 0A               123  	mov	a,	#10
038C  11 EF               124  	acall	print_char
038E                      125  
038E                      126  	; wind back again
038E  E8                  127  	mov	a,	r0
038F  24 F0               128  	add	a,	#-16
0391  F8                  129  	mov	r0,	a
0392                      130  
0392                      131  	; next address
0392  EC                  132  	mov	a,	r4
0393  29                  133  	add	a,	r1
0394  FC                  134  	mov	r4,	a
0395  ED                  135  	mov	a,	r5
0396  34 00               136  	addc	a,	#0
0398  FD                  137  	mov	r5,	a
0399  EE                  138  	mov	a,	r6
039A  34 00               139  	addc	a,	#0
039C  FE                  140  	mov	r6,	a
039D  EF                  141  	mov	a,	r7
039E  34 00               142  	addc	a,	#0
03A0  FF                  143  	mov	r7,	a
03A1                      144  
03A1  E5 F0               145  	mov	a,	b
03A3  60 02               146  	jz	dump__end
03A5  61 1F               147  	ajmp	dump__line_loop
03A7                      148  
03A7                      149  dump__end:
03A7                      150  	; deallocate array from stack
03A7  E5 81               151  	mov	a,	sp
03A9  24 F0               152  	add	a,	#-16
03AB  F5 81               153  	mov	sp,	a
03AD                      154  
03AD  71 BC               155  	acall	xch_r0123_r4567
03AF                      156  
03AF  D0 07               157  	pop	7
03B1  D0 06               158  	pop	6
03B3  D0 05               159  	pop	5
03B5  D0 04               160  	pop	4
03B7  D0 E0               161  	pop	acc
03B9  D0 F0               162  	pop	b
03BB  22                  163  	ret
03BC                      164  
