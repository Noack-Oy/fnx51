0191: F9                   mov     r1,     a
0192: 80 06                sjmp    print_int_u16__1
                   
                   ; >> void print_int_u16(int r0r1) <<
                   
                   ; Print unsigned integer from r0-r1.
                   
                   print_int_u16:
0194: C0 E0                push    ACC
0196: C0 00                push    0
0198: C0 01                push    1
                   print_int_u16__1:
019A: C0 02                push    2
019C: C0 F0                push    B
                   
019E: 7A 00                mov     r2,     #0 ; flag for leading zeroes
                   
                           ; divide by 10000 (0x2710)
                           ; collect quotient in b
01A0: 75 F0 FF             mov     b,      #-1
01A3: C3                   clr     c
                   print_int_u16__10k_loop:
01A4: E8                   mov     a,      r0
