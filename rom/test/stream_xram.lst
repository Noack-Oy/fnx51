                         ; ==== ../print/char.inc ====
00EF                        1  
00EF                        2  ; *** print/char.inc ***
00EF                        3  
00EF                        4  ; >> void print_char(char a) <<
00EF                        5  
00EF                        6  ; Print char from accumulator.
00EF                        7  ; Indirect call to function behind OUT pointer.
00EF                        8  
00EF                        9  print_char:
00EF  C0 32                10  	push	OUT
00F1  C0 33                11  	push	OUT+1
00F3  22                   12  	ret
00F4                       13  
                         ; ==== stream_xram.asm ====
00F4                       93  .include ../print/text.inc
                         ; ==== ../print/text.inc ====
00F4                        1  
00F4                        2  ; *** print/text.inc ***
00F4                        3  
00F4                        4  ; >> void print_text(char* dptr) <<
00F4                        5  
00F4                        6  ; Print null-terminated string from program code.
00F4                        7  ; Aborts if no null terminator is found after 256 bytes.
00F4                        8  
00F4                        9  print_text:
00F4  C0 E0                10  	push	ACC
00F6  C0 00                11  	push	0
00F8                       12  
00F8  E4                   13  	clr	a
00F9  F8                   14  	mov	r0,	a
00FA                       15  print_text__loop:
00FA  93                   16  	movc	a,	@a+dptr
00FB  60 06                17  	jz	print_text__end
00FD  11 EF                18  	acall	print_char
00FF  08                   19  	inc	r0
0100  E8                   20  	mov	a,	r0
0101  70 F7                21  	jnz	print_text__loop
0103                       22  
0103                       23  print_text__end:
0103  D0 00                24  	pop	0
0105  D0 E0                25  	pop	ACC
0107  22                   26  	ret
0108                       27  
                         ; ==== stream_xram.asm ====
0108                       94  .include ../print/hex.inc
                         ; ==== ../print/hex.inc ====
0108                        1  
0108                        2  ; *** print/hex.inc ***
0108                        3  
0108                        4  ; >> void print_hex_8(char a) <<
0108                        5  
0108                        6  ; Print hexadecimal number from accumulator.
0108                        7  
0108                        8  print_hex_8:
0108  C4                    9  	swap	a	; high nibble first
0109  31 0C                10  	acall	print_hex_8__nibble
010B  C4                   11  	swap	a
010C                       12  print_hex_8__nibble:
010C  C0 E0                13  	push	ACC
010E  54 0F                14  	anl	a,	#0x0f
0110  24 90                15  	add	a,	#0x90
0112  D4                   16  	da	a
0113  34 40                17  	addc	a,	#0x40
0115  D4                   18  	da	a
0116  44 20                19  	orl	a,	#0x20	; lower case
0118  11 EF                20  	acall	print_char
011A  D0 E0                21  	pop	ACC
011C  22                   22  	ret
011D                       23  
011D                       24  ; >> void print_hex_16(int r0r1) <<
011D                       25  
011D                       26  ; Print hexadecimal number from r0-r1.
011D                       27  
011D                       28  print_hex_16:
011D  C0 E0                29  	push	ACC
011F  E9                   30  	mov	a,	r1	; MSB first
0120  31 08                31  	acall	print_hex_8
0122  E8                   32  	mov	a,	r0	; LSB second
0123  31 08                33  	acall	print_hex_8
0125  D0 E0                34  	pop	ACC
0127  22                   35  	ret
0128                       36  
0128                       37  ; >> void print_hex_32(long r0r1r2r3) <<
0128                       38  
0128                       39  ; Print hexadecimal number from r0-r3.
0128                       40  
0128                       41  print_hex_32:
0128  C0 E0                42  	push	ACC
012A  EB                   43  	mov	a,	r3	; MSB first
012B  31 08                44  	acall	print_hex_8
012D  EA                   45  	mov	a,	r2
012E  31 08                46  	acall	print_hex_8
0130  E9                   47  	mov	a,	r1
0131  31 08                48  	acall	print_hex_8
0133  E8                   49  	mov	a,	r0	; LSB last
0134  31 08                50  	acall	print_hex_8
0136  D0 E0                51  	pop	ACC
0138  22                   52  	ret
0139                       53  
