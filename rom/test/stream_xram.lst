03BC                       98  .include ../util/xch.inc
                         ; ==== ../util/xch.inc ====
03BC                        1  
03BC                        2  ; *** util/xch.inc ***
03BC                        3  
03BC                        4  ; >> void xch_r0123_r4567(uint32 &r0r1r2r3, uint32 &r4r5r6r7) <<
03BC                        5  
03BC                        6  ; Exchange registers r0-r3 with r4-r7.
03BC                        7  
03BC                        8  xch_r0123_r4567:
03BC                        9  	; r0 <-> r4
03BC  C8                   10  	xch	a,	r0
03BD  CC                   11  	xch	a,	r4
03BE  C8                   12  	xch	a,	r0
03BF                       13  	; r1 <-> r5
03BF  C9                   14  	xch	a,	r1
03C0  CD                   15  	xch	a,	r5
03C1  C9                   16  	xch	a,	r1
03C2                       17  	; r2 <-> r6
03C2  CA                   18  	xch	a,	r2
03C3  CE                   19  	xch	a,	r6
03C4  CA                   20  	xch	a,	r2
03C5                       21  	; r3 <-> r7
03C5  CB                   22  	xch	a,	r3
03C6  CF                   23  	xch	a,	r7
03C7  CB                   24  	xch	a,	r3
03C8                       25  	; a remains unchanged
03C8  22                   26  	ret
03C9                       27  
                         ; ==== stream_xram.asm ====
03C9                       99  
00A5                      100  .equ panic_out, serial_tx
03C9                      101  .include ../util/panic.inc
                         ; ==== ../util/panic.inc ====
03C9                        1  
03C9                        2  ; *** panic/panic.inc ***
03C9                        3  
03C9                        4  ; >> void panic() <<
03C9                        5  
03C9                        6  ; Unrecoverable error handler.
03C9                        7  ; Print caller address and halt.
03C9                        8  
03C9                        9  panic:
03C9  C2 AF                10  	clr	ea	; disable interrupts
03CB  F8                   11  	mov	r0,a	; save a
03CC                       12  	; display panic text
03CC  90 00 A5             13  	mov	dptr,#panic_out
03CF  85 82 32             14  	mov	out,dpl
03D2  85 83 33             15  	mov	out+1,dph
03D5  90 03 FC             16  	mov	dptr,#panic_text
03D8  11 F4                17  	acall	print_text
03DA                       18  	; get return address from stack
03DA  D0 E0                19  	pop	acc
03DC  FA                   20  	mov	r2,a
03DD  D0 E0                21  	pop	acc
03DF                       22  	; subtract two to get call instruction address
03DF  C3                   23  	clr	c
03E0  94 02                24  	subb	a,#2
03E2  F9                   25  	mov	r1,a
03E3  EA                   26  	mov	a,r2
03E4  94 00                27  	subb	a,#0
03E6                       28  	; print caller address (to look up cause in .lst file)
03E6  31 08                29  	acall	print_hex_8
03E8  E9                   30  	mov	a,r1
03E9  31 08                31  	acall	print_hex_8
03EB                       32  	; print original value of a (error code / debug info)
03EB  74 20                33  	mov	a,#' '
03ED  11 EF                34  	acall	print_char
03EF  E8                   35  	mov	a,r0
03F0  31 08                36  	acall	print_hex_8
03F2                       37  	; newline
03F2  74 0D                38  	mov	a,#13
03F4  11 EF                39  	acall	print_char
03F6  74 0A                40  	mov	a,#10
03F8  11 EF                41  	acall	print_char
03FA                       42  	; hang
03FA  80 FE                43  	sjmp	*
03FC                       44  
03FC                       45  panic_text:
03FC  0D 0A                46  	.db	13, 10
03FE  20 21 21 21 20 70    47  	.db	" !!! panic @"
