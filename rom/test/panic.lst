0045                       41  .equ panic_out, serial_tx
0097                       42  .include ../util/panic.inc
                         ; ==== ../util/panic.inc ====
0097                        1  
0097                        2  ; *** panic/panic.inc ***
0097                        3  
0097                        4  ; >> void panic() <<
0097                        5  
0097                        6  ; Unrecoverable error handler.
0097                        7  ; Print caller address and halt.
0097                        8  
0097                        9  panic:
0097  C2 AF                10  	clr	ea	; disable interrupts
0099  F8                   11  	mov	r0,a	; save a
009A                       12  	; display panic text
009A  90 00 45             13  	mov	dptr,#panic_out
009D  85 82 32             14  	mov	out,dpl
00A0  85 83 33             15  	mov	out+1,dph
00A3  90 00 CA             16  	mov	dptr,#panic_text
00A6  11 52                17  	acall	print_text
00A8                       18  	; get return address from stack
00A8  D0 E0                19  	pop	acc
00AA  FA                   20  	mov	r2,a
00AB  D0 E0                21  	pop	acc
00AD                       22  	; subtract two to get call instruction address
00AD  C3                   23  	clr	c
00AE  94 02                24  	subb	a,#2
00B0  F9                   25  	mov	r1,a
00B1  EA                   26  	mov	a,r2
00B2  94 00                27  	subb	a,#0
00B4                       28  	; print caller address (to look up cause in .lst file)
00B4  11 66                29  	acall	print_hex_8
00B6  E9                   30  	mov	a,r1
00B7  11 66                31  	acall	print_hex_8
00B9                       32  	; print original value of a (error code / debug info)
00B9  74 20                33  	mov	a,#' '
00BB  11 4D                34  	acall	print_char
00BD  E8                   35  	mov	a,r0
00BE  11 66                36  	acall	print_hex_8
00C0                       37  	; newline
00C0  74 0D                38  	mov	a,#13
00C2  11 4D                39  	acall	print_char
00C4  74 0A                40  	mov	a,#10
00C6  11 4D                41  	acall	print_char
00C8                       42  	; hang
00C8  80 FE                43  	sjmp	*
00CA                       44  
00CA                       45  panic_text:
00CA  0D 0A                46  	.db	13, 10
00CC  20 21 21 21 20 70    47  	.db	" !!! panic @"
00D2  61 6E 69 63 20 40
00D8  00                   48  	.db	0
00D9                       49  
                         ; ==== panic.asm ====
00D9                       43  
