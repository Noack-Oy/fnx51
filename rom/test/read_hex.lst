00B6                       42  .include ../print/hex.inc
                         ; ==== ../print/hex.inc ====
00B6                        1  
00B6                        2  ; *** print/hex.inc ***
00B6                        3  
00B6                        4  ; >> void print_hex_8(char a) <<
00B6                        5  
00B6                        6  ; Print hexadecimal number from accumulator.
00B6                        7  
00B6                        8  print_hex_8:
00B6  C4                    9  	swap	a	; high nibble first
00B7  11 BA                10  	acall	print_hex_8__nibble
00B9  C4                   11  	swap	a
00BA                       12  print_hex_8__nibble:
00BA  C0 E0                13  	push	ACC
00BC  54 0F                14  	anl	a,	#0x0f
00BE  24 90                15  	add	a,	#0x90
00C0  D4                   16  	da	a
00C1  34 40                17  	addc	a,	#0x40
00C3  D4                   18  	da	a
00C4  44 20                19  	orl	a,	#0x20	; lower case
00C6  11 B1                20  	acall	print_char
00C8  D0 E0                21  	pop	ACC
00CA  22                   22  	ret
00CB                       23  
00CB                       24  ; >> void print_hex_16(int r0r1) <<
00CB                       25  
00CB                       26  ; Print hexadecimal number from r0-r1.
00CB                       27  
00CB                       28  print_hex_16:
00CB  C0 E0                29  	push	ACC
00CD  E9                   30  	mov	a,	r1	; MSB first
00CE  11 B6                31  	acall	print_hex_8
00D0  E8                   32  	mov	a,	r0	; LSB second
00D1  11 B6                33  	acall	print_hex_8
00D3  D0 E0                34  	pop	ACC
00D5  22                   35  	ret
00D6                       36  
00D6                       37  ; >> void print_hex_32(long r0r1r2r3) <<
00D6                       38  
00D6                       39  ; Print hexadecimal number from r0-r3.
00D6                       40  
00D6                       41  print_hex_32:
00D6  C0 E0                42  	push	ACC
00D8  EB                   43  	mov	a,	r3	; MSB first
00D9  11 B6                44  	acall	print_hex_8
00DB  EA                   45  	mov	a,	r2
00DC  11 B6                46  	acall	print_hex_8
00DE  E9                   47  	mov	a,	r1
00DF  11 B6                48  	acall	print_hex_8
00E1  E8                   49  	mov	a,	r0	; LSB last
00E2  11 B6                50  	acall	print_hex_8
00E4  D0 E0                51  	pop	ACC
00E6  22                   52  	ret
00E7                       53  
