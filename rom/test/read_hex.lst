00B1                        2  ; *** print/char.inc ***
00B1                        3  
00B1                        4  ; >> void print_char(char a) <<
00B1                        5  
00B1                        6  ; Print char from accumulator.
00B1                        7  ; Indirect call to function behind OUT pointer.
00B1                        8  
00B1                        9  print_char:
00B1  C0 32                10  	push	OUT
00B3  C0 33                11  	push	OUT+1
00B5  22                   12  	ret
