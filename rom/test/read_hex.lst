001D  11 25                25  	acall	serial_init
001F                       26  
001F                       27  loop:
001F  11 56                28  	acall	read_hex_32
0021  11 D6                29  	acall	print_hex_32
0023  80 FA                30  	sjmp	loop
0025                       31  
