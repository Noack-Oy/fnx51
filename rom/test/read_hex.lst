                         ; ==== ../read/char.inc ====
0051                        1  
0051                        2  ; *** read/char.inc ***
0051                        3  
0051                        4  ; >> char read_char() <<
0051                        5  
0051                        6  ; Read char into accumulator.
0051                        7  ; Indirect call to function behind IN pointer.
0051                        8  
0051                        9  read_char:
0051  C0 30                10  	push	IN
0053  C0 31                11  	push	IN+1
0055  22                   12  	ret
0056                       13  
                         ; ==== read_hex.asm ====
0056                       40  .include ../read/hex.inc
                         ; ==== ../read/hex.inc ====
0056                        1  
0056                        2  ; *** read/char.inc ***
0056                        3  
0056                        4  ; >> uint32 read_hex_32() <<
0056                        5  
0056                        6  ; Read 32 bit hex integer from input into r0-r3.
0056                        7  ; Stops at the first non-hex character or integer overflow.
0056                        8  
0056                        9  read_hex_32:
0056  C0 E0                10  	push	acc
0058  C0 04                11  	push	4
005A  C0 05                12  	push	5
005C                       13  
005C  E4                   14  	clr	a
005D  F8                   15  	mov	r0,	a
005E  F9                   16  	mov	r1,	a
005F  FA                   17  	mov	r2,	a
0060  FB                   18  	mov	r3,	a
0061                       19  
0061                       20  read_hex_32__loop:
0061  11 51                21  	acall	read_char
0063                       22  
0063  C3                   23  	clr	c
0064  94 30                24  	subb	a,	#0x30	; ascii '0'
0066  40 42                25  	jc	read_hex_32__end
0068  B4 0A 00             26  	cjne	a,	#10,	read_hex_32__1
006B                       27  read_hex_32__1:
006B  40 0D                28  	jc	read_hex_32__3
006D  94 11                29  	subb	a,	#17	; chars between '0' and 'A'
006F  40 39                30  	jc	read_hex_32__end
0071  24 0A                31  	add	a,	#10
0073  54 DF                32  	anl	a,	#0xdf	; allow lowercase
0075  B4 10 00             33  	cjne	a,	#0x10,	read_hex_32__2
0078                       34  read_hex_32__2:
0078  50 30                35  	jnc	read_hex_32__end
007A                       36  
007A                       37  read_hex_32__3:
007A  FC                   38  	mov	r4,	a
007B  E8                   39  	mov	a,	r0
007C  C4                   40  	swap	a
007D  FD                   41  	mov	r5,	a
007E  54 F0                42  	anl	a,	#0xf0
0080  4C                   43  	orl	a,	r4
0081  F8                   44  	mov	r0,	a
0082  ED                   45  	mov	a,	r5
0083  54 0F                46  	anl	a,	#0x0f
0085                       47  
0085  FC                   48  	mov	r4,	a
0086  E9                   49  	mov	a,	r1
0087  C4                   50  	swap	a
0088  FD                   51  	mov	r5,	a
0089  54 F0                52  	anl	a,	#0xf0
008B  4C                   53  	orl	a,	r4
008C  F9                   54  	mov	r1,	a
008D  ED                   55  	mov	a,	r5
008E  54 0F                56  	anl	a,	#0x0f
0090                       57  
0090  FC                   58  	mov	r4,	a
0091  EA                   59  	mov	a,	r2
0092  C4                   60  	swap	a
0093  FD                   61  	mov	r5,	a
0094  54 F0                62  	anl	a,	#0xf0
0096  4C                   63  	orl	a,	r4
0097  FA                   64  	mov	r2,	a
0098  ED                   65  	mov	a,	r5
0099  54 0F                66  	anl	a,	#0x0f
009B                       67  
009B  FC                   68  	mov	r4,	a
009C  EB                   69  	mov	a,	r3
009D  C4                   70  	swap	a
009E  FD                   71  	mov	r5,	a
009F  54 F0                72  	anl	a,	#0xf0
00A1  4C                   73  	orl	a,	r4
00A2  FB                   74  	mov	r3,	a
00A3  ED                   75  	mov	a,	r5
00A4  54 0F                76  	anl	a,	#0x0f
00A6                       77  
00A6  70 02                78  	jnz	read_hex_32__end	; overflow
00A8  80 B7                79  	sjmp	read_hex_32__loop
00AA                       80  
00AA                       81  
00AA                       82  read_hex_32__end:
00AA  D0 05                83  	pop	5
00AC  D0 04                84  	pop	4
00AE  D0 E0                85  	pop	acc
00B0  22                   86  	ret
00B1                       87  
