0025                       36  .include ../serial/init.inc
                         ; ==== ../serial/init.inc ====
0025                        1  
0025                        2  ; *** serial/init.inc ***
0025                        3  
0025                        4  ; >> void serial_init() <<
0025                        5  
0025                        6  ; Initialize serial interface.
0025                        7  ; - assumes 20MHz clock and X2 mode
0025                        8  ; - uses internal baud rate generator
0025                        9  ; - speed: 9600 bits per second
0025                       10  ; Formula: BRL = 256 - (F_clk / (32 * Baud_Rate))
0025                       11  ; ---
0025                       12  ; See datasheet page 52 for details,
0025                       13  ; also note oscillator diagram on page 16!
0025                       14  
0025                       15  serial_init:
0025  75 98 52             16  	mov	SCON,	#0x52	; SM1, REN, TI
0028  75 9A BF             17  	mov	BRL,	#191	; 9600 @20MHz CLK
002B  75 9B 1E             18  	mov	BDRCON, #0x1e	; BRR, RBCK, TBCK, SPD
002E                       19  
002E  90 00 49             20  	mov	dptr,	#serial_rx
0031  85 82 30             21  	mov	IN,	DPL
0034  85 83 31             22  	mov	IN+1,	DPH
0037                       23  
0037  90 00 41             24  	mov	dptr,	#serial_tx
003A  85 82 32             25  	mov	OUT,	DPL
003D  85 83 33             26  	mov	OUT+1,	DPH
0040                       27  
0040  22                   28  	ret
0041                       29  
                         ; ==== read_hex.asm ====
0041                       37  .include ../serial/tx.inc
                         ; ==== ../serial/tx.inc ====
0041                        1  
0041                        2  ; *** serial/tx.inc ***
0041                        3  
0041                        4  ; >> void serial_tx(char a) <<
0041                        5  
0041                        6  ; Transmit byte from accumulator.
0041                        7  
0041                        8  serial_tx:
0041  30 99 FD              9  	jnb	TI,	serial_tx
0044  C2 99                10  	clr	TI
0046  F5 99                11  	mov	SBUF,	a
0048  22                   12  	ret
0049                       13  
                         ; ==== read_hex.asm ====
0049                       38  .include ../serial/rx.inc
                         ; ==== ../serial/rx.inc ====
0049                        1  
0049                        2  ; *** serial/rx.inc ***
0049                        3  
0049                        4  ; >> char serial_rx <<
0049                        5  
0049                        6  ; Receive byte into accumulator.
0049                        7  
0049                        8  serial_rx:
0049  30 98 FD              9  	jnb	RI,	serial_rx
004C  C2 98                10  	clr	RI
004E  E5 99                11  	mov	a,	SBUF
0050  22                   12  	ret
0051                       13  
