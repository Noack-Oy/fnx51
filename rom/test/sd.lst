023D                       95  .include ../sd/command.inc
                         ; ==== ../sd/command.inc ====
023D                        1  
023D                        2  ; *** sd/command.inc ***
023D                        3  
023D                        4  ; >> void sd_command(uint8{a} cmd, uint32{r0-r3} arg, uint8{r4} crc) <<
023D                        5  
023D                        6  ; Issue a command to the SD card
023D                        7  sd_command:
023D  C0 E0                 8  	push	acc
023F                        9  	; transmit command
023F  44 40                10  	orl	a,#0x40	; transmission bit
0241  31 2C                11  	acall	spi_transfer
0243                       12  	; transmit argument
0243  EB                   13  	mov	a,r3
0244  31 2C                14  	acall	spi_transfer
0246  EA                   15  	mov	a,r2
0247  31 2C                16  	acall	spi_transfer
0249  E9                   17  	mov	a,r1
024A  31 2C                18  	acall	spi_transfer
024C  E8                   19  	mov	a,r0
024D  31 2C                20  	acall	spi_transfer
024F                       21  	; transmit crc
024F  EC                   22  	mov	a,r4
0250  44 01                23  	orl	a,#0x01	; end bit
0252  31 2C                24  	acall	spi_transfer
0254  D0 E0                25  	pop	acc
0256  22                   26  	ret
