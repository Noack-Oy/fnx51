0317                        3  
0317                        4  ; >> char{a} stream_xram_read() <<
0317                        5  
0317                        6  ; Read byte from on-chip expanded RAM at stream input pointer.
0317                        7  ; 16 bit value of the stream pointer is used and incremented.
0317                        8  
0317                        9  stream_xram_read:
0317  C0 8E                10  	push	auxr
0319  C0 82                11  	push	dpl
031B  C0 83                12  	push	dph
031D                       13  
031D  53 8E E1             14  	anl	auxr,#0xe1	; clear extram, xrs0-2
0320  43 8E 10             15  	orl	auxr,#0x10	; set xrs2 (size 1792 bytes)
0323                       16  
0323  85 34 82             17  	mov	dpl,stream_in
0326  85 35 83             18  	mov	dph,stream_in+1
0329                       19  
0329  E0                   20  	movx	a,@dptr
032A  A3                   21  	inc	dptr
032B  85 82 34             22  	mov	stream_in,dpl
032E  85 83 35             23  	mov	stream_in+1,dph
0331                       24  
0331  D0 83                25  	pop	dph
0333  D0 82                26  	pop	dpl
0335  D0 8E                27  	pop	auxr
0337  22                   28  	ret
0338                       29  
