                         ; ==== ../sd/block_read.inc ====
0287                        1  
0287                        2  ; *** sd/block_read.inc ***
0287                        3  
0287                        4  ; >> uint16{r4-r5} sd_block_read(
0287                        5  ;	uint32{r0-r3} block_address,
0287                        6  ;	char *{dptr}&destination) <<
0287                        7  
0287                        8  ; Read block at address from sd card, write to RAM at dptr.
0287                        9  ; Return CRC in r4-r5, block address unchanged,
0287                       10  ; dptr pointing to first byte after read block.
0287                       11  
0287                       12  sd_block_read:
0287  C0 E0                13  	push	acc
0289                       14  
0289                       15  	; send CMD17 (single block read)
0289  74 11                16  	mov	a,#17
028B  7C FF                17  	mov	r4,#0xff ; command CRC, ignored
028D  51 3D                18  	acall	sd_command
028F                       19  sd_block_read__wait:
028F  51 57                20  	acall	sd_response1
0291  B4 FE FB             21  	cjne	a,#0xfe,sd_block_read__wait
0294  7D 00                22  	mov	r5,#0 ; loop counter
0296                       23  	; this loop will run 256 times,
0296                       24  	; two bytes are read per iteration
0296                       25  sd_block_read__loop:
0296  74 FF                26  	mov	a,#0xff
0298  31 2C                27  	acall	spi_transfer
029A  F0                   28  	movx	@dptr,a
029B  A3                   29  	inc	dptr
029C  74 FF                30  	mov	a,#0xff
029E  31 2C                31  	acall	spi_transfer
02A0  F0                   32  	movx	@dptr,a
02A1  A3                   33  	inc	dptr
02A2  DD F2                34  	djnz	r5,sd_block_read__loop
02A4                       35  	; read block CRC
02A4  74 FF                36  	mov	a,#0xff
02A6  31 2C                37  	acall	spi_transfer
02A8  FD                   38  	mov	r5,a
02A9  74 FF                39  	mov	a,#0xff
02AB  31 2C                40  	acall	spi_transfer
02AD  FC                   41  	mov	r4,a
02AE                       42  
02AE  D0 E0                43  	pop	acc
02B0  22                   44  	ret
02B1                       45  
                         ; ==== sd.asm ====
02B1                       98  
02B1                       99  .include ../util/delay.inc
                         ; ==== ../util/delay.inc ====
02B1                        1  
02B1                        2  ; *** util/delay.inc ***
02B1                        3  
02B1                        4  ; >> void delay_ms_8(uint8{a} duration) <<
02B1                        5  
02B1                        6  ; 1-256 millisecond delay, duration given in a.
02B1                        7  ; Assumes 20MHz clock and X2 mode.
02B1                        8  ; Actual delay is slightly longer.
02B1                        9  delay_ms_8:
02B1                       10  
02B1  C0 E0                11  	push	acc
02B3  C0 F0                12  	push	b
02B5                       13  
02B5                       14  	; This loop is repeated a times (256 if a is zero).
02B5                       15  	; The goal is to stretch each repeat to one millisecond.
02B5                       16  delay_ms_8__loop1:
02B5                       17  	; Each millisecond is 20k clock periods.
02B5                       18  	; In X2 mode, a machine cycle is 6 clock periods.
02B5                       19  	; Therefore, a millisecond is approx. 3334 machine cycles.
02B5  75 F0 B9             20  	mov	b,#185	; n = 185	cycles:	  2
02B8                       21  delay_ms_8__loop2:
02B8  C0 E0                22  	push	acc			; n*2 = 370
02BA  C0 F0                23  	push	b			; n*2 = 370
02BC  A4                   24  	mul	ab			; n*4 = 740
02BD  A4                   25  	mul	ab			; n*4 = 740
02BE  D0 F0                26  	pop	b			; n*2 = 370
02C0  D0 E0                27  	pop	acc			; n*2 = 370
02C2  D5 F0 F3             28  	djnz	b,delay_ms_8__loop2	; n*2 = 370
02C5  D5 E0 ED             29  	djnz	acc,delay_ms_8__loop1	;	  2
02C8                       30  					; Sum: 3334
02C8  D0 F0                31  	pop	b
02CA  D0 E0                32  	pop	acc
02CC  22                   33  	ret
02CD                       34  
