                         ; ==== ../sd/response.inc ====
0257                        1  
0257                        2  ; *** sd/response.inc ***
0257                        3  
0257                        4  ; >> uint8{a} sd_response1() <<
0257                        5  
0257                        6  ; Read response from SD card in 'R1' format into a
0257                        7  sd_response1:
0257  C0 F0                 8  	push	b
0259  85 08 F0              9  	mov	b,8	; number of tries
025C                       10  sd_response1__loop:
025C  74 FF                11  	mov	a,#0xff
025E  31 2C                12  	acall	spi_transfer
0260  B4 FF 03             13  	cjne	a,#0xff,sd_response1__end	; success
0263  D5 F0 F6             14  	djnz	b,sd_response1__loop	; retry / timeout
0266                       15  sd_response1__end:
0266  D0 F0                16  	pop	b
0268  22                   17  	ret
0269                       18  
0269                       19  ; >> uint8{a}, uint32{r0-r3} sd_response3() <<
0269                       20  
0269                       21  ; Read response from SD card in 'R3' format into a and r0-r3
0269                       22  sd_response3: ; same as R7
0269                       23  
0269                       24  ; >> uint8{a}, uint32{r0-r3} sd_response7() <<
0269                       25  
0269                       26  ; Read response from SD card in 'R7' format into a and r0-r3
0269                       27  sd_response7:
0269  51 57                28  	acall	sd_response1
026B  B4 02 00             29  	cjne	a,#0x02,sd_response7__1
026E                       30  sd_response7__1:
026E  40 01                31  	jc	sd_response7__2
0270  22                   32  	ret	; error in R1 response
0271                       33  sd_response7__2:
0271  F8                   34  	mov	r0,a
0272  74 FF                35  	mov	a,#0xff
0274  31 2C                36  	acall	spi_transfer
0276  FB                   37  	mov	r3,a
0277  74 FF                38  	mov	a,#0xff
0279  31 2C                39  	acall	spi_transfer
027B  FA                   40  	mov	r2,a
027C  74 FF                41  	mov	a,#0xff
027E  31 2C                42  	acall	spi_transfer
0280  F9                   43  	mov	r1,a
0281  74 FF                44  	mov	a,#0xff
0283  31 2C                45  	acall	spi_transfer
0285  C8                   46  	xch	a,r0
0286  22                   47  	ret
0287                       48  
