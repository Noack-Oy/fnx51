02D2                      101  .include ../print/hex.inc
                         ; ==== ../print/hex.inc ====
02D2                        1  
02D2                        2  ; *** print/hex.inc ***
02D2                        3  
02D2                        4  ; >> void print_hex_8(char a) <<
02D2                        5  
02D2                        6  ; Print hexadecimal number from accumulator.
02D2                        7  
02D2                        8  print_hex_8:
02D2  C4                    9  	swap	a	; high nibble first
02D3  51 D6                10  	acall	print_hex_8__nibble
02D5  C4                   11  	swap	a
02D6                       12  print_hex_8__nibble:
02D6  C0 E0                13  	push	ACC
02D8  54 0F                14  	anl	a,	#0x0f
02DA  24 90                15  	add	a,	#0x90
02DC  D4                   16  	da	a
02DD  34 40                17  	addc	a,	#0x40
02DF  D4                   18  	da	a
02E0  44 20                19  	orl	a,	#0x20	; lower case
02E2  51 CD                20  	acall	print_char
02E4  D0 E0                21  	pop	ACC
02E6  22                   22  	ret
02E7                       23  
02E7                       24  ; >> void print_hex_16(int r0r1) <<
02E7                       25  
02E7                       26  ; Print hexadecimal number from r0-r1.
02E7                       27  
02E7                       28  print_hex_16:
02E7  C0 E0                29  	push	ACC
02E9  E9                   30  	mov	a,	r1	; MSB first
02EA  51 D2                31  	acall	print_hex_8
02EC  E8                   32  	mov	a,	r0	; LSB second
02ED  51 D2                33  	acall	print_hex_8
02EF  D0 E0                34  	pop	ACC
02F1  22                   35  	ret
02F2                       36  
02F2                       37  ; >> void print_hex_32(long r0r1r2r3) <<
02F2                       38  
02F2                       39  ; Print hexadecimal number from r0-r3.
02F2                       40  
02F2                       41  print_hex_32:
02F2  C0 E0                42  	push	ACC
02F4  EB                   43  	mov	a,	r3	; MSB first
02F5  51 D2                44  	acall	print_hex_8
02F7  EA                   45  	mov	a,	r2
02F8  51 D2                46  	acall	print_hex_8
02FA  E9                   47  	mov	a,	r1
02FB  51 D2                48  	acall	print_hex_8
02FD  E8                   49  	mov	a,	r0	; LSB last
02FE  51 D2                50  	acall	print_hex_8
0300  D0 E0                51  	pop	ACC
0302  22                   52  	ret
0303                       53  
