01AF  C0 00                 8  	push	0
01B1  C0 01                 9  	push	1
01B3  C0 02                10  	push	2
01B5  C0 03                11  	push	3
01B7  C0 04                12  	push	4
01B9  E4                   13  	clr	a
01BA  F8                   14  	mov	r0,a
01BB  F9                   15  	mov	r1,a
01BC  FA                   16  	mov	r2,a
01BD  FB                   17  	mov	r3,a
01BE  7C 94                18  	mov	r4,#0x94
01C0  51 3D                19  	acall	sd_command
01C2  51 57                20  	acall	sd_response1
01C4  D0 04                21  	pop	4
01C6  D0 03                22  	pop	3
01C8  D0 02                23  	pop	2
01CA  D0 01                24  	pop	1
01CC  D0 00                25  	pop	0
01CE  22                   26  	ret
