033D                        1  
033D                        2  ; *** util/xch.inc ***
033D                        3  
033D                        4  ; >> void xch_r0123_r4567(uint32 &r0r1r2r3, uint32 &r4r5r6r7) <<
033D                        5  
033D                        6  ; Exchange registers r0-r3 with r4-r7.
033D                        7  
033D                        8  xch_r0123_r4567:
033D                        9  	; r0 <-> r4
033D  C8                   10  	xch	a,	r0
033E  CC                   11  	xch	a,	r4
033F  C8                   12  	xch	a,	r0
0340                       13  	; r1 <-> r5
0340  C9                   14  	xch	a,	r1
0341  CD                   15  	xch	a,	r5
0342  C9                   16  	xch	a,	r1
0343                       17  	; r2 <-> r6
0343  CA                   18  	xch	a,	r2
0344  CE                   19  	xch	a,	r6
0345  CA                   20  	xch	a,	r2
0346                       21  	; r3 <-> r7
0346  CB                   22  	xch	a,	r3
0347  CF                   23  	xch	a,	r7
0348  CB                   24  	xch	a,	r3
0349                       25  	; a remains unchanged
0349  22                   26  	ret
034A                       27  
