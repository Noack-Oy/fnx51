                         ; ==== ../util/panic.inc ====
03FE                        1  
03FE                        2  ; *** panic/panic.inc ***
03FE                        3  
03FE                        4  ; >> void panic() <<
03FE                        5  
03FE                        6  ; Unrecoverable error handler.
03FE                        7  ; Print caller address and halt.
03FE                        8  
03FE                        9  panic:
03FE  C2 AF                10  	clr	ea	; disable interrupts
0400  F8                   11  	mov	r0,a	; save a
0401                       12  	; display panic text
0401  90 01 1C             13  	mov	dptr,#panic_out
0404  85 82 32             14  	mov	out,dpl
0407  85 83 33             15  	mov	out+1,dph
040A  90 04 31             16  	mov	dptr,#panic_text
040D  71 03                17  	acall	print_text
040F                       18  	; get return address from stack
040F  D0 E0                19  	pop	acc
0411  FA                   20  	mov	r2,a
0412  D0 E0                21  	pop	acc
0414                       22  	; subtract two to get call instruction address
0414  C3                   23  	clr	c
0415  94 02                24  	subb	a,#2
0417  F9                   25  	mov	r1,a
0418  EA                   26  	mov	a,r2
0419  94 00                27  	subb	a,#0
041B                       28  	; print caller address (to look up cause in .lst file)
041B  51 D2                29  	acall	print_hex_8
041D  E9                   30  	mov	a,r1
041E  51 D2                31  	acall	print_hex_8
0420                       32  	; print original value of a (error code / debug info)
0420  74 20                33  	mov	a,#' '
0422  51 CD                34  	acall	print_char
0424  E8                   35  	mov	a,r0
0425  51 D2                36  	acall	print_hex_8
0427                       37  	; newline
0427  74 0D                38  	mov	a,#13
0429  51 CD                39  	acall	print_char
042B  74 0A                40  	mov	a,#10
042D  51 CD                41  	acall	print_char
042F                       42  	; hang
042F  80 FE                43  	sjmp	*
0431                       44  
0431                       45  panic_text:
0431  0D 0A                46  	.db	13, 10
0433  20 21 21 21 20 70    47  	.db	" !!! panic @"
0439  61 6E 69 63 20 40
043F  00                   48  	.db	0
0440                       49  
