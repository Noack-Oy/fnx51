0303                        4  ; >> void print_text(char* dptr) <<
0303                        5  
0303                        6  ; Print null-terminated string from program code.
0303                        7  ; Aborts if no null terminator is found after 256 bytes.
0303                        8  
0303                        9  print_text:
0303  C0 E0                10  	push	ACC
0305  C0 00                11  	push	0
0307                       12  
0307  E4                   13  	clr	a
0308  F8                   14  	mov	r0,	a
0309                       15  print_text__loop:
0309  93                   16  	movc	a,	@a+dptr
030A  60 06                17  	jz	print_text__end
030C  51 CD                18  	acall	print_char
030E  08                   19  	inc	r0
030F  E8                   20  	mov	a,	r0
0310  70 F7                21  	jnz	print_text__loop
0312                       22  
0312                       23  print_text__end:
0312  D0 00                24  	pop	0
0314  D0 E0                25  	pop	ACC
0316  22                   26  	ret
