                   
                   ; ************************
                   ; * SD Card Test Program *
                   ; ************************
                   
                   ; This program initializes an SD card
                   ; and dumps the first sector.
                   
                   
                   ; **********************
                   ; * Header Definitions *
                   ; **********************
                   
                   ; *** global/variables.equ ***
                   
                   ; variables in internal RAM
                   
                   ; 0x00-0x1f: register banks 0-3
                   ; 0x20-0x2f: bit addressable variables
                   
0000:              .equ    in,             0x30    ; pointer to input handling 
0000:              .equ    out,            0x32    ; pointer to ouput handling 
                   
0000:              .equ    stream_in,      0x34    ; input stream position
0000:              .equ    stream_out,     0x36    ; output stream position
                   
0000:              .equ    memory_list,    0x38    ; pointer to heap list head
0000:              .equ    memory_start,   0x40    ; first allocatable address
0000:              .equ    memory_end,     0x42    ; last allocatable address
                   
0000:              .equ    block_read,     0x44    ; pointers to block device d
0000:              .equ    block_write,    0x46    ; code (read and write funct
0000:              .equ    block_cache,    0x48    ; pointer to block cache dat
                   
0000:              .equ    fatfs_info,     0x50    ; pointer to FAT file system
                   
0000:              .equ    stack,          0x60    ; beginning of stack (grows 
                   
                   ; *** global/sfr.equ ***
                   
                   ; global SFRs
                   
0000:              .equ    auxr,   0x8e    ; auxiliary register 0
0000:              .equ    auxr1,  0xa2    ; auxiliary register 1
                   
                   ; *** serial/sfr.equ ***
                   
                   ; Special function registers for serial interface.
                   ; See chapter 14 of AT89C51ED2 datasheet, page 48ff.
                   
                   ; Internal Baud Rate Generator (BRG), see datasheet page 52.
0000:                      .equ    BRL,    0x9A    ; baud rate reload value
0000:                      .equ    BDRCON, 0x9B    ; BRG control register
                   
                   ; *** spi/sfr.equ ***
                   
                   ; Special function registers for serial peripheral interface
                   ; See chapter 16 of AT89C51ED2 datasheet
                   
0000:              .equ    spcon,  0xc3    ; Serial Peripheral Control Register
0000:              .equ    spsta,  0xc4    ; Serial Peripheral Status Register
0000:              .equ    spdat,  0xc5    ; Serial Peripheral Data Register
                   
                   ; *** sd/config.equ ***
                   
                   ; SPCON register configuration for SD card:
                   ; .-----.-------.-------.-----------------------------------
                   ; | bit | name  | value | remark                            
                   ; |-----|-------|-------|-----------------------------------
                   ; | 7   | SPR2  | 1     | SPR2:0 = 101-> Fclk_periph / 64   
                   ; | 6   | SPEN  | 1     | Set to enable the SPI             
                   ; | 5   | SSDIS | 1     | Set to disable /SS input          
                   ; | 4   | MSTR  | 1     | Set to configure the SPI as a mast
                   ; | 3   | CPOL  | 0     | Cleared to have SCK idle at '0'   
                   ; | 2   | CPHA  | 0     | Cleared to sample on leading edge 
                   ; | 1   | SPR1  | 0     | (see above)                       
                   ; | 0   | SPR0  | 1     | (see above)   speed: 312.5 kHz    
                   ; '-----'-------'-------'-----------------------------------
                   
0000:              .equ    sd_spi_config,  0xf1
                   
0000:              .flag   sd_pin_cs,      p1.1
                   
                   ; *************
                   ; * Main Code *
                   ; *************
                   
                   ; *** test/sd.asm ***
                   
0000:              .org    0
                   
                   ; *** global/init.inc ***
                   
                   ; Initialize stack pointer and global variables.
                   ; This must be included early in the main program.
                   
                   global_init:
0000: 75 81 60             mov     SP,#STACK
                   
                   ; Select register bank zero, clear processor flags
0003: 75 D0 00             mov     PSW,#0
                   
                   ; Fill internal RAM with markers for uninitialized data
0006: 78 00                mov     r0,#0 ; write pointer
                   
0008: 74 3F                mov     a,#0x3f ; '?' for uninitialized registers
                   global_init__1:
000A: 08                   inc     r0 ; first iteration skips address 0, r0 liv
000B: F6                   mov     @r0,a
000C: B8 1F FB             cjne    r0,#0x1f,global_init__1
                   
000F: 74 2A                mov     a,#0x2a ; '*' for uninitialized variables
                   global_init__2:
0011: 08                   inc     r0
0012: F6                   mov     @r0,a
0013: B8 5F FB             cjne    r0,#STACK-1,global_init__2
                   
0016: 74 7E                mov     a,#0x7e ; '~' for stack and above
                   global_init__3:
0018: 08                   inc     r0
0019: F6                   mov     @r0,a
001A: B8 FF FB             cjne    r0,#0xff,global_init__3
                   
001D: 31 00                acall   serial_init
001F: 31 37                acall   sd_init
0021: 51 D2                acall   print_hex_8     ; status
0023: 51 F2                acall   print_hex_32    ; operation condition
0025: 74 0D                mov     a,#13
0027: 51 CD                acall   print_char
0029: 74 0A                mov     a,#10
002B: 51 CD                acall   print_char
                   
                           ; use xram
002D: 53 8E E1             anl     auxr,#0xe1      ; clear extram, xrs0-2
0030: 43 8E 10             orl     auxr,#0x10      ; set xrs2 (size 1792 bytes)
                   
0033: E4                   clr     a
0034: F5 82                mov     dpl,a
0036: F5 83                mov     dph,a
0038: F8                   mov     r0,a
0039: F9                   mov     r1,a
003A: FA                   mov     r2,a
003B: FB                   mov     r3,a
003C: 51 87                acall   sd_block_read
                   
                           ; print CRC
003E: EC                   mov     a,r4
003F: F8                   mov     r0,a
0040: ED                   mov     a,r5
0041: F9                   mov     r1,a
0042: 51 E7                acall   print_hex_16
0044: 74 0D                mov     a,#13
0046: 51 CD                acall   print_char
0048: 74 0A                mov     a,#10
004A: 51 CD                acall   print_char
                   
004C: E4                   clr     a
004D: F8                   mov     r0,a
004E: F9                   mov     r1,a
004F: FA                   mov     r2,a
0050: FB                   mov     r3,a
0051: F5 34                mov     stream_in,a
0053: F5 35                mov     stream_in+1,a
0055: 90 03 19             mov     dptr,#stream_xram_read
0058: 85 82 30             mov     in,dpl
005B: 85 83 31             mov     in+1,dph
005E: 71 4C                acall   dump
0060: 71 4C                acall   dump
                   
                   halt:
0062: 80 FE                sjmp    halt
                   
0100:              .org    0x0100
                   
                   ; *********************
                   ; * Library Functions *
                   ; *********************
                   
                   ; *** serial/init.inc ***
                   
                   ; >> void serial_init() <<
                   
                   ; Initialize serial interface.
                   ; - assumes 20MHz clock and X2 mode
                   ; - uses internal baud rate generator
                   ; - speed: 9600 bits per second
                   ; Formula: BRL = 256 - (F_clk / (32 * Baud_Rate))
                   ; ---
                   ; See datasheet page 52 for details,
                   ; also note oscillator diagram on page 16!
                   
                   serial_init:
0100: 75 98 52             mov     SCON,   #0x52   ; SM1, REN, TI
0103: 75 9A BF             mov     BRL,    #191    ; 9600 @20MHz CLK
0106: 75 9B 1E             mov     BDRCON, #0x1e   ; BRR, RBCK, TBCK, SPD
                   
0109: 90 01 24             mov     dptr,   #serial_rx
010C: 85 82 30             mov     IN,     DPL
010F: 85 83 31             mov     IN+1,   DPH
                   
0112: 90 01 1C             mov     dptr,   #serial_tx
0115: 85 82 32             mov     OUT,    DPL
0118: 85 83 33             mov     OUT+1,  DPH
                   
011B: 22                   ret
                   
                   ; *** serial/tx.inc ***
                   
                   ; >> void serial_tx(char a) <<
                   
                   ; Transmit byte from accumulator.
                   
                   serial_tx:
011C: 30 99 FD             jnb     TI,     serial_tx
011F: C2 99                clr     TI
0121: F5 99                mov     SBUF,   a
0123: 22                   ret
                   
                   ; *** serial/rx.inc ***
                   
                   ; >> char serial_rx <<
                   
                   ; Receive byte into accumulator.
                   
                   serial_rx:
0124: 30 98 FD             jnb     RI,     serial_rx
0127: C2 98                clr     RI
0129: E5 99                mov     a,      SBUF
012B: 22                   ret
                   
                   
                   ; *** spi/transfer.inc ***
                   
                   ; >> char{a} serial_transfer(char{a} data) <<
                   
                   ; SPI transfer function: send byte from a, read response int
                   
                   spi_transfer:
012C: F5 C5                mov     spdat,a
                   
                   spi_transfer__wait:
012E: E5 C4                mov     a,spsta
0130: 54 80                anl     a,#0x80 ;check SPIF bit
0132: 60 FA                jz      spi_transfer__wait
                   
0134: E5 C5                mov     a,spdat
0136: 22                   ret
                   
                   ; *** sd/init.inc ***
                   
                   ; >> uint8{a},uint32{r0-r3} sd_init() <<
                   
                   ; Initialize SD card, return error code in a, OCR in r0-r3.
                   sd_init:
0137: ED                   mov     a,r5    ; r5 is used as temp store for error
0138: C0 E0                push    acc
013A: C0 82                push    dpl
013C: C0 83                push    dph
                   
013E: 75 C3 F1             mov     spcon,#sd_spi_config
0141: 31 85                acall   sd_warmup
0143: 31 9A                acall   sd_select
                   
0145: 7D 05                mov     r5,#5   ; 5: no idle response to cmd0
0147: 31 A9                acall   sd_cmd0
0149: B4 01 31             cjne    a,#1,sd_init__end
                   
014C: 1D                   dec     r5      ; 4: no idle response to cmd8
014D: 31 C9                acall   sd_cmd8
014F: B4 01 2B             cjne    a,#1,sd_init__end
0152: 1D                   dec     r5      ; 3: invalid cmd8 response
0153: BB 00 27             cjne    r3,#0x00,sd_init__end
0156: BA 00 24             cjne    r2,#0x00,sd_init__end
0159: B9 01 21             cjne    r1,#0x01,sd_init__end
015C: B8 AA 1E             cjne    r0,#0xaa,sd_init__end
                   
015F: 7D 64                mov     r5,#100 ; retry counter
                   sd_init__loop:
0161: 31 E1                acall   sd_acmd41
0163: 60 0A                jz      sd_init__continue
0165: 74 0A                mov     a,#10
0167: 51 B1                acall   delay_ms_8
0169: DD F6                djnz    r5,sd_init__loop
016B: 7D 02                mov     r5,#2   ; 2: acmd41 ready response timeout
016D: 80 0E                sjmp    sd_init__end
                   
                   sd_init__continue:
016F: 7D 01                mov     r5,#1   ; 1: no ready response to cmd58
0171: 51 29                acall   sd_cmd58
                   
0173: 1D                   dec     r5      ; 0: success
                   
0174: 90 02 87             mov     dptr,#sd_block_read
0177: 85 82 44             mov     block_read,dpl
017A: 85 83 45             mov     block_read+1,dph
                   
                   sd_init__end:
017D: D0 83                pop     dph
017F: D0 82                pop     dpl
0181: D0 E0                pop     acc
0183: CD                   xch     a,r5
0184: 22                   ret
                   
                   ; *** sd/warmup.inc ***
                   
                   ; >> void sd_warmup() <<
                   
                   ; send 80 warmup pulses to sclk while cs is high
                   sd_warmup:
0185: C0 E0                push    acc
0187: C0 F0                push    b
0189: D2 91                setb    sd_pin_cs ; p1.1
018B: 75 F0 0A             mov     b,#10
                   sd_warmup_loop:
018E: 74 FF                mov     a,#0xff
0190: 31 2C                acall   spi_transfer
0192: D5 F0 F9             djnz    b,sd_warmup_loop
0195: D0 F0                pop     b
0197: D0 E0                pop     acc
0199: 22                   ret
                   
                   ; *** sd/select.inc ***
                   
                   ; >> void sd_select() <<
                   
                   ; Activate the SD card
                   sd_select:
019A: C0 E0                push    acc
019C: 74 FF                mov     a,#0xff
019E: 31 2C                acall   spi_transfer
01A0: C2 91                clr     sd_pin_cs
01A2: 74 FF                mov     a,#0xff
01A4: 31 2C                acall   spi_transfer
01A6: D0 E0                pop     acc
01A8: 22                   ret
                   
                   ; *** sd/cmd0.inc ***
                   
                   ; >> char{a} sd_cmd0() <<
                   
                   ; CMD0: go to idle state
                   sd_cmd0:
01A9: C0 00                push    0
01AB: C0 01                push    1
01AD: C0 02                push    2
01AF: C0 03                push    3
01B1: C0 04                push    4
01B3: E4                   clr     a
01B4: F8                   mov     r0,a
01B5: F9                   mov     r1,a
01B6: FA                   mov     r2,a
01B7: FB                   mov     r3,a
01B8: 7C 94                mov     r4,#0x94
01BA: 51 3D                acall   sd_command
01BC: 51 57                acall   sd_response1
01BE: D0 04                pop     4
01C0: D0 03                pop     3
01C2: D0 02                pop     2
01C4: D0 01                pop     1
01C6: D0 00                pop     0
01C8: 22                   ret
                   
                   ; *** sd/cmd8.inc ***
                   
                   ; >> uint8{a},uint32{r0-r3} sd_cmd8() <<
                   
                   ; CMD8: send interface condition
                   sd_cmd8:
01C9: EC                   mov     a,r4
01CA: C0 E0                push    acc
01CC: 74 08                mov     a,#8
01CE: 78 AA                mov     r0,#0xaa
01D0: 79 01                mov     r1,#0x01
01D2: 7A 00                mov     r2,#0x00
01D4: 7B 00                mov     r3,#0x00
01D6: 7C 86                mov     r4,#0x86
01D8: 51 3D                acall   sd_command
01DA: 51 69                acall   sd_response7
01DC: FC                   mov     r4,a
01DD: D0 E0                pop     acc
01DF: CC                   xch     a,r4
01E0: 22                   ret
                   
                   ; *** sd/acmd41.inc ***
                   
                   ; >> char{a} sd_acmd41() <<
                   
                   ; ACMD41: send operation condition
                   sd_acmd41:
01E1: 51 08                acall   sd_cmd55
01E3: B4 01 21             cjne    a,#1,sd_acmd41__end
01E6: C0 00                push    0
01E8: C0 01                push    1
01EA: C0 02                push    2
01EC: C0 03                push    3
01EE: C0 04                push    4
01F0: E4                   clr     a
01F1: F8                   mov     r0,a
01F2: F9                   mov     r1,a
01F3: FA                   mov     r2,a
01F4: 7B 40                mov     r3,#0x40 ; indicates high capacity support
01F6: FC                   mov     r4,a
01F7: 74 29                mov     a,#41
01F9: 51 3D                acall   sd_command
01FB: 51 57                acall   sd_response1
01FD: D0 04                pop     4
01FF: D0 03                pop     3
0201: D0 02                pop     2
0203: D0 01                pop     1
0205: D0 00                pop     0
                   sd_acmd41__end:
0207: 22                   ret
                   
                   ; *** sd/cmd55.inc ***
                   
                   ; >> char{a} sd_cmd55() <<
                   
                   ; CMD55: application specific command (prefix)
                   sd_cmd55:
0208: C0 00                push    0
020A: C0 01                push    1
020C: C0 02                push    2
020E: C0 03                push    3
0210: C0 04                push    4
0212: E4                   clr     a
0213: F8                   mov     r0,a
0214: F9                   mov     r1,a
0215: FA                   mov     r2,a
0216: FB                   mov     r3,a
0217: FC                   mov     r4,a
0218: 74 37                mov     a,#55
021A: 51 3D                acall   sd_command
021C: 51 57                acall   sd_response1
021E: D0 04                pop     4
0220: D0 03                pop     3
0222: D0 02                pop     2
0224: D0 01                pop     1
0226: D0 00                pop     0
0228: 22                   ret
                   
                   ; *** sd/cmd58.inc ***
                   
                   ; >> uint8{a},uint32{r0-r3} sd_cmd58() <<
                   
                   ; CMD58: read operation conditions register
                   sd_cmd58:
0229: EC                   mov     a,r4
022A: C0 E0                push    acc
022C: E4                   clr     a
022D: F8                   mov     r0,a
022E: F9                   mov     r1,a
022F: FA                   mov     r2,a
0230: FB                   mov     r3,a
0231: FC                   mov     r4,a
0232: 74 3A                mov     a,#58
0234: 51 3D                acall   sd_command
0236: 51 69                acall   sd_response3
0238: FC                   mov     r4,a
0239: D0 E0                pop     acc
023B: CC                   xch     a,r4
023C: 22                   ret
                   
                   ; *** sd/command.inc ***
                   
                   ; >> void sd_command(uint8{a} cmd, uint32{r0-r3} arg, uint8{
                   
                   ; Issue a command to the SD card
                   sd_command:
023D: C0 E0                push    acc
                           ; transmit command
023F: 44 40                orl     a,#0x40 ; transmission bit
0241: 31 2C                acall   spi_transfer
                           ; transmit argument
0243: EB                   mov     a,r3
0244: 31 2C                acall   spi_transfer
0246: EA                   mov     a,r2
0247: 31 2C                acall   spi_transfer
0249: E9                   mov     a,r1
024A: 31 2C                acall   spi_transfer
024C: E8                   mov     a,r0
024D: 31 2C                acall   spi_transfer
                           ; transmit crc
024F: EC                   mov     a,r4
0250: 44 01                orl     a,#0x01 ; end bit
0252: 31 2C                acall   spi_transfer
0254: D0 E0                pop     acc
0256: 22                   ret
                   
                   ; *** sd/response.inc ***
                   
                   ; >> uint8{a} sd_response1() <<
                   
                   ; Read response from SD card in 'R1' format into a
                   sd_response1:
0257: C0 F0                push    b
0259: 85 08 F0             mov     b,8     ; number of tries
                   sd_response1__loop:
025C: 74 FF                mov     a,#0xff
025E: 31 2C                acall   spi_transfer
0260: B4 FF 03             cjne    a,#0xff,sd_response1__end       ; success
0263: D5 F0 F6             djnz    b,sd_response1__loop    ; retry / timeout
                   sd_response1__end:
0266: D0 F0                pop     b
0268: 22                   ret
                   
                   ; >> uint8{a}, uint32{r0-r3} sd_response3() <<
                   
                   ; Read response from SD card in 'R3' format into a and r0-r3
                   sd_response3: ; same as R7
                   
                   ; >> uint8{a}, uint32{r0-r3} sd_response7() <<
                   
                   ; Read response from SD card in 'R7' format into a and r0-r3
                   sd_response7:
0269: 51 57                acall   sd_response1
026B: B4 02 00             cjne    a,#0x02,sd_response7__1
                   sd_response7__1:
026E: 40 01                jc      sd_response7__2
0270: 22                   ret     ; error in R1 response
                   sd_response7__2:
0271: F8                   mov     r0,a
0272: 74 FF                mov     a,#0xff
0274: 31 2C                acall   spi_transfer
0276: FB                   mov     r3,a
0277: 74 FF                mov     a,#0xff
0279: 31 2C                acall   spi_transfer
027B: FA                   mov     r2,a
027C: 74 FF                mov     a,#0xff
027E: 31 2C                acall   spi_transfer
0280: F9                   mov     r1,a
0281: 74 FF                mov     a,#0xff
0283: 31 2C                acall   spi_transfer
0285: C8                   xch     a,r0
0286: 22                   ret
                   
                   ; *** sd/block_read.inc ***
                   
                   ; >> uint16{r4-r5} sd_block_read(
                   ;       uint32{r0-r3} block_address,
                   ;       char *{dptr}&destination) <<
                   
                   ; Read block at address from sd card, write to RAM at dptr.
                   ; Return CRC in r4-r5, block address unchanged,
                   ; dptr pointing to first byte after read block.
                   
                   sd_block_read:
0287: C0 E0                push    acc
                   
                           ; send CMD17 (single block read)
0289: 74 11                mov     a,#17
028B: 7C FF                mov     r4,#0xff ; command CRC, ignored
028D: 51 3D                acall   sd_command
                   sd_block_read__wait:
028F: 51 57                acall   sd_response1
0291: B4 FE FB             cjne    a,#0xfe,sd_block_read__wait
0294: 7D 00                mov     r5,#0 ; loop counter
                           ; this loop will run 256 times,
                           ; two bytes are read per iteration
                   sd_block_read__loop:
0296: 74 FF                mov     a,#0xff
0298: 31 2C                acall   spi_transfer
029A: F0                   movx    @dptr,a
029B: A3                   inc     dptr
029C: 74 FF                mov     a,#0xff
029E: 31 2C                acall   spi_transfer
02A0: F0                   movx    @dptr,a
02A1: A3                   inc     dptr
02A2: DD F2                djnz    r5,sd_block_read__loop
                           ; read block CRC
02A4: 74 FF                mov     a,#0xff
02A6: 31 2C                acall   spi_transfer
02A8: FD                   mov     r5,a
02A9: 74 FF                mov     a,#0xff
02AB: 31 2C                acall   spi_transfer
02AD: FC                   mov     r4,a
                   
02AE: D0 E0                pop     acc
02B0: 22                   ret
                   
                   
                   ; *** util/delay.inc ***
                   
                   ; >> void delay_ms_8(uint8{a} duration) <<
                   
                   ; 1-256 millisecond delay, duration given in a.
                   ; Assumes 20MHz clock and X2 mode.
                   ; Actual delay is slightly longer.
                   delay_ms_8:
                   
02B1: C0 E0                push    acc
02B3: C0 F0                push    b
                   
                           ; This loop is repeated a times (256 if a is zero).
                           ; The goal is to stretch each repeat to one millisec
                   delay_ms_8__loop1:
                           ; Each millisecond is 20k clock periods.
                           ; In X2 mode, a machine cycle is 6 clock periods.
                           ; Therefore, a millisecond is approx. 3334 machine c
02B5: 75 F0 B9             mov     b,#185  ; n = 185       cycles:   2
                   delay_ms_8__loop2:
02B8: C0 E0                push    acc                     ; n*2 = 370
02BA: C0 F0                push    b                       ; n*2 = 370
02BC: A4                   mul     ab                      ; n*4 = 740
02BD: A4                   mul     ab                      ; n*4 = 740
02BE: D0 F0                pop     b                       ; n*2 = 370
02C0: D0 E0                pop     acc                     ; n*2 = 370
02C2: D5 F0 F3             djnz    b,delay_ms_8__loop2     ; n*2 = 370
02C5: D5 E0 ED             djnz    acc,delay_ms_8__loop1   ;         2
                                                           ; Sum: 3334
02C8: D0 F0                pop     b
02CA: D0 E0                pop     acc
02CC: 22                   ret
                   
                   ; *** print/char.inc ***
                   
                   ; >> void print_char(char a) <<
                   
                   ; Print char from accumulator.
                   ; Indirect call to function behind OUT pointer.
                   
                   print_char:
02CD: C0 32                push    OUT
02CF: C0 33                push    OUT+1
02D1: 22                   ret
                   
                   ; *** print/hex.inc ***
                   
                   ; >> void print_hex_8(char a) <<
                   
                   ; Print hexadecimal number from accumulator.
                   
                   print_hex_8:
02D2: C4                   swap    a       ; high nibble first
02D3: 51 D6                acall   print_hex_8__nibble
02D5: C4                   swap    a
                   print_hex_8__nibble:
02D6: C0 E0                push    ACC
02D8: 54 0F                anl     a,      #0x0f
02DA: 24 90                add     a,      #0x90
02DC: D4                   da      a
02DD: 34 40                addc    a,      #0x40
02DF: D4                   da      a
02E0: 44 20                orl     a,      #0x20   ; lower case
02E2: 51 CD                acall   print_char
02E4: D0 E0                pop     ACC
02E6: 22                   ret
                   
                   ; >> void print_hex_16(int r0r1) <<
                   
                   ; Print hexadecimal number from r0-r1.
                   
                   print_hex_16:
02E7: C0 E0                push    ACC
02E9: E9                   mov     a,      r1      ; MSB first
02EA: 51 D2                acall   print_hex_8
02EC: E8                   mov     a,      r0      ; LSB second
02ED: 51 D2                acall   print_hex_8
02EF: D0 E0                pop     ACC
02F1: 22                   ret
                   
                   ; >> void print_hex_32(long r0r1r2r3) <<
                   
                   ; Print hexadecimal number from r0-r3.
                   
                   print_hex_32:
02F2: C0 E0                push    ACC
02F4: EB                   mov     a,      r3      ; MSB first
