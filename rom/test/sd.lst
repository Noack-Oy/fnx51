034A                        1  
034A                        2  ; *** util/dump.inc ***
034A                        3  
034A                        4  ; >> uint32{r0-r3} dump(uint32{r0-r3} addr, uint8{a} count) <<
034A                        5  
034A                        6  ; Print hexdump from standard input to standard output.
034A                        7  ; Starting value for address column in r0-r3.
034A                        8  ; Number of bytes to print in a (0 means 256).
034A                        9  ; r0-r3 contains next address upon exit.
034A                       10  
034A                       11  dump:
034A  C0 F0                12  	push	b
034C  C0 E0                13  	push	acc
034E  F5 F0                14  	mov	b,	a
0350  C0 04                15  	push	4
0352  C0 05                16  	push	5
0354  C0 06                17  	push	6
0356  C0 07                18  	push	7
0358                       19  
0358                       20  	; b: total bytes remaining
0358                       21  	; r0: buffer pointer
0358                       22  	; r1: read loop counter / padding size
0358                       23  	; r2: print loop counter
0358                       24  
0358                       25  	; r4-7: address label
0358  71 3D                26  	acall	xch_r0123_r4567
035A                       27  
035A                       28  	; allocate 16 byte array on stack
035A  E5 81                29  	mov	a,	sp
035C  F8                   30  	mov	r0,	a
035D  24 10                31  	add	a,	#16
035F  F5 81                32  	mov	sp,	a
0361                       33  
0361                       34  dump__line_loop:
0361                       35  	; read into buffer
0361  79 10                36  	mov	r1,	#16
0363                       37  dump__read_loop:
0363  71 38                38  	acall	read_char
0365  08                   39  	inc	r0
0366  F6                   40  	mov	@r0,	a
0367  D5 F0 03             41  	djnz	b,	dump__read_continue
036A  19                   42  	dec	r1
036B  80 02                43  	sjmp	dump__read_end
036D                       44  dump__read_continue:
036D  D9 F4                45  	djnz	r1,	dump__read_loop
036F                       46  dump__read_end:
036F                       47  
036F                       48  	; print address column
036F  71 3D                49  	acall	xch_r0123_r4567
0371  51 F2                50  	acall	print_hex_32
0373  71 3D                51  	acall	xch_r0123_r4567
0375  74 3A                52  	mov	a,	#':'
0377  51 CD                53  	acall	print_char
0379                       54  
0379                       55  	; if r1 is nonzero here, we have a shorter line
0379                       56  	; the value in r1 is the number of padding bytes
0379                       57  
0379                       58  	; wind back pointer
0379  E8                   59  	mov	a,	r0
037A  24 F0                60  	add	a,	#-16
037C  29                   61  	add	a,	r1
037D  F8                   62  	mov	r0,	a
037E                       63  
037E                       64  	; print hex
037E  7A 10                65  	mov	r2,	#16
0380                       66  dump__print_hex_loop:
0380  08                   67  	inc	r0
0381  EA                   68  	mov	a,	r2
0382  54 03                69  	anl	a,	#3	; mod 4
0384  70 04                70  	jnz	dump__print_hex_no_gap
0386  74 20                71  	mov	a,	#' ' ; gap after every 4 bytes
0388  51 CD                72  	acall	print_char
038A                       73  dump__print_hex_no_gap:
038A  EA                   74  	mov	a,	r2
038B  D3                   75  	setb	c
038C  99                   76  	subb	a,	r1
038D  50 08                77  	jnc	dump__print_hex_no_padding
038F  74 20                78  	mov	a,	#' ' ; padding for shorter line
0391  51 CD                79  	acall	print_char
0393  51 CD                80  	acall	print_char
0395  80 03                81  	sjmp	dump__print_hex_next
0397                       82  dump__print_hex_no_padding:
0397  E6                   83  	mov	a,	@r0
0398  51 D2                84  	acall	print_hex_8
039A                       85  dump__print_hex_next:
039A  74 20                86  	mov	a,	#' ' ; space between bytes
039C  51 CD                87  	acall	print_char
039E  DA E0                88  	djnz	r2,	dump__print_hex_loop
03A0                       89  
03A0                       90  	; wind back again
03A0  E8                   91  	mov	a,	r0
03A1  24 F0                92  	add	a,	#-16
03A3  F8                   93  	mov	r0,	a
03A4                       94  
03A4                       95  	; print ascii
03A4  74 20                96  	mov	a,	#' '
03A6  51 CD                97  	acall	print_char
03A8  74 7C                98  	mov	a,	#'|'
03AA  51 CD                99  	acall	print_char
03AC  74 10               100  	mov	a,	#16
03AE  C3                  101  	clr	c
03AF  99                  102  	subb	a,	r1
03B0  F9                  103  	mov	r1,	a ; number of bytes to print
03B1  FA                  104  	mov	r2,	a
03B2                      105  dump__print_ascii_loop:
03B2  08                  106  	inc	r0
03B3  E6                  107  	mov	a,	@r0
03B4  B4 20 00            108  	cjne	a,	#0x20,	dump__print_ascii_check1
03B7                      109  dump__print_ascii_check1:
03B7  40 05               110  	jc	dump__print_ascii_replace
03B9  B4 7F 00            111  	cjne	a,	#0x7f,	dump__print_ascii_check2
03BC                      112  dump__print_ascii_check2:
03BC  40 02               113  	jc	dump__print_ascii_continue
03BE                      114  dump__print_ascii_replace:
03BE  74 2E               115  	mov	a,	#'.'
03C0                      116  dump__print_ascii_continue:
03C0  51 CD               117  	acall	print_char
03C2  DA EE               118  	djnz	r2,	dump__print_ascii_loop
03C4  74 7C               119  	mov	a,	#'|'
03C6  51 CD               120  	acall	print_char
03C8  74 0D               121  	mov	a,	#13
03CA  51 CD               122  	acall	print_char
03CC  74 0A               123  	mov	a,	#10
03CE  51 CD               124  	acall	print_char
03D0                      125  
03D0                      126  	; wind back again
03D0  E8                  127  	mov	a,	r0
03D1  24 F0               128  	add	a,	#-16
03D3  F8                  129  	mov	r0,	a
03D4                      130  
03D4                      131  	; next address
03D4  EC                  132  	mov	a,	r4
03D5  29                  133  	add	a,	r1
03D6  FC                  134  	mov	r4,	a
03D7  ED                  135  	mov	a,	r5
03D8  34 00               136  	addc	a,	#0
03DA  FD                  137  	mov	r5,	a
03DB  EE                  138  	mov	a,	r6
03DC  34 00               139  	addc	a,	#0
03DE  FE                  140  	mov	r6,	a
03DF  EF                  141  	mov	a,	r7
03E0  34 00               142  	addc	a,	#0
03E2  FF                  143  	mov	r7,	a
03E3                      144  
03E3  E5 F0               145  	mov	a,	b
03E5  60 02               146  	jz	dump__end
03E7  61 61               147  	ajmp	dump__line_loop
03E9                      148  
03E9                      149  dump__end:
03E9                      150  	; deallocate array from stack
03E9  E5 81               151  	mov	a,	sp
03EB  24 F0               152  	add	a,	#-16
03ED  F5 81               153  	mov	sp,	a
03EF                      154  
03EF  71 3D               155  	acall	xch_r0123_r4567
03F1                      156  
03F1  D0 07               157  	pop	7
03F3  D0 06               158  	pop	6
03F5  D0 05               159  	pop	5
03F7  D0 04               160  	pop	4
03F9  D0 E0               161  	pop	acc
03FB  D0 F0               162  	pop	b
03FD  22                  163  	ret
03FE                      164  
