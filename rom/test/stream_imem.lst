02AA: 9C                   subb    a,r4
02AB: F8                   mov     r0,a
02AC: E9                   mov     a,r1
02AD: 9D                   subb    a,r5
02AE: F9                   mov     r1,a
02AF: EA                   mov     a,r2
02B0: 9E                   subb    a,r6
02B1: FA                   mov     r2,a
02B2: EB                   mov     a,r3
02B3: 9F                   subb    a,r7
02B4: FB                   mov     r3,a
02B5: 05 F0                inc     b
02B7: 50 F0                jnc     print_int_u32__divide_loop
                           ; restore remainder
