0130: 11 B4                acall   print_char
                   print_int_u8__ones:
0132: E5 F0                mov     a,      b
0134: 24 30                add     a,      #'0'
0136: 11 B4                acall   print_char
                   
0138: D0 00                pop     0
013A: D0 F0                pop     B
013C: D0 E0                pop     ACC
013E: 22                   ret
                   
