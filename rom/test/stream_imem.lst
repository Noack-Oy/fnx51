                   ; *** util/xch.inc ***
                   
                   ; >> void xch_r0123_r4567(uint32 &r0r1r2r3, uint32 &r4r5r6r7
                   
                   ; Exchange registers r0-r3 with r4-r7.
                   
                   xch_r0123_r4567:
                           ; r0 <-> r4
0383: C8                   xch     a,      r0
0384: CC                   xch     a,      r4
0385: C8                   xch     a,      r0
                           ; r1 <-> r5
0386: C9                   xch     a,      r1
0387: CD                   xch     a,      r5
0388: C9                   xch     a,      r1
                           ; r2 <-> r6
0389: CA                   xch     a,      r2
038A: CE                   xch     a,      r6
038B: CA                   xch     a,      r2
                           ; r3 <-> r7
038C: CB                   xch     a,      r3
038D: CF                   xch     a,      r7
038E: CB                   xch     a,      r3
                           ; a remains unchanged
038F: 22                   ret
                   
