011B: 75 F0 64             mov     b,      #100
011E: 84                   div     ab
011F: 60 05                jz      print_int_u8__tens
0121: 24 30                add     a,      #'0'
0123: 11 B4                acall   print_char
0125: 08                   inc     r0      ; stop skipping leading zeroes
                   print_int_u8__tens:
0126: E5 F0                mov     a,      b
0128: 75 F0 0A             mov     b,      #10
012B: 84                   div     ab
012C: 28                   add     a,      r0
012D: 60 05                jz      print_int_u8__ones
012F: 98                   subb    a,      r0
0130: 24 30                add     a,      #'0'
0132: 11 B4                acall   print_char
                   print_int_u8__ones:
0134: E5 F0                mov     a,      b
0136: 24 30                add     a,      #'0'
0138: 11 B4                acall   print_char
                   
013A: D0 00                pop     0
013C: D0 F0                pop     B
013E: D0 E0                pop     ACC
0140: 22                   ret
                   
