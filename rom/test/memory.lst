0149: 31 1D                acall   print_hex_8
014B: D0 E0                pop     ACC
014D: 22                   ret
                   
                   ; *** util/xch.inc ***
                   
                   ; >> void xch_r0123_r4567(uint32 &r0r1r2r3, uint32 &r4r5r6r7
                   
                   ; Exchange registers r0-r3 with r4-r7.
                   
                   xch_r0123_r4567:
                           ; r0 <-> r4
014E: C8                   xch     a,      r0
014F: CC                   xch     a,      r4
0150: C8                   xch     a,      r0
                           ; r1 <-> r5
0151: C9                   xch     a,      r1
0152: CD                   xch     a,      r5
0153: C9                   xch     a,      r1
                           ; r2 <-> r6
0154: CA                   xch     a,      r2
0155: CE                   xch     a,      r6
0156: CA                   xch     a,      r2
                           ; r3 <-> r7
0157: CB                   xch     a,      r3
0158: CF                   xch     a,      r7
0159: CB                   xch     a,      r3
                           ; a remains unchanged
015A: 22                   ret
                   
                   ; *** util/dump.inc ***
                   
