0000                        1  
0000                        2  ; *** global/init.inc ***
0000                        3  
0000                        4  ; Initialize stack pointer and global variables.
0000                        5  ; This must be included early in the main program.
0000                        6  
0000                        7  global_init:
0000  75 81 60              8  	mov	SP,#STACK
0003                        9  
0003                       10  ; Select register bank zero, clear processor flags
0003  75 D0 00             11  	mov	PSW,#0
0006                       12  
0006                       13  ; Fill internal RAM with markers for uninitialized data
0006  78 00                14  	mov	r0,#0 ; write pointer
0008                       15  
0008  74 3F                16  	mov	a,#0x3f ; '?' for uninitialized registers
000A                       17  global_init__1:
000A  08                   18  	inc	r0 ; first iteration skips address 0, r0 lives there
000B  F6                   19  	mov	@r0,a
000C  B8 1F FB             20  	cjne	r0,#0x1f,global_init__1
000F                       21  
000F  74 2A                22  	mov	a,#0x2a ; '*' for uninitialized variables
0011                       23  global_init__2:
0011  08                   24  	inc	r0
0012  F6                   25  	mov	@r0,a
0013  B8 5F FB             26  	cjne	r0,#STACK-1,global_init__2
0016                       27  
0016  74 7E                28  	mov	a,#0x7e ; '~' for stack and above
0018                       29  global_init__3:
0018  08                   30  	inc	r0
0019  F6                   31  	mov	@r0,a
001A  B8 FF FB             32  	cjne	r0,#0xff,global_init__3
001D                       33  
