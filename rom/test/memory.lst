020F                        1  
020F                        2  ; *** stream/xram_read.inc ***
020F                        3  
020F                        4  ; >> char{a} stream_xram_read() <<
020F                        5  
020F                        6  ; Read byte from on-chip expanded RAM at stream input pointer.
020F                        7  ; 16 bit value of the stream pointer is used and incremented.
020F                        8  
020F                        9  stream_xram_read:
020F  C0 8E                10  	push	auxr
0211  C0 82                11  	push	dpl
0213  C0 83                12  	push	dph
0215                       13  
0215  53 8E E1             14  	anl	auxr,#0xe1	; clear extram, xrs0-2
0218  43 8E 10             15  	orl	auxr,#0x10	; set xrs2 (size 1792 bytes)
021B                       16  
021B  85 34 82             17  	mov	dpl,stream_in
021E  85 35 83             18  	mov	dph,stream_in+1
0221                       19  
0221  E0                   20  	movx	a,@dptr
0222  A3                   21  	inc	dptr
0223  85 82 34             22  	mov	stream_in,dpl
0226  85 83 35             23  	mov	stream_in+1,dph
0229                       24  
0229  D0 83                25  	pop	dph
022B  D0 82                26  	pop	dpl
022D  D0 8E                27  	pop	auxr
022F  22                   28  	ret
0230                       29  
