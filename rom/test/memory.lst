                         ; ==== ../serial/rx.inc ====
009C                        1  
009C                        2  ; *** serial/rx.inc ***
009C                        3  
009C                        4  ; >> char serial_rx <<
009C                        5  
009C                        6  ; Receive byte into accumulator.
009C                        7  
009C                        8  serial_rx:
009C  30 98 FD              9  	jnb	RI,	serial_rx
009F  C2 98                10  	clr	RI
00A1  E5 99                11  	mov	a,	SBUF
00A3  22                   12  	ret
00A4                       13  
