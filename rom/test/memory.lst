0230                        1  
0230                        2  ; *** memory/init.inc ***
0230                        3  
0230                        4  ; >> void memory_init(() <<
0230                        5  
0230                        6  ; Enable xram, initialize memory allocator data structures
0230                        7  
0230                        8  memory_init:
0230                        9  
0230  C0 E0                10  	push	acc
0232  C0 82                11  	push	dpl
0234  C0 83                12  	push	dph
0236                       13  
0236                       14  	; use xram
0236  53 8E E1             15  	anl	auxr,#0xe1	; clear extram, xrs0-2
0239  43 8E 10             16  	orl	auxr,#0x10	; set xrs2 (size 1792 bytes)
023C                       17  
023C                       18  	; clear xram with dummy value
023C  90 00 00             19  	mov	dptr,#0
023F                       20  memory_init__1:
023F  74 23                21  	mov	a,#0x23
0241  F0                   22  	movx	@dptr,a
0242  A3                   23  	inc	dptr
0243  74 07                24  	mov	a,#0x07 ; xram goes up to 0x06ff
0245  B5 83 F7             25  	cjne	a,dph,memory_init__1
0248                       26  
0248                       27  	; initialize memory list
0248  90 00 00             28  	mov	dptr,#0
024B  85 82 38             29  	mov	memory_list,dpl
024E  85 83 39             30  	mov	memory_list+1,dph
0251                       31  	; list head: pointer to first block
0251  74 04                32  	mov	a,#4
0253  F5 40                33  	mov	memory_start,a
0255  F0                   34  	movx	@dptr,a
0256  A3                   35  	inc	dptr
0257  E4                   36  	clr	a
0258  F5 41                37  	mov	memory_start+1,a
025A  F0                   38  	movx	@dptr,a
025B  A3                   39  	inc	dptr
025C                       40  	; max address of allocatable memory: 0x06ff
025C  75 42 FF             41  	mov	memory_end,#0xff
025F  85 06 43             42  	mov	memory_end+1,0x06
0262                       43  	; amount of free memory: 1792-4 = 1788 = 0x06fc
0262  74 FC                44  	mov	a,#0xfc
0264  F0                   45  	movx	@dptr,a
0265  A3                   46  	inc	dptr
0266  74 06                47  	mov	a,#0x06
0268  F0                   48  	movx	@dptr,a
0269  A3                   49  	inc	dptr
026A                       50  	; first entry: pointer to next (null initially)
026A  E4                   51  	clr	a
026B  F0                   52  	movx	@dptr,a
026C  A3                   53  	inc	dptr
026D  F0                   54  	movx	@dptr,a
026E  A3                   55  	inc	dptr
026F                       56  	; size of block (same as free memory initially)
026F  74 FC                57  	mov	a,#0xfc
0271  F0                   58  	movx	@dptr,a
0272  A3                   59  	inc	dptr
0273  74 06                60  	mov	a,#0x06
0275  F0                   61  	movx	@dptr,a
0276  A3                   62  	inc	dptr
0277                       63  
0277  D0 83                64  	pop	dph
0279  D0 82                65  	pop	dpl
027B  D0 E0                66  	pop	acc
027D                       67  
027D  22                   68  	ret
