00A4                        4  ; >> char read_char() <<
00A4                        5  
00A4                        6  ; Read char into accumulator.
00A4                        7  ; Indirect call to function behind IN pointer.
00A4                        8  
00A4                        9  read_char:
00A4  C0 30                10  	push	IN
00A6  C0 31                11  	push	IN+1
00A8  22                   12  	ret
00A9                       13  
