                   print_text__end:
0118: D0 00                pop     0
011A: D0 E0                pop     ACC
011C: 22                   ret
                   
                   ; *** print/hex.inc ***
                   
                   ; >> void print_hex_8(char a) <<
                   
                   ; Print hexadecimal number from accumulator.
                   
                   print_hex_8:
011D: C4                   swap    a       ; high nibble first
011E: 31 21                acall   print_hex_8__nibble
0120: C4                   swap    a
                   print_hex_8__nibble:
0121: C0 E0                push    ACC
0123: 54 0F                anl     a,      #0x0f
0125: 24 90                add     a,      #0x90
0127: D4                   da      a
