027E                        3  
027E                        4  ; >> char *{dptr} memory_allocate(uint16{r0r1} size) <<
027E                        5  
027E                        6  ; Allocate `size` bytes, return pointer to the start of the block.
027E                        7  
027E                        8  memory_allocate:
027E  C0 A8                 9  	push	ie
0280  C2 AF                10  	clr	ea
0282                       11  
0282  C0 E0                12  	push	acc
0284                       13  	; r0,r1 = size (input, preserved); r2-r7 are clobbered
0284  C0 00                14  	push	0
0286  C0 01                15  	push	1
0288  C0 02                16  	push	2
028A  C0 03                17  	push	3
028C  C0 04                18  	push	4
028E  C0 05                19  	push	5
0290  C0 06                20  	push	6
0292  C0 07                21  	push	7
0294  05 A2                22  	inc	auxr1
0296  C0 82                23  	push	dpl
0298  C0 83                24  	push	dph
029A                       25  
029A                       26  	; size lives in r0r1 throughout (modified by the rounding step,
029A                       27  	; restored by the matching pop at exit). The pointer is built up
029A                       28  	; in r4r5 and copied into dptr just before returning.
029A                       29  
029A  E8                   30  	mov	a,r0
029B  49                   31  	orl	a,r1
