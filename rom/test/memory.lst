015B                       92  .include ../util/dump.inc
                         ; ==== ../util/dump.inc ====
015B                        1  
015B                        2  ; *** util/dump.inc ***
015B                        3  
015B                        4  ; >> uint32{r0-r3} dump(uint32{r0-r3} addr, uint8{a} count) <<
015B                        5  
015B                        6  ; Print hexdump from standard input to standard output.
015B                        7  ; Starting value for address column in r0-r3.
015B                        8  ; Number of bytes to print in a (0 means 256).
015B                        9  ; r0-r3 contains next address upon exit.
015B                       10  
015B                       11  dump:
015B  C0 F0                12  	push	b
015D  C0 E0                13  	push	acc
015F  F5 F0                14  	mov	b,	a
0161  C0 04                15  	push	4
0163  C0 05                16  	push	5
0165  C0 06                17  	push	6
0167  C0 07                18  	push	7
0169                       19  
0169                       20  	; b: total bytes remaining
0169                       21  	; r0: buffer pointer
0169                       22  	; r1: read loop counter / padding size
0169                       23  	; r2: print loop counter
0169                       24  
0169                       25  	; r4-7: address label
0169  31 4E                26  	acall	xch_r0123_r4567
016B                       27  
016B                       28  	; allocate 16 byte array on stack
016B  E5 81                29  	mov	a,	sp
016D  F8                   30  	mov	r0,	a
016E  24 10                31  	add	a,	#16
0170  F5 81                32  	mov	sp,	a
0172                       33  
0172                       34  dump__line_loop:
0172                       35  	; read into buffer
0172  79 10                36  	mov	r1,	#16
0174                       37  dump__read_loop:
0174  11 A4                38  	acall	read_char
0176  08                   39  	inc	r0
0177  F6                   40  	mov	@r0,	a
0178  D5 F0 03             41  	djnz	b,	dump__read_continue
017B  19                   42  	dec	r1
017C  80 02                43  	sjmp	dump__read_end
017E                       44  dump__read_continue:
017E  D9 F4                45  	djnz	r1,	dump__read_loop
0180                       46  dump__read_end:
0180                       47  
0180                       48  	; print address column
0180  31 4E                49  	acall	xch_r0123_r4567
0182  31 3D                50  	acall	print_hex_32
0184  31 4E                51  	acall	xch_r0123_r4567
0186  74 3A                52  	mov	a,	#':'
0188  31 04                53  	acall	print_char
018A                       54  
018A                       55  	; if r1 is nonzero here, we have a shorter line
018A                       56  	; the value in r1 is the number of padding bytes
018A                       57  
018A                       58  	; wind back pointer
018A  E8                   59  	mov	a,	r0
018B  24 F0                60  	add	a,	#-16
018D  29                   61  	add	a,	r1
018E  F8                   62  	mov	r0,	a
018F                       63  
018F                       64  	; print hex
018F  7A 10                65  	mov	r2,	#16
0191                       66  dump__print_hex_loop:
