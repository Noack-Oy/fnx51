02CD  EE                   74  	mov	a,r6
02CE  98                   75  	subb	a,r0
02CF  70 18                76  	jnz	memory_allocate__1
02D1                       77  
02D1                       78  	; block size is exact match
02D1  8A 82                79  	mov	dpl,r2	; prev
02D3  8B 83                80  	mov	dph,r3
02D5  05 A2                81  	inc	auxr1	;*switch data pointers
02D7  8C 82                82  	mov	dpl,r4	; curr
02D9  8D 83                83  	mov	dph,r5
02DB                       84  	; prev->next = curr->next
02DB  E0                   85  	movx	a,@dptr
02DC  A3                   86  	inc	dptr
02DD  05 A2                87  	inc	auxr1	;*
02DF  F0                   88  	movx	@dptr,a
02E0  A3                   89  	inc	dptr
02E1  05 A2                90  	inc	auxr1	;*
02E3  E0                   91  	movx	a,@dptr
02E4  05 A2                92  	inc	auxr1	;*
02E6  F0                   93  	movx	@dptr,a
02E7  80 47                94  	sjmp	memory_allocate__success
02E9                       95  
02E9                       96  memory_allocate__1:
02E9  50 0F                97  	jnc	memory_allocate__2 ; jump if curr is larger than required
02EB                       98  	; too small, move on to next entry in list
02EB  EC                   99  	mov	a,r4	; -.
02EC  FA                  100  	mov	r2,a	;  |- prev = curr
02ED  ED                  101  	mov	a,r5	;  |
02EE  FB                  102  	mov	r3,a	; -'
02EF  8C 82               103  	mov	dpl,r4	; -.
02F1  8D 83               104  	mov	dph,r5	;  |
02F3  E0                  105  	movx	a,@dptr ;  |
02F4  FC                  106  	mov	r4,a	;  |- curr = curr->next
02F5  A3                  107  	inc	dptr	;  |
02F6  E0                  108  	movx	a,@dptr ;  |
02F7  FD                  109  	mov	r5,a	; -'
02F8  80 BE               110  	sjmp	memory_allocate__loop
02FA                      111  
02FA                      112  memory_allocate__2:
02FA                      113  	; split big block
02FA  8A 82               114  	mov	dpl,r2	; prev
02FC  8B 83               115  	mov	dph,r3	;
02FE  EC                  116  	mov	a,r4	; -.
02FF  28                  117  	add	a,r0	;  |
0300  FA                  118  	mov	r2,a	;  |
0301  F0                  119  	movx	@dptr,a ;  |
0302  A3                  120  	inc	dptr	;  |- prev->next = curr+size
0303  ED                  121  	mov	a,r5	;  |               '---.---'
0304  39                  122  	addc	a,r1	;  |  pointer to leftover block
0305  FB                  123  	mov	r3,a	;  |  also gets stored in r2r3
0306  F0                  124  	movx	@dptr,a ; -' (prev is not needed anymore)
0307                      125  
0307  8A 82               126  	mov	dpl,r2  ; leftover
0309  8B 83               127  	mov	dph,r3
030B  05 A2               128  	inc	auxr1	;*switch data pointers
030D  8C 82               129  	mov	dpl,r4	; curr
030F  8D 83               130  	mov	dph,r5
0311  E0                  131  	movx	a,@dptr	; -.
0312  A3                  132  	inc	dptr	;  |
0313  05 A2               133  	inc	auxr1	;* |
0315  F0                  134  	movx	@dptr,a ;  |
0316  A3                  135  	inc	dptr	;  |
0317  05 A2               136  	inc	auxr1	;* |- leftover->next = curr->next
0319  E0                  137  	movx	a,@dptr ;  |
031A  A3                  138  	inc	dptr	;  |
031B  05 A2               139  	inc	auxr1	;* |
031D  F0                  140  	movx	@dptr,a ;  |
031E  A3                  141  	inc	dptr	; -'
031F                      142  	; data pointers are now &(leftover->size) and &(curr->size)
031F  05 A2               143  	inc	auxr1	;*-.
0321  E0                  144  	movx	a,@dptr ;  |
0322  A3                  145  	inc	dptr	;  |
0323  C3                  146  	clr	c	;  |
0324  98                  147  	subb	a,r0	;  |
0325  05 A2               148  	inc	auxr1	;* |
0327  F0                  149  	movx	@dptr,a ;  |- leftover->size = curr->size - size
0328  A3                  150  	inc	dptr	;  |
0329  05 A2               151  	inc	auxr1	;* |
032B  E0                  152  	movx	a,@dptr ;  |
032C  99                  153  	subb	a,r1	;  |
032D  05 A2               154  	inc	auxr1	;* |
032F  F0                  155  	movx	@dptr,a ; -'
0330                      156  
0330                      157  memory_allocate__success:
0330  85 38 82            158  	mov	dpl,memory_list
0333  85 39 83            159  	mov	dph,memory_list+1
0336  A3                  160  	inc	dptr	; -.
0337  A3                  161  	inc	dptr	;  |
0338  E0                  162  	movx	a,@dptr ;  |
0339  C3                  163  	clr	c	;  |
033A  98                  164  	subb	a,r0	;  |- memory_list->free -= size
033B  F0                  165  	movx	@dptr,a ;  |
033C  A3                  166  	inc	dptr	;  |
033D  E0                  167  	movx	a,@dptr ;  |
033E  99                  168  	subb	a,r1	;  |
033F  F0                  169  	movx	@dptr,a ; -'
0340                      170  
0340                      171  	; restore the alternate dptr, then set the main dptr to the
0340                      172  	; result pointer that's been sitting in r4r5
0340  D0 83               173  	pop	dph
0342  D0 82               174  	pop	dpl
0344  05 A2               175  	inc	auxr1
0346  8C 82               176  	mov	dpl,r4
0348  8D 83               177  	mov	dph,r5
034A                      178  
034A  D0 07               179  	pop	7
034C  D0 06               180  	pop	6
034E  D0 05               181  	pop	5
0350  D0 04               182  	pop	4
0352  D0 03               183  	pop	3
0354  D0 02               184  	pop	2
0356  D0 01               185  	pop	1
0358  D0 00               186  	pop	0
035A  D0 E0               187  	pop	acc
035C                      188  
035C  D0 A8               189  	pop	ie
035E  22                  190  	ret
