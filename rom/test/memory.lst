                         ; ==== ../serial/init.inc ====
0078                        1  
0078                        2  ; *** serial/init.inc ***
0078                        3  
0078                        4  ; >> void serial_init() <<
0078                        5  
0078                        6  ; Initialize serial interface.
0078                        7  ; - assumes 20MHz clock and X2 mode
0078                        8  ; - uses internal baud rate generator
0078                        9  ; - speed: 9600 bits per second
0078                       10  ; Formula: BRL = 256 - (F_clk / (32 * Baud_Rate))
0078                       11  ; ---
0078                       12  ; See datasheet page 52 for details,
0078                       13  ; also note oscillator diagram on page 16!
0078                       14  
0078                       15  serial_init:
0078  75 98 52             16  	mov	SCON,	#0x52	; SM1, REN, TI
007B  75 9A BF             17  	mov	BRL,	#191	; 9600 @20MHz CLK
007E  75 9B 1E             18  	mov	BDRCON, #0x1e	; BRR, RBCK, TBCK, SPD
0081                       19  
0081  90 00 9C             20  	mov	dptr,	#serial_rx
0084  85 82 30             21  	mov	IN,	DPL
0087  85 83 31             22  	mov	IN+1,	DPH
008A                       23  
008A  90 00 94             24  	mov	dptr,	#serial_tx
008D  85 82 32             25  	mov	OUT,	DPL
0090  85 83 33             26  	mov	OUT+1,	DPH
0093                       27  
0093  22                   28  	ret
0094                       29  
                         ; ==== memory.asm ====
0094                       84  .include ../serial/tx.inc
                         ; ==== ../serial/tx.inc ====
0094                        1  
0094                        2  ; *** serial/tx.inc ***
0094                        3  
0094                        4  ; >> void serial_tx(char a) <<
0094                        5  
0094                        6  ; Transmit byte from accumulator.
0094                        7  
0094                        8  serial_tx:
0094  30 99 FD              9  	jnb	TI,	serial_tx
0097  C2 99                10  	clr	TI
0099  F5 99                11  	mov	SBUF,	a
009B  22                   12  	ret
009C                       13  
                         ; ==== memory.asm ====
