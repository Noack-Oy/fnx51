049C                        2  ; *** panic/panic.inc ***
049C                        3  
049C                        4  ; >> void panic() <<
049C                        5  
049C                        6  ; Unrecoverable error handler.
049C                        7  ; Print caller address and halt.
049C                        8  
049C                        9  panic:
049C  C2 AF                10  	clr	ea	; disable interrupts
049E  F8                   11  	mov	r0,a	; save a
049F                       12  	; display panic text
049F  90 00 94             13  	mov	dptr,#panic_out
04A2  85 82 32             14  	mov	out,dpl
04A5  85 83 33             15  	mov	out+1,dph
04A8  90 04 CF             16  	mov	dptr,#panic_text
04AB  31 09                17  	acall	print_text
04AD                       18  	; get return address from stack
04AD  D0 E0                19  	pop	acc
04AF  FA                   20  	mov	r2,a
04B0  D0 E0                21  	pop	acc
