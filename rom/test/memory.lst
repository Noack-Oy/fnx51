                         ; ==== ../print/hex.inc ====
011D                        1  
011D                        2  ; *** print/hex.inc ***
011D                        3  
011D                        4  ; >> void print_hex_8(char a) <<
011D                        5  
011D                        6  ; Print hexadecimal number from accumulator.
011D                        7  
011D                        8  print_hex_8:
011D  C4                    9  	swap	a	; high nibble first
011E  31 21                10  	acall	print_hex_8__nibble
0120  C4                   11  	swap	a
0121                       12  print_hex_8__nibble:
0121  C0 E0                13  	push	ACC
0123  54 0F                14  	anl	a,	#0x0f
0125  24 90                15  	add	a,	#0x90
0127  D4                   16  	da	a
0128  34 40                17  	addc	a,	#0x40
012A  D4                   18  	da	a
012B  44 20                19  	orl	a,	#0x20	; lower case
012D  31 04                20  	acall	print_char
012F  D0 E0                21  	pop	ACC
0131  22                   22  	ret
0132                       23  
0132                       24  ; >> void print_hex_16(int r0r1) <<
0132                       25  
0132                       26  ; Print hexadecimal number from r0-r1.
0132                       27  
0132                       28  print_hex_16:
0132  C0 E0                29  	push	ACC
0134  E9                   30  	mov	a,	r1	; MSB first
0135  31 1D                31  	acall	print_hex_8
0137  E8                   32  	mov	a,	r0	; LSB second
0138  31 1D                33  	acall	print_hex_8
013A  D0 E0                34  	pop	ACC
013C  22                   35  	ret
013D                       36  
013D                       37  ; >> void print_hex_32(long r0r1r2r3) <<
013D                       38  
013D                       39  ; Print hexadecimal number from r0-r3.
013D                       40  
013D                       41  print_hex_32:
013D  C0 E0                42  	push	ACC
013F  EB                   43  	mov	a,	r3	; MSB first
0140  31 1D                44  	acall	print_hex_8
0142  EA                   45  	mov	a,	r2
0143  31 1D                46  	acall	print_hex_8
0145  E9                   47  	mov	a,	r1
0146  31 1D                48  	acall	print_hex_8
0148  E8                   49  	mov	a,	r0	; LSB last
0149  31 1D                50  	acall	print_hex_8
014B  D0 E0                51  	pop	ACC
014D  22                   52  	ret
014E                       53  
