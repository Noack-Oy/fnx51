0000                        2  ; ************************************
0000                        3  ; * Memory Management Test Program *
0000                        4  ; ************************************
0000                        5  
0000                        6  ; Interactive test:
0000                        7  ; D <addr> <size>; 	- dump memory
0000                        8  ; A <size>;		- allocate memory
0000                        9  ; R <addr> <size>;	- release memory
0000                       10  
