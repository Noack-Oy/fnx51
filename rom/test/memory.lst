014E                        1  
014E                        2  ; *** util/xch.inc ***
014E                        3  
014E                        4  ; >> void xch_r0123_r4567(uint32 &r0r1r2r3, uint32 &r4r5r6r7) <<
014E                        5  
014E                        6  ; Exchange registers r0-r3 with r4-r7.
014E                        7  
014E                        8  xch_r0123_r4567:
014E                        9  	; r0 <-> r4
014E  C8                   10  	xch	a,	r0
014F  CC                   11  	xch	a,	r4
0150  C8                   12  	xch	a,	r0
0151                       13  	; r1 <-> r5
0151  C9                   14  	xch	a,	r1
0152  CD                   15  	xch	a,	r5
0153  C9                   16  	xch	a,	r1
0154                       17  	; r2 <-> r6
0154  CA                   18  	xch	a,	r2
0155  CE                   19  	xch	a,	r6
0156  CA                   20  	xch	a,	r2
0157                       21  	; r3 <-> r7
0157  CB                   22  	xch	a,	r3
0158  CF                   23  	xch	a,	r7
0159  CB                   24  	xch	a,	r3
015A                       25  	; a remains unchanged
015A  22                   26  	ret
015B                       27  
