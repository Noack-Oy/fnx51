                         ; ==== ../read/hex.inc ====
00A9                        1  
00A9                        2  ; *** read/char.inc ***
00A9                        3  
00A9                        4  ; >> uint32 read_hex_32() <<
00A9                        5  
00A9                        6  ; Read 32 bit hex integer from input into r0-r3.
00A9                        7  ; Stops at the first non-hex character or integer overflow.
00A9                        8  
00A9                        9  read_hex_32:
00A9  C0 E0                10  	push	acc
00AB  C0 04                11  	push	4
00AD  C0 05                12  	push	5
00AF                       13  
00AF  E4                   14  	clr	a
00B0  F8                   15  	mov	r0,	a
00B1  F9                   16  	mov	r1,	a
00B2  FA                   17  	mov	r2,	a
00B3  FB                   18  	mov	r3,	a
00B4                       19  
00B4                       20  read_hex_32__loop:
00B4  11 A4                21  	acall	read_char
00B6                       22  
00B6  C3                   23  	clr	c
00B7  94 30                24  	subb	a,	#0x30	; ascii '0'
00B9  40 42                25  	jc	read_hex_32__end
00BB  B4 0A 00             26  	cjne	a,	#10,	read_hex_32__1
00BE                       27  read_hex_32__1:
00BE  40 0D                28  	jc	read_hex_32__3
00C0  94 11                29  	subb	a,	#17	; chars between '0' and 'A'
00C2  40 39                30  	jc	read_hex_32__end
00C4  24 0A                31  	add	a,	#10
00C6  54 DF                32  	anl	a,	#0xdf	; allow lowercase
00C8  B4 10 00             33  	cjne	a,	#0x10,	read_hex_32__2
00CB                       34  read_hex_32__2:
00CB  50 30                35  	jnc	read_hex_32__end
00CD                       36  
00CD                       37  read_hex_32__3:
00CD  FC                   38  	mov	r4,	a
00CE  E8                   39  	mov	a,	r0
00CF  C4                   40  	swap	a
00D0  FD                   41  	mov	r5,	a
00D1  54 F0                42  	anl	a,	#0xf0
00D3  4C                   43  	orl	a,	r4
00D4  F8                   44  	mov	r0,	a
00D5  ED                   45  	mov	a,	r5
00D6  54 0F                46  	anl	a,	#0x0f
00D8                       47  
00D8  FC                   48  	mov	r4,	a
00D9  E9                   49  	mov	a,	r1
00DA  C4                   50  	swap	a
00DB  FD                   51  	mov	r5,	a
00DC  54 F0                52  	anl	a,	#0xf0
00DE  4C                   53  	orl	a,	r4
00DF  F9                   54  	mov	r1,	a
00E0  ED                   55  	mov	a,	r5
00E1  54 0F                56  	anl	a,	#0x0f
00E3                       57  
00E3  FC                   58  	mov	r4,	a
00E4  EA                   59  	mov	a,	r2
00E5  C4                   60  	swap	a
00E6  FD                   61  	mov	r5,	a
00E7  54 F0                62  	anl	a,	#0xf0
00E9  4C                   63  	orl	a,	r4
00EA  FA                   64  	mov	r2,	a
00EB  ED                   65  	mov	a,	r5
00EC  54 0F                66  	anl	a,	#0x0f
00EE                       67  
00EE  FC                   68  	mov	r4,	a
00EF  EB                   69  	mov	a,	r3
00F0  C4                   70  	swap	a
00F1  FD                   71  	mov	r5,	a
00F2  54 F0                72  	anl	a,	#0xf0
00F4  4C                   73  	orl	a,	r4
00F5  FB                   74  	mov	r3,	a
00F6  ED                   75  	mov	a,	r5
00F7  54 0F                76  	anl	a,	#0x0f
00F9                       77  
00F9  70 02                78  	jnz	read_hex_32__end	; overflow
00FB  80 B7                79  	sjmp	read_hex_32__loop
00FD                       80  
00FD                       81  
00FD                       82  read_hex_32__end:
00FD  D0 05                83  	pop	5
00FF  D0 04                84  	pop	4
0101  D0 E0                85  	pop	acc
0103  22                   86  	ret
0104                       87  
