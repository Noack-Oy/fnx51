02A1                       36  	; rounding to next multiple of 4
02A1  E8                   37  	mov	a,r0
02A2  24 03                38  	add	a,#3
02A4  54 FC                39  	anl	a,#0xfc
02A6  F8                   40  	mov	r0,a
02A7  E9                   41  	mov	a,r1
02A8  34 00                42  	addc	a,#0
02AA  F9                   43  	mov	r1,a
02AB                       44  
02AB                       45  	; set prev (r2,r3) and curr (r4r5) pointers
02AB  AA 38                46  	mov	r2,memory_list
02AD  AB 39                47  	mov	r3,memory_list+1
02AF  8A 82                48  	mov	dpl,r2
02B1  8B 83                49  	mov	dph,r3
02B3  E0                   50  	movx	a,@dptr
02B4  FC                   51  	mov	r4,a
02B5  A3                   52  	inc	dptr
02B6  E0                   53  	movx	a,@dptr
02B7  FD                   54  	mov	r5,a
