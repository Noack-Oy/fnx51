02B8  EC                   57  	mov	a,r4
02B9  4D                   58  	orl	a,r5
02BA  70 03                59  	jnz	memory_allocate__0a
02BC  12 04 9C             60  	lcall	panic	; no large enough free block found
02BF                       61  memory_allocate__0a:
02BF                       62  	; compare curr->size with required size
02BF  8C 82                63  	mov	dpl,r4
02C1  8D 83                64  	mov	dph,r5
02C3  A3                   65  	inc	dptr
02C4  A3                   66  	inc	dptr	; dptr is now &(curr->size)
02C5  E0                   67  	movx	a,@dptr
02C6  FE                   68  	mov	r6,a	; store low byte for later (cannot easily dec dptr)
02C7  A3                   69  	inc	dptr	; compare high byte first
02C8  C3                   70  	clr	c
02C9  E0                   71  	movx	a,@dptr
02CA  99                   72  	subb	a,r1
