                         ; ==== ../print/text.inc ====
0109                        1  
0109                        2  ; *** print/text.inc ***
0109                        3  
0109                        4  ; >> void print_text(char* dptr) <<
0109                        5  
0109                        6  ; Print null-terminated string from program code.
0109                        7  ; Aborts if no null terminator is found after 256 bytes.
0109                        8  
0109                        9  print_text:
0109  C0 E0                10  	push	ACC
010B  C0 00                11  	push	0
010D                       12  
010D  E4                   13  	clr	a
010E  F8                   14  	mov	r0,	a
010F                       15  print_text__loop:
010F  93                   16  	movc	a,	@a+dptr
0110  60 06                17  	jz	print_text__end
0112  31 04                18  	acall	print_char
0114  08                   19  	inc	r0
0115  E8                   20  	mov	a,	r0
0116  70 F7                21  	jnz	print_text__loop
0118                       22  
0118                       23  print_text__end:
0118  D0 00                24  	pop	0
011A  D0 E0                25  	pop	ACC
011C  22                   26  	ret
011D                       27  
