035F                        1  
035F                        2  ; *** memory/release.inc ***
035F                        3  
035F                        4  ; >> void memory_release(char *{dptr} addr, uint16{r0r1} size) <<
035F                        5  
035F                        6  ; Release a previously allocated block. `addr` must be the pointer
035F                        7  ; returned by memory_allocate, `size` the same value passed to it.
035F                        8  
035F                        9  memory_release:
035F  C0 A8                10  	push	ie
0361  C2 AF                11  	clr	ea
0363                       12  
0363  C0 E0                13  	push	acc
0365  C0 82                14  	push	dpl
0367  C0 83                15  	push	dph
0369                       16  
0369                       17  	; void function: r0-r7 all preserved
0369  C0 00                18  	push	0
036B  C0 01                19  	push	1
036D  C0 02                20  	push	2
036F  C0 03                21  	push	3
0371  C0 04                22  	push	4
0373  C0 05                23  	push	5
0375  C0 06                24  	push	6
0377  C0 07                25  	push	7
0379                       26  
0379                       27  	; copy address from dptr into r2r3 for the body's use;
0379                       28  	; size stays in r0r1 (where the caller put it)
0379  AA 82                29  	mov	r2,dpl
037B  AB 83                30  	mov	r3,dph
037D                       31  
037D                       32  	; r0r1: size, r2r3: block addr;
037D                       33  	; r6r7 takes over the prev-pointer role during the list walk.
037D                       34  
037D                       35  	; input parameter check
037D  E8                   36  	mov	a,r0
037E  49                   37  	orl	a,r1
037F  70 03                38  	jnz	memory_release__1
0381  12 04 9C             39  	lcall	panic	; invalid size (0)
0384                       40  memory_release__1:
0384  EB                   41  	mov	a,r3
0385  B5 41 04             42  	cjne	a,memory_start+1,memory_release__2
0388  EA                   43  	mov	a,r2
0389  B5 40 00             44  	cjne	a,memory_start,memory_release__2
038C                       45  memory_release__2:
038C  50 03                46  	jnc	memory_release__3
038E  12 04 9C             47  	lcall	panic	; invalid address (< memory_start)
0391                       48  memory_release__3:
0391  EB                   49  	mov	a,r3
0392  B5 43 04             50  	cjne	a,memory_end+1,memory_release__4
0395  EA                   51  	mov	a,r2
0396  B5 42 00             52  	cjne	a,memory_end,memory_release__4
0399                       53  memory_release__4:
0399  40 03                54  	jc	memory_release__5
039B  12 04 9C             55  	lcall	panic	; invalid address (>= memory_end)
039E                       56  memory_release__5:
039E                       57  
039E                       58  	; rounding
039E  E8                   59  	mov	a,r0
039F  24 03                60  	add	a,#3
03A1  54 FC                61  	anl	a,#0xfc
03A3  F8                   62  	mov	r0,a
03A4  E9                   63  	mov	a,r1
03A5  34 00                64  	addc	a,#0
03A7  F9                   65  	mov	r1,a
03A8                       66  
03A8                       67  	; find position in list
03A8                       68  	; r6r7: prev pointer
