012A: D4                   da      a
012B: 44 20                orl     a,      #0x20   ; lower case
012D: 31 04                acall   print_char
012F: D0 E0                pop     ACC
0131: 22                   ret
                   
                   ; >> void print_hex_16(int r0r1) <<
                   
                   ; Print hexadecimal number from r0-r1.
                   
                   print_hex_16:
0132: C0 E0                push    ACC
0134: E9                   mov     a,      r1      ; MSB first
0135: 31 1D                acall   print_hex_8
0137: E8                   mov     a,      r0      ; LSB second
0138: 31 1D                acall   print_hex_8
013A: D0 E0                pop     ACC
013C: 22                   ret
                   
                   ; >> void print_hex_32(long r0r1r2r3) <<
                   
                   ; Print hexadecimal number from r0-r3.
                   
                   print_hex_32:
013D: C0 E0                push    ACC
013F: EB                   mov     a,      r3      ; MSB first
0140: 31 1D                acall   print_hex_8
0142: EA                   mov     a,      r2
0143: 31 1D                acall   print_hex_8
0145: E9                   mov     a,      r1
0146: 31 1D                acall   print_hex_8
