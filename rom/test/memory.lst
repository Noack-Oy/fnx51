00CA: 54 DF                anl     a,      #0xdf   ; allow lowercase
00CC: B4 10 00             cjne    a,      #0x10,  read_hex_32__2
                   read_hex_32__2:
00CF: 50 30                jnc     read_hex_32__end
                   
                   read_hex_32__3:
00D1: FC                   mov     r4,     a
00D2: E8                   mov     a,      r0
00D3: C4                   swap    a
00D4: FD                   mov     r5,     a
00D5: 54 F0                anl     a,      #0xf0
00D7: 4C                   orl     a,      r4
00D8: F8                   mov     r0,     a
00D9: ED                   mov     a,      r5
00DA: 54 0F                anl     a,      #0x0f
                   
00DC: FC                   mov     r4,     a
00DD: E9                   mov     a,      r1
00DE: C4                   swap    a
00DF: FD                   mov     r5,     a
00E0: 54 F0                anl     a,      #0xf0
00E2: 4C                   orl     a,      r4
00E3: F9                   mov     r1,     a
00E4: ED                   mov     a,      r5
00E5: 54 0F                anl     a,      #0x0f
                   
00E7: FC                   mov     r4,     a
00E8: EA                   mov     a,      r2
00E9: C4                   swap    a
00EA: FD                   mov     r5,     a
00EB: 54 F0                anl     a,      #0xf0
00ED: 4C                   orl     a,      r4
00EE: FA                   mov     r2,     a
00EF: ED                   mov     a,      r5
00F0: 54 0F                anl     a,      #0x0f
                   
