                         ; ==== ../print/hex.inc ====
0065                        1  
0065                        2  ; *** print/hex.inc ***
0065                        3  
0065                        4  ; >> void print_hex_8(char a) <<
0065                        5  
0065                        6  ; Print hexadecimal number from accumulator.
0065                        7  
0065                        8  print_hex_8:
0065  C4                    9  	swap	a	; high nibble first
0066  11 69                10  	acall	print_hex_8__nibble
0068  C4                   11  	swap	a
0069                       12  print_hex_8__nibble:
0069  C0 E0                13  	push	ACC
006B  54 0F                14  	anl	a,	#0x0f
006D  24 90                15  	add	a,	#0x90
006F  D4                   16  	da	a
0070  34 40                17  	addc	a,	#0x40
0072  D4                   18  	da	a
0073  44 20                19  	orl	a,	#0x20	; lower case
0075  11 60                20  	acall	print_char
0077  D0 E0                21  	pop	ACC
0079  22                   22  	ret
007A                       23  
007A                       24  ; >> void print_hex_16(int r0r1) <<
007A                       25  
007A                       26  ; Print hexadecimal number from r0-r1.
007A                       27  
007A                       28  print_hex_16:
007A  C0 E0                29  	push	ACC
007C  E9                   30  	mov	a,	r1	; MSB first
007D  11 65                31  	acall	print_hex_8
007F  E8                   32  	mov	a,	r0	; LSB second
0080  11 65                33  	acall	print_hex_8
0082  D0 E0                34  	pop	ACC
0084  22                   35  	ret
0085                       36  
0085                       37  ; >> void print_hex_32(long r0r1r2r3) <<
0085                       38  
0085                       39  ; Print hexadecimal number from r0-r3.
0085                       40  
0085                       41  print_hex_32:
0085  C0 E0                42  	push	ACC
0087  EB                   43  	mov	a,	r3	; MSB first
0088  11 65                44  	acall	print_hex_8
008A  EA                   45  	mov	a,	r2
008B  11 65                46  	acall	print_hex_8
008D  E9                   47  	mov	a,	r1
008E  11 65                48  	acall	print_hex_8
0090  E8                   49  	mov	a,	r0	; LSB last
0091  11 65                50  	acall	print_hex_8
0093  D0 E0                51  	pop	ACC
0095  22                   52  	ret
