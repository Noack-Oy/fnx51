014F                        1  
014F                        2  ; *** util/xch.inc ***
014F                        3  
014F                        4  ; >> void xch_r0123_r4567(uint32 &r0r1r2r3, uint32 &r4r5r6r7) <<
014F                        5  
014F                        6  ; Exchange registers r0-r3 with r4-r7.
014F                        7  
014F                        8  xch_r0123_r4567:
014F                        9  	; r0 <-> r4
014F  C8                   10  	xch	a,	r0
0150  CC                   11  	xch	a,	r4
0151  C8                   12  	xch	a,	r0
0152                       13  	; r1 <-> r5
0152  C9                   14  	xch	a,	r1
0153  CD                   15  	xch	a,	r5
0154  C9                   16  	xch	a,	r1
0155                       17  	; r2 <-> r6
0155  CA                   18  	xch	a,	r2
0156  CE                   19  	xch	a,	r6
0157  CA                   20  	xch	a,	r2
0158                       21  	; r3 <-> r7
0158  CB                   22  	xch	a,	r3
0159  CF                   23  	xch	a,	r7
015A  CB                   24  	xch	a,	r3
015B                       25  	; a remains unchanged
015B  22                   26  	ret
015C                       27  
