0060                        4  ; >> void print_char(char a) <<
0060                        5  
0060                        6  ; Print char from accumulator.
0060                        7  ; Indirect call to function behind OUT pointer.
0060                        8  
0060                        9  print_char:
0060  C0 32                10  	push	OUT
0062  C0 33                11  	push	OUT+1
0064  22                   12  	ret
