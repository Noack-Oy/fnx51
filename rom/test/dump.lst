                         ; ==== ../serial/init.inc ====
0034                        1  
0034                        2  ; *** serial/init.inc ***
0034                        3  
0034                        4  ; >> void serial_init() <<
0034                        5  
0034                        6  ; Initialize serial interface.
0034                        7  ; - assumes 20MHz clock and X2 mode
0034                        8  ; - uses internal baud rate generator
0034                        9  ; - speed: 9600 bits per second
0034                       10  ; Formula: BRL = 256 - (F_clk / (32 * Baud_Rate))
0034                       11  ; ---
0034                       12  ; See datasheet page 52 for details,
0034                       13  ; also note oscillator diagram on page 16!
0034                       14  
0034                       15  serial_init:
0034  75 98 52             16  	mov	SCON,	#0x52	; SM1, REN, TI
0037  75 9A BF             17  	mov	BRL,	#191	; 9600 @20MHz CLK
003A  75 9B 1E             18  	mov	BDRCON, #0x1e	; BRR, RBCK, TBCK, SPD
003D                       19  
003D  90 00 50             20  	mov	dptr,	#serial_rx
0040  85 82 30             21  	mov	IN,	DPL
0043  85 83 31             22  	mov	IN+1,	DPH
0046                       23  
0046  90 00 58             24  	mov	dptr,	#serial_tx
0049  85 82 32             25  	mov	OUT,	DPL
004C  85 83 33             26  	mov	OUT+1,	DPH
004F                       27  
004F  22                   28  	ret
0050                       29  
                         ; ==== dump.asm ====
0050                       49  .include ../serial/rx.inc
                         ; ==== ../serial/rx.inc ====
0050                        1  
0050                        2  ; *** serial/rx.inc ***
0050                        3  
0050                        4  ; >> char serial_rx <<
0050                        5  
0050                        6  ; Receive byte into accumulator.
0050                        7  
0050                        8  serial_rx:
0050  30 98 FD              9  	jnb	RI,	serial_rx
0053  C2 98                10  	clr	RI
0055  E5 99                11  	mov	a,	SBUF
0057  22                   12  	ret
0058                       13  
                         ; ==== dump.asm ====
