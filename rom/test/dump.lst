0058                        3  
0058                        4  ; >> void serial_tx(char a) <<
0058                        5  
0058                        6  ; Transmit byte from accumulator.
0058                        7  
0058                        8  serial_tx:
0058  30 99 FD              9  	jnb	TI,	serial_tx
005B  C2 99                10  	clr	TI
005D  F5 99                11  	mov	SBUF,	a
005F  22                   12  	ret
