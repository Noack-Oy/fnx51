009B                        1  
009B                        2  ; *** util/dump.inc ***
009B                        3  
009B                        4  ; >> uint32{r0-r3} dump(uint32{r0-r3} addr, uint8{a} count) <<
009B                        5  
009B                        6  ; Print hexdump from standard input to standard output.
009B                        7  ; Starting value for address column in r0-r3.
009B                        8  ; Number of bytes to print in a (0 means 256).
009B                        9  ; r0-r3 contains next address upon exit.
009B                       10  
009B                       11  dump:
009B  C0 F0                12  	push	b
009D  C0 E0                13  	push	acc
009F  F5 F0                14  	mov	b,	a
00A1  C0 04                15  	push	4
00A3  C0 05                16  	push	5
00A5  C0 06                17  	push	6
00A7  C0 07                18  	push	7
00A9                       19  
00A9                       20  	; b: total bytes remaining
00A9                       21  	; r0: buffer pointer
00A9                       22  	; r1: read loop counter / padding size
00A9                       23  	; r2: print loop counter
00A9                       24  
00A9                       25  	; r4-7: address label
00A9  31 4F                26  	acall	xch_r0123_r4567
00AB                       27  
00AB                       28  	; allocate 16 byte array on stack
00AB  E5 81                29  	mov	a,	sp
00AD  F8                   30  	mov	r0,	a
00AE  24 10                31  	add	a,	#16
00B0  F5 81                32  	mov	sp,	a
00B2                       33  
00B2                       34  dump__line_loop:
00B2                       35  	; read into buffer
00B2  79 10                36  	mov	r1,	#16
00B4                       37  dump__read_loop:
00B4  11 96                38  	acall	read_char
00B6  08                   39  	inc	r0
00B7  F6                   40  	mov	@r0,	a
00B8  D5 F0 03             41  	djnz	b,	dump__read_continue
00BB  19                   42  	dec	r1
00BC  80 02                43  	sjmp	dump__read_end
00BE                       44  dump__read_continue:
00BE  D9 F4                45  	djnz	r1,	dump__read_loop
00C0                       46  dump__read_end:
00C0                       47  
00C0                       48  	; print address column
00C0  31 4F                49  	acall	xch_r0123_r4567
00C2  11 85                50  	acall	print_hex_32
00C4  31 4F                51  	acall	xch_r0123_r4567
00C6  74 3A                52  	mov	a,	#':'
00C8  11 60                53  	acall	print_char
00CA                       54  
00CA                       55  	; if r1 is nonzero here, we have a shorter line
00CA                       56  	; the value in r1 is the number of padding bytes
00CA                       57  
00CA                       58  	; wind back pointer
00CA  E8                   59  	mov	a,	r0
00CB  24 F0                60  	add	a,	#-16
00CD  29                   61  	add	a,	r1
00CE  F8                   62  	mov	r0,	a
00CF                       63  
00CF                       64  	; print hex
00CF  7A 10                65  	mov	r2,	#16
00D1                       66  dump__print_hex_loop:
00D1  08                   67  	inc	r0
00D2  EA                   68  	mov	a,	r2
00D3  54 03                69  	anl	a,	#3	; mod 4
00D5  70 04                70  	jnz	dump__print_hex_no_gap
00D7  74 20                71  	mov	a,	#' ' ; gap after every 4 bytes
00D9  11 60                72  	acall	print_char
00DB                       73  dump__print_hex_no_gap:
00DB  EA                   74  	mov	a,	r2
00DC  D3                   75  	setb	c
00DD  99                   76  	subb	a,	r1
00DE  50 08                77  	jnc	dump__print_hex_no_padding
00E0  74 20                78  	mov	a,	#' ' ; padding for shorter line
00E2  11 60                79  	acall	print_char
00E4  11 60                80  	acall	print_char
00E6  80 03                81  	sjmp	dump__print_hex_next
00E8                       82  dump__print_hex_no_padding:
00E8  E6                   83  	mov	a,	@r0
00E9  11 65                84  	acall	print_hex_8
00EB                       85  dump__print_hex_next:
00EB  74 20                86  	mov	a,	#' ' ; space between bytes
00ED  11 60                87  	acall	print_char
00EF  DA E0                88  	djnz	r2,	dump__print_hex_loop
00F1                       89  
00F1                       90  	; wind back again
00F1  E8                   91  	mov	a,	r0
00F2  24 F0                92  	add	a,	#-16
00F4  F8                   93  	mov	r0,	a
00F5                       94  
00F5                       95  	; print ascii
00F5  74 20                96  	mov	a,	#' '
00F7  11 60                97  	acall	print_char
00F9  74 7C                98  	mov	a,	#'|'
00FB  11 60                99  	acall	print_char
00FD  74 10               100  	mov	a,	#16
00FF  C3                  101  	clr	c
0100  99                  102  	subb	a,	r1
0101  F9                  103  	mov	r1,	a ; number of bytes to print
0102  FA                  104  	mov	r2,	a
0103                      105  dump__print_ascii_loop:
0103  08                  106  	inc	r0
0104  E6                  107  	mov	a,	@r0
0105  B4 20 00            108  	cjne	a,	#0x20,	dump__print_ascii_check1
0108                      109  dump__print_ascii_check1:
0108  40 05               110  	jc	dump__print_ascii_replace
010A  B4 7F 00            111  	cjne	a,	#0x7f,	dump__print_ascii_check2
010D                      112  dump__print_ascii_check2:
010D  40 02               113  	jc	dump__print_ascii_continue
010F                      114  dump__print_ascii_replace:
010F  74 2E               115  	mov	a,	#'.'
0111                      116  dump__print_ascii_continue:
0111  11 60               117  	acall	print_char
0113  DA EE               118  	djnz	r2,	dump__print_ascii_loop
0115  74 7C               119  	mov	a,	#'|'
0117  11 60               120  	acall	print_char
0119  74 0D               121  	mov	a,	#13
011B  11 60               122  	acall	print_char
011D  74 0A               123  	mov	a,	#10
011F  11 60               124  	acall	print_char
0121                      125  
0121                      126  	; wind back again
0121  E8                  127  	mov	a,	r0
0122  24 F0               128  	add	a,	#-16
0124  F8                  129  	mov	r0,	a
0125                      130  
0125                      131  	; next address
0125  EC                  132  	mov	a,	r4
0126  29                  133  	add	a,	r1
0127  FC                  134  	mov	r4,	a
0128  ED                  135  	mov	a,	r5
0129  34 00               136  	addc	a,	#0
012B  FD                  137  	mov	r5,	a
012C  EE                  138  	mov	a,	r6
012D  34 00               139  	addc	a,	#0
012F  FE                  140  	mov	r6,	a
0130  EF                  141  	mov	a,	r7
0131  34 00               142  	addc	a,	#0
0133  FF                  143  	mov	r7,	a
0134                      144  
0134  E5 F0               145  	mov	a,	b
0136  60 02               146  	jz	dump__end
0138  01 B2               147  	ajmp	dump__line_loop
013A                      148  
013A                      149  dump__end:
013A                      150  	; deallocate array from stack
013A  E5 81               151  	mov	a,	sp
013C  24 F0               152  	add	a,	#-16
013E  F5 81               153  	mov	sp,	a
0140                      154  
0140  31 4F               155  	acall	xch_r0123_r4567
0142                      156  
0142  D0 07               157  	pop	7
0144  D0 06               158  	pop	6
0146  D0 05               159  	pop	5
0148  D0 04               160  	pop	4
014A  D0 E0               161  	pop	acc
014C  D0 F0               162  	pop	b
014E  22                  163  	ret
014F                      164  
