0208                        1  
0208                        2  ; *** print/int.inc ***
0208                        3  
0208                        4  ; >> void print_int_s8(char a) <<
0208                        5  
0208                        6  ; Print signed integer from accumulator.
0208                        7  
0208                        8  print_int_s8:
0208  C0 E0                 9  	push	ACC
020A  C0 F0                10  	push	B
020C  C0 00                11  	push	0
020E  30 E7 10             12  	jnb	ACC.7,	print_int_u8__1
0211  F8                   13  	mov	r0,	a	; save a in r0 (just pushed) while we print '-'
0212  74 2D                14  	mov	a,	#'-'
0214  31 BE                15  	acall	print_char
0216  E8                   16  	mov	a,	r0
0217  F4                   17  	cpl	a
0218  04                   18  	inc	a
0219  80 06                19  	sjmp	print_int_u8__1
021B                       20  
021B                       21  ; >> void print_int_u8(char a) <<
021B                       22  
021B                       23  ; Print unsingned integer from accumulator.
021B                       24  
021B                       25  print_int_u8:
021B  C0 E0                26  	push	ACC
021D  C0 F0                27  	push	B
021F  C0 00                28  	push	0
0221                       29  print_int_u8__1:
0221  78 00                30  	mov	r0,	#0
0223  75 F0 64             31  	mov	b,	#100
0226  84                   32  	div	ab
0227  60 05                33  	jz	print_int_u8__tens
0229  24 30                34  	add	a,	#'0'
022B  31 BE                35  	acall	print_char
022D  08                   36  	inc	r0	; stop skipping leading zeroes
022E                       37  print_int_u8__tens:
022E  E5 F0                38  	mov	a,	b
0230  75 F0 0A             39  	mov	b,	#10
0233  84                   40  	div	ab
0234  28                   41  	add	a,	r0
0235  60 05                42  	jz	print_int_u8__ones
0237  98                   43  	subb	a,	r0
0238  24 30                44  	add	a,	#'0'
023A  31 BE                45  	acall	print_char
023C                       46  print_int_u8__ones:
023C  E5 F0                47  	mov	a,	b
023E  24 30                48  	add	a,	#'0'
0240  31 BE                49  	acall	print_char
0242                       50  
0242  D0 00                51  	pop	0
0244  D0 F0                52  	pop	B
0246  D0 E0                53  	pop	ACC
0248  22                   54  	ret
0249                       55  
0249                       56  ; >> void print_int_s16(int r0r1) <<
0249                       57  
0249                       58  ; Print signed integer from r0-r1.
0249                       59  
0249                       60  print_int_s16:
0249  C0 E0                61  	push	ACC
024B  C0 00                62  	push	0
024D  C0 01                63  	push	1
024F  E9                   64  	mov	a,	r1
0250  30 E7 16             65  	jnb	ACC.7,	print_int_u16__1
0253  74 2D                66  	mov	a,	#'-'
0255  31 BE                67  	acall	print_char
0257  E8                   68  	mov	a,	r0
0258  F4                   69  	cpl	a
0259  24 01                70  	add	a,	#1
025B  F8                   71  	mov	r0,	a
025C  E9                   72  	mov	a,	r1
025D  F4                   73  	cpl	a
025E  34 00                74  	addc	a,	#0
0260  F9                   75  	mov	r1,	a
0261  80 06                76  	sjmp	print_int_u16__1
0263                       77  
0263                       78  ; >> void print_int_u16(int r0r1) <<
0263                       79  
0263                       80  ; Print unsigned integer from r0-r1.
0263                       81  
0263                       82  print_int_u16:
0263  C0 E0                83  	push	ACC
0265  C0 00                84  	push	0
0267  C0 01                85  	push	1
0269                       86  print_int_u16__1:
0269  C0 02                87  	push	2
026B  C0 F0                88  	push	B
026D                       89  
026D  7A 00                90  	mov	r2,	#0 ; flag for leading zeroes
026F                       91  
026F                       92  	; divide by 10000 (0x2710)
026F                       93  	; collect quotient in b
026F  75 F0 FF             94  	mov	b,	#-1
0272  C3                   95  	clr	c
0273                       96  print_int_u16__10k_loop:
0273  E8                   97  	mov	a,	r0
0274  94 10                98  	subb	a,	#0x10
0276  F8                   99  	mov	r0,	a
0277  E9                  100  	mov	a,	r1
0278  94 27               101  	subb	a,	#0x27
027A  F9                  102  	mov	r1,	a
027B  05 F0               103  	inc	b
027D  50 F4               104  	jnc	print_int_u16__10k_loop
027F                      105  	; undo last subtraction to restore remainder
027F  E8                  106  	mov	a,	r0
0280  24 10               107  	add	a,	#0x10
0282  F8                  108  	mov	r0,	a
0283  E9                  109  	mov	a,	r1
0284  34 27               110  	addc	a,	#0x27
0286  F9                  111  	mov	r1,	a
0287                      112  	; print tenthousands digit
0287  E5 F0               113  	mov	a,	b
0289  60 05               114  	jz	print_int_u16__1k
028B  24 30               115  	add	a,	#'0'
028D  31 BE               116  	acall	print_char
028F  0A                  117  	inc	r2
0290                      118  print_int_u16__1k:
0290                      119  	; divide by 1000 (0x03e8)
0290                      120  	; collect quotient in b
0290  75 F0 FF            121  	mov	b,	#-1
0293  C3                  122  	clr	c
0294                      123  print_int_u16__1k_loop:
0294  E8                  124  	mov	a,	r0
0295  94 E8               125  	subb	a,	#0xe8
0297  F8                  126  	mov	r0,	a
0298  E9                  127  	mov	a,	r1
0299  94 03               128  	subb	a,	#0x03
029B  F9                  129  	mov	r1,	a
029C  05 F0               130  	inc	b
029E  50 F4               131  	jnc	print_int_u16__1k_loop
02A0                      132  	; undo last subtraction to restore remainder
02A0  E8                  133  	mov	a,	r0
02A1  24 E8               134  	add	a,	#0xe8
02A3  F8                  135  	mov	r0,	a
02A4  E9                  136  	mov	a,	r1
02A5  34 03               137  	addc	a,	#0x03
02A7  F9                  138  	mov	r1,	a
02A8                      139  	; print thousands digit
02A8  E5 F0               140  	mov	a,	b
02AA  2A                  141  	add	a,	r2
02AB  60 06               142  	jz	print_int_u16__100
02AD  9A                  143  	subb	a,	r2
02AE  24 30               144  	add	a,	#'0'
02B0  31 BE               145  	acall	print_char
02B2  0A                  146  	inc	r2
02B3                      147  print_int_u16__100:
02B3                      148  	; divide by 100 (0x0064)
02B3                      149  	; collect quotient in b
02B3  75 F0 FF            150  	mov	b,	#-1
02B6  C3                  151  	clr	c
02B7                      152  print_int_u16__100_loop:
02B7  E8                  153  	mov	a,	r0
02B8  94 64               154  	subb	a,	#0x64
02BA  F8                  155  	mov	r0,	a
02BB  E9                  156  	mov	a,	r1
02BC  94 00               157  	subb	a,	#0x00
02BE  F9                  158  	mov	r1,	a
02BF  05 F0               159  	inc	b
02C1  50 F4               160  	jnc	print_int_u16__100_loop
02C3                      161  	; undo last subtraction to restore remainder
02C3  E8                  162  	mov	a,	r0
02C4  24 64               163  	add	a,	#0x64
02C6  F8                  164  	mov	r0,	a
02C7  E9                  165  	mov	a,	r1
02C8  34 00               166  	addc	a,	#0x00
02CA  F9                  167  	mov	r1,	a
02CB                      168  	; print hundreds digit
02CB  E5 F0               169  	mov	a,	b
02CD  2A                  170  	add	a,	r2
02CE  60 06               171  	jz	print_int_u16__tens
02D0  9A                  172  	subb	a,	r2
02D1  24 30               173  	add	a,	#'0'
02D3  31 BE               174  	acall	print_char
02D5  0A                  175  	inc	r2
02D6                      176  print_int_u16__tens:
02D6                      177  	; divide by 10 (using div instruction)
02D6  E8                  178  	mov	a,	r0
02D7  75 F0 0A            179  	mov	b,	#10
02DA  84                  180  	div	ab
02DB                      181  	; print tens digit
02DB  2A                  182  	add	a,	r2
02DC  60 05               183  	jz	print_int_u16__ones
02DE  9A                  184  	subb	a,	r2
02DF  24 30               185  	add	a,	#'0'
02E1  31 BE               186  	acall	print_char
02E3                      187  print_int_u16__ones:
02E3                      188  	; print ones digit
02E3  E5 F0               189  	mov	a,	b
02E5  24 30               190  	add	a,	#'0'
02E7  31 BE               191  	acall	print_char
02E9                      192  
02E9  D0 F0               193  	pop	B
02EB  D0 02               194  	pop	2
02ED  D0 01               195  	pop	1
02EF  D0 00               196  	pop	0
02F1  D0 E0               197  	pop	ACC
02F3  22                  198  	ret
02F4                      199  
02F4                      200  ; >> void print_int_s32(long r0r1r2r3) <<
02F4                      201  
02F4                      202  ; Print signed integer from r0-r3.
02F4                      203  
02F4                      204  print_int_s32:
02F4  C0 E0               205  	push	acc
02F6  C0 F0               206  	push	b
02F8  C0 82               207  	push	dpl
02FA  C0 83               208  	push	dph
02FC  C0 00               209  	push	0
02FE  C0 01               210  	push	1
0300  C0 02               211  	push	2
0302  C0 03               212  	push	3
0304  C0 04               213  	push	4
0306  C0 05               214  	push	5
0308  C0 06               215  	push	6
030A  C0 07               216  	push	7
030C                      217  	; check sign bit (high byte of value is in r3)
030C  EB                  218  	mov	a,r3
030D  30 E7 32            219  	jnb	ACC.7,	print_int_u32__1
0310  74 2D               220  	mov	a,#'-'
0312  31 BE               221  	acall	print_char
0314                      222  	; negate r0-r3
0314  E8                  223  	mov	a,r0
0315  F4                  224  	cpl	a
0316  24 01               225  	add	a,#1
0318  F8                  226  	mov	r0,a
0319  E9                  227  	mov	a,r1
031A  F4                  228  	cpl	a
031B  34 00               229  	addc	a,#0
031D  F9                  230  	mov	r1,a
031E  EA                  231  	mov	a,r2
031F  F4                  232  	cpl	a
0320  34 00               233  	addc	a,#0
0322  FA                  234  	mov	r2,a
0323  EB                  235  	mov	a,r3
0324  F4                  236  	cpl	a
0325  34 00               237  	addc	a,#0
0327  FB                  238  	mov	r3,a
0328  80 18               239  	sjmp	print_int_u32__1
032A                      240  
032A                      241  
032A                      242  ; >> void print_int_u32(long r0r1r2r3) <<
032A                      243  
032A                      244  ; Print unsigned integer from r0-r3.
032A                      245  
032A                      246  print_int_u32:
032A  C0 E0               247  	push	acc
032C  C0 F0               248  	push	b
032E  C0 82               249  	push	dpl
0330  C0 83               250  	push	dph
0332  C0 00               251  	push	0
0334  C0 01               252  	push	1
0336  C0 02               253  	push	2
0338  C0 03               254  	push	3
033A  C0 04               255  	push	4
033C  C0 05               256  	push	5
033E  C0 06               257  	push	6
0340  C0 07               258  	push	7
0342                      259  print_int_u32__1:
0342                      260  	; value to print stays in r0-r3 throughout;
0342                      261  	; each digit's divisor is loaded into r4-r7.
0342  75 F0 00            262  	mov	b,#0 ; flag for leading zeroes
0345  90 03 87            263  	mov	dptr,#print_int_u32__divisors
0348                      264  print_int_u32__loop:
0348                      265  	; load divisor into r4-r7
0348  E4                  266  	clr	a
0349  93                  267  	movc	a,@a+dptr
034A  FC                  268  	mov	r4,a
034B  A3                  269  	inc	dptr
034C  E4                  270  	clr	a
034D  93                  271  	movc	a,@a+dptr
034E  FD                  272  	mov	r5,a
034F  A3                  273  	inc	dptr
0350  E4                  274  	clr	a
0351  93                  275  	movc	a,@a+dptr
0352  FE                  276  	mov	r6,a
0353  A3                  277  	inc	dptr
0354  E4                  278  	clr	a
0355  93                  279  	movc	a,@a+dptr
0356  FF                  280  	mov	r7,a
0357  A3                  281  	inc	dptr
0358                      282  	; divide r0-r3 by r4-r7 (quotient in a, remainder in r0-r3)
0358  71 AB               283  	acall	print_int_u32__divide
035A  25 F0               284  	add	a,b
035C  60 08               285  	jz	print_int_u32__skip ; leading zero
035E  95 F0               286  	subb	a,b
0360  24 30               287  	add	a,#'0'
0362  05 F0               288  	inc	b
0364  31 BE               289  	acall	print_char
0366                      290  print_int_u32__skip:
0366  BC 0A DF            291  	cjne	r4,#0x0a,	print_int_u32__loop
0369  E8                  292  	mov	a,r0
036A  24 30               293  	add	a,#'0'
036C  31 BE               294  	acall	print_char
036E                      295  
036E  D0 07               296  	pop	7
0370  D0 06               297  	pop	6
0372  D0 05               298  	pop	5
0374  D0 04               299  	pop	4
0376  D0 03               300  	pop	3
0378  D0 02               301  	pop	2
037A  D0 01               302  	pop	1
037C  D0 00               303  	pop	0
037E  D0 83               304  	pop	dph
0380  D0 82               305  	pop	dpl
0382  D0 F0               306  	pop	b
0384  D0 E0               307  	pop	acc
0386  22                  308  	ret
0387                      309  ; Divisor table:
0387                      310  print_int_u32__divisors:
0387                      311  	; 1,000,000,000 = 3b9aca00
0387  00 CA 9A 3B         312  	.db	0x00, 0xca, 0x9a, 0x3b
038B                      313  	;   100,000,000 = 05f5e100
038B  00 E1 F5 05         314  	.db	0x00, 0xe1, 0xf5, 0x05
038F                      315  	;    10,000,000 = 00989680
038F  80 96 98 00         316  	.db	0x80, 0x96, 0x98, 0x00
0393                      317  	;     1,000,000 = 000f4240
0393  40 42 0F 00         318  	.db	0x40, 0x42, 0x0f, 0x00
0397                      319  	;       100,000 = 000186a0
0397  A0 86 01 00         320  	.db	0xa0, 0x86, 0x01, 0x00
039B                      321  	;        10,000 = 00002710
039B  10 27 00 00         322  	.db	0x10, 0x27, 0x00, 0x00
039F                      323  	;         1,000 = 000003e8
039F  E8 03 00 00         324  	.db	0xe8, 0x03, 0x00, 0x00
03A3                      325  	;           100 = 00000064
03A3  64 00 00 00         326  	.db	0x64, 0x00, 0x00, 0x00
03A7                      327  	;            10 = 0000000a
03A7  0A 00 00 00         328  	.db	0x0a, 0x00, 0x00, 0x00
03AB                      329  ; Divide r0-r3 by r4-r7 using repeated subtraction.
03AB                      330  ; Quotient returned in a, remainder in r0-r3.
03AB                      331  ; Since the quotient is at most 9,
03AB                      332  ; this is faster than 'proper' division.
03AB                      333  print_int_u32__divide:
03AB  C0 F0               334  	push	b
03AD  C3                  335  	clr	c
03AE  75 F0 FF            336  	mov	b,#-1
03B1                      337  print_int_u32__divide_loop:
03B1  E8                  338  	mov	a,r0
03B2  9C                  339  	subb	a,r4
03B3  F8                  340  	mov	r0,a
03B4  E9                  341  	mov	a,r1
03B5  9D                  342  	subb	a,r5
03B6  F9                  343  	mov	r1,a
03B7  EA                  344  	mov	a,r2
03B8  9E                  345  	subb	a,r6
03B9  FA                  346  	mov	r2,a
03BA  EB                  347  	mov	a,r3
03BB  9F                  348  	subb	a,r7
03BC  FB                  349  	mov	r3,a
03BD  05 F0               350  	inc	b
03BF  50 F0               351  	jnc	print_int_u32__divide_loop
03C1                      352  	; restore remainder
03C1  E8                  353  	mov	a,r0
03C2  2C                  354  	add	a,r4
03C3  F8                  355  	mov	r0,a
03C4  E9                  356  	mov	a,r1
03C5  3D                  357  	addc	a,r5
03C6  F9                  358  	mov	r1,a
03C7  EA                  359  	mov	a,r2
03C8  3E                  360  	addc	a,r6
03C9  FA                  361  	mov	r2,a
03CA  EB                  362  	mov	a,r3
03CB  3F                  363  	addc	a,r7
03CC  FB                  364  	mov	r3,a
03CD  E5 F0               365  	mov	a,b
03CF  D0 F0               366  	pop	b
03D1  22                  367  	ret
03D2                      368  
