                         ; ==== ../serial/tx.inc ====
01B6                        1  
01B6                        2  ; *** serial/tx.inc ***
01B6                        3  
01B6                        4  ; >> void serial_tx(char a) <<
01B6                        5  
01B6                        6  ; Transmit byte from accumulator.
01B6                        7  
01B6                        8  serial_tx:
01B6  30 99 FD              9  	jnb	TI,	serial_tx
01B9  C2 99                10  	clr	TI
01BB  F5 99                11  	mov	SBUF,	a
01BD  22                   12  	ret
01BE                       13  
