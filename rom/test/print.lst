                         ; ==== ../serial/init.inc ====
0192                        1  
0192                        2  ; *** serial/init.inc ***
0192                        3  
0192                        4  ; >> void serial_init() <<
0192                        5  
0192                        6  ; Initialize serial interface.
0192                        7  ; - assumes 20MHz clock and X2 mode
0192                        8  ; - uses internal baud rate generator
0192                        9  ; - speed: 9600 bits per second
0192                       10  ; Formula: BRL = 256 - (F_clk / (32 * Baud_Rate))
0192                       11  ; ---
0192                       12  ; See datasheet page 52 for details,
0192                       13  ; also note oscillator diagram on page 16!
0192                       14  
0192                       15  serial_init:
0192  75 98 52             16  	mov	SCON,	#0x52	; SM1, REN, TI
0195  75 9A BF             17  	mov	BRL,	#191	; 9600 @20MHz CLK
0198  75 9B 1E             18  	mov	BDRCON, #0x1e	; BRR, RBCK, TBCK, SPD
019B                       19  
019B  90 01 AE             20  	mov	dptr,	#serial_rx
019E  85 82 30             21  	mov	IN,	DPL
01A1  85 83 31             22  	mov	IN+1,	DPH
01A4                       23  
01A4  90 01 B6             24  	mov	dptr,	#serial_tx
01A7  85 82 32             25  	mov	OUT,	DPL
01AA  85 83 33             26  	mov	OUT+1,	DPH
01AD                       27  
01AD  22                   28  	ret
01AE                       29  
                         ; ==== print.asm ====
01AE                      308  .include ../serial/rx.inc
                         ; ==== ../serial/rx.inc ====
01AE                        1  
01AE                        2  ; *** serial/rx.inc ***
01AE                        3  
01AE                        4  ; >> char serial_rx <<
01AE                        5  
01AE                        6  ; Receive byte into accumulator.
01AE                        7  
01AE                        8  serial_rx:
01AE  30 98 FD              9  	jnb	RI,	serial_rx
01B1  C2 98                10  	clr	RI
01B3  E5 99                11  	mov	a,	SBUF
01B5  22                   12  	ret
01B6                       13  
                         ; ==== print.asm ====
