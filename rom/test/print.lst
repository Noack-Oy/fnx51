01E6: D4                   da      a
01E7: 44 20                orl     a,      #0x20   ; lower case
01E9: 31 BE                acall   print_char
01EB: D0 E0                pop     ACC
01ED: 22                   ret
                   
                   ; >> void print_hex_16(int r0r1) <<
                   
