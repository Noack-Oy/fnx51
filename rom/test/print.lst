0000                        2  ; ***********************
0000                        3  ; * Output Test Program *
0000                        4  ; ***********************
0000                        5  
0000                        6  ; This program tests the print_* functions.
0000                        7  
0000                        8  ; text:    "Hello, World!"
0000                        9  ; hex_8:   hex numbers 00..ff
0000                       10  ; hex_16:  hex numbers 0000..ffff in steps of 55 (hex)
0000                       11  ; hex_32:  fibonacci sequence (in hex)
0000                       12  ; int_u8:  all integers from 0 to 255
0000                       13  ; int_s8:  all integers from -128 to 127
0000                       14  ; int_u16: integers from 0 to 65535 in steps of 51 (decimal)
0000                       15  ; int_s16: start at -32768 and add 127 until signed overflow
0000                       16  ; int_u32: fibonacci sequence (in decimal)
0000                       17  ; int_s32: start at -2147483648 and add 123456789 repeatedly
0000                       18  
0000                       19  
0000                       20  ; **********************
0000                       21  ; * Header Definitions *
0000                       22  ; **********************
0000                       23  .include ../global/variables.equ
                         ; ==== ../global/variables.equ ====
0000                        1  
0000                        2  ; *** global/variables.equ ***
0000                        3  
0000                        4  ; variables in internal RAM
0000                        5  
0000                        6  ; 0x00-0x1f: register banks 0-3
0000                        7  ; 0x20-0x2f: bit addressable variables
0000                        8  
0030                        9  .equ	in,		0x30	; pointer to input handling routine
0032                       10  .equ	out,		0x32	; pointer to ouput handling routine
0000                       11  
0034                       12  .equ	stream_in,	0x34	; input stream position
0036                       13  .equ	stream_out,	0x36	; output stream position
0000                       14  
0038                       15  .equ	memory_list,	0x38	; pointer to heap list head
0040                       16  .equ	memory_start,	0x40	; first allocatable address
0042                       17  .equ	memory_end,	0x42	; last allocatable address
0000                       18  
0044                       19  .equ	block_read,	0x44	; pointers to block device driver
0046                       20  .equ	block_write,	0x46	; code (read and write functions)
0048                       21  .equ	block_cache,	0x48	; pointer to block cache data in xram
0000                       22  
0050                       23  .equ	fatfs_info,	0x50	; pointer to FAT file system metadata
0000                       24  
0060                       25  .equ	stack,		0x60	; beginning of stack (grows upwards)
0000                       26  
