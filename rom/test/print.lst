03D2                      314  
01B6                      315  .equ panic_out, serial_tx
03D2                      316  .include ../util/panic.inc
                         ; ==== ../util/panic.inc ====
03D2                        1  
03D2                        2  ; *** panic/panic.inc ***
03D2                        3  
03D2                        4  ; >> void panic() <<
03D2                        5  
03D2                        6  ; Unrecoverable error handler.
03D2                        7  ; Print caller address and halt.
03D2                        8  
03D2                        9  panic:
03D2  C2 AF                10  	clr	ea	; disable interrupts
03D4  F8                   11  	mov	r0,a	; save a
03D5                       12  	; display panic text
03D5  90 01 B6             13  	mov	dptr,#panic_out
03D8  85 82 32             14  	mov	out,dpl
03DB  85 83 33             15  	mov	out+1,dph
03DE  90 04 05             16  	mov	dptr,#panic_text
03E1  31 C3                17  	acall	print_text
03E3                       18  	; get return address from stack
03E3  D0 E0                19  	pop	acc
03E5  FA                   20  	mov	r2,a
03E6  D0 E0                21  	pop	acc
03E8                       22  	; subtract two to get call instruction address
03E8  C3                   23  	clr	c
03E9  94 02                24  	subb	a,#2
03EB  F9                   25  	mov	r1,a
03EC  EA                   26  	mov	a,r2
03ED  94 00                27  	subb	a,#0
03EF                       28  	; print caller address (to look up cause in .lst file)
03EF  31 D7                29  	acall	print_hex_8
03F1  E9                   30  	mov	a,r1
03F2  31 D7                31  	acall	print_hex_8
03F4                       32  	; print original value of a (error code / debug info)
03F4  74 20                33  	mov	a,#' '
03F6  31 BE                34  	acall	print_char
03F8  E8                   35  	mov	a,r0
03F9  31 D7                36  	acall	print_hex_8
03FB                       37  	; newline
03FB  74 0D                38  	mov	a,#13
03FD  31 BE                39  	acall	print_char
03FF  74 0A                40  	mov	a,#10
0401  31 BE                41  	acall	print_char
0403                       42  	; hang
0403  80 FE                43  	sjmp	*
0405                       44  
0405                       45  panic_text:
0405  0D 0A                46  	.db	13, 10
0407  20 21 21 21 20 70    47  	.db	" !!! panic @"
