                         ; ==== ../print/char.inc ====
01BE                        1  
01BE                        2  ; *** print/char.inc ***
01BE                        3  
01BE                        4  ; >> void print_char(char a) <<
01BE                        5  
01BE                        6  ; Print char from accumulator.
01BE                        7  ; Indirect call to function behind OUT pointer.
01BE                        8  
01BE                        9  print_char:
01BE  C0 32                10  	push	OUT
01C0  C0 33                11  	push	OUT+1
01C2  22                   12  	ret
01C3                       13  
                         ; ==== print.asm ====
01C3                      311  .include ../print/text.inc
                         ; ==== ../print/text.inc ====
01C3                        1  
01C3                        2  ; *** print/text.inc ***
01C3                        3  
01C3                        4  ; >> void print_text(char* dptr) <<
01C3                        5  
01C3                        6  ; Print null-terminated string from program code.
01C3                        7  ; Aborts if no null terminator is found after 256 bytes.
01C3                        8  
01C3                        9  print_text:
01C3  C0 E0                10  	push	ACC
01C5  C0 00                11  	push	0
01C7                       12  
01C7  E4                   13  	clr	a
01C8  F8                   14  	mov	r0,	a
01C9                       15  print_text__loop:
01C9  93                   16  	movc	a,	@a+dptr
01CA  60 06                17  	jz	print_text__end
01CC  31 BE                18  	acall	print_char
01CE  08                   19  	inc	r0
01CF  E8                   20  	mov	a,	r0
01D0  70 F7                21  	jnz	print_text__loop
01D2                       22  
01D2                       23  print_text__end:
01D2  D0 00                24  	pop	0
01D4  D0 E0                25  	pop	ACC
01D6  22                   26  	ret
01D7                       27  
