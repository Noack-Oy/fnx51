                         ; ==== ../print/hex.inc ====
01D7                        1  
01D7                        2  ; *** print/hex.inc ***
01D7                        3  
01D7                        4  ; >> void print_hex_8(char a) <<
01D7                        5  
01D7                        6  ; Print hexadecimal number from accumulator.
01D7                        7  
01D7                        8  print_hex_8:
01D7  C4                    9  	swap	a	; high nibble first
01D8  31 DB                10  	acall	print_hex_8__nibble
01DA  C4                   11  	swap	a
01DB                       12  print_hex_8__nibble:
01DB  C0 E0                13  	push	ACC
01DD  54 0F                14  	anl	a,	#0x0f
01DF  24 90                15  	add	a,	#0x90
01E1  D4                   16  	da	a
01E2  34 40                17  	addc	a,	#0x40
01E4  D4                   18  	da	a
01E5  44 20                19  	orl	a,	#0x20	; lower case
01E7  31 BE                20  	acall	print_char
01E9  D0 E0                21  	pop	ACC
01EB  22                   22  	ret
01EC                       23  
01EC                       24  ; >> void print_hex_16(int r0r1) <<
01EC                       25  
01EC                       26  ; Print hexadecimal number from r0-r1.
01EC                       27  
01EC                       28  print_hex_16:
01EC  C0 E0                29  	push	ACC
01EE  E9                   30  	mov	a,	r1	; MSB first
01EF  31 D7                31  	acall	print_hex_8
01F1  E8                   32  	mov	a,	r0	; LSB second
01F2  31 D7                33  	acall	print_hex_8
01F4  D0 E0                34  	pop	ACC
01F6  22                   35  	ret
01F7                       36  
01F7                       37  ; >> void print_hex_32(long r0r1r2r3) <<
01F7                       38  
01F7                       39  ; Print hexadecimal number from r0-r3.
01F7                       40  
01F7                       41  print_hex_32:
01F7  C0 E0                42  	push	ACC
01F9  EB                   43  	mov	a,	r3	; MSB first
01FA  31 D7                44  	acall	print_hex_8
01FC  EA                   45  	mov	a,	r2
01FD  31 D7                46  	acall	print_hex_8
01FF  E9                   47  	mov	a,	r1
0200  31 D7                48  	acall	print_hex_8
0202  E8                   49  	mov	a,	r0	; LSB last
0203  31 D7                50  	acall	print_hex_8
0205  D0 E0                51  	pop	ACC
0207  22                   52  	ret
0208                       53  
