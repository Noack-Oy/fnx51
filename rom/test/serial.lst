001D                       27  
001D  11 42                28  	acall	serial_init
001F                       29  
001F  90 00 32             30  	mov	dptr,	#hello_text
0022                       31  hello_loop:
0022  E4                   32  	clr	a
0023  93                   33  	movc	a,	@a+dptr
0024  60 05                34  	jz	hello_end
0026  11 5E                35  	acall	serial_tx
0028  A3                   36  	inc	dptr
0029  80 F7                37  	sjmp	hello_loop
002B                       38  hello_end:
002B                       39  
002B                       40  echo_loop:
002B  11 66                41  	acall	serial_rx
002D  04                   42  	inc	a
002E  11 5E                43  	acall	serial_tx
0030  80 F9                44  	sjmp	echo_loop
0032                       45  
0032                       46  hello_text:
0032  48 65 6C 6C 6F 2C    47  	.byte	"Hello, world!"
0038  20 77 6F 72 6C 64
003E  21
003F  0D 0A 00             48  	.byte	13, 10, 0
