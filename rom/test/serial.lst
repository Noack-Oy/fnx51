0042                       54  .include ../serial/init.inc
                         ; ==== ../serial/init.inc ====
0042                        1  
0042                        2  ; *** serial/init.inc ***
0042                        3  
0042                        4  ; >> void serial_init() <<
0042                        5  
0042                        6  ; Initialize serial interface.
0042                        7  ; - assumes 20MHz clock and X2 mode
0042                        8  ; - uses internal baud rate generator
0042                        9  ; - speed: 9600 bits per second
0042                       10  ; Formula: BRL = 256 - (F_clk / (32 * Baud_Rate))
0042                       11  ; ---
0042                       12  ; See datasheet page 52 for details,
0042                       13  ; also note oscillator diagram on page 16!
0042                       14  
0042                       15  serial_init:
0042  75 98 52             16  	mov	SCON,	#0x52	; SM1, REN, TI
0045  75 9A BF             17  	mov	BRL,	#191	; 9600 @20MHz CLK
0048  75 9B 1E             18  	mov	BDRCON, #0x1e	; BRR, RBCK, TBCK, SPD
004B                       19  
004B  90 00 66             20  	mov	dptr,	#serial_rx
004E  85 82 30             21  	mov	IN,	DPL
0051  85 83 31             22  	mov	IN+1,	DPH
0054                       23  
0054  90 00 5E             24  	mov	dptr,	#serial_tx
0057  85 82 32             25  	mov	OUT,	DPL
005A  85 83 33             26  	mov	OUT+1,	DPH
005D                       27  
005D  22                   28  	ret
005E                       29  
                         ; ==== serial.asm ====
005E                       55  .include ../serial/tx.inc
                         ; ==== ../serial/tx.inc ====
005E                        1  
005E                        2  ; *** serial/tx.inc ***
005E                        3  
005E                        4  ; >> void serial_tx(char a) <<
005E                        5  
005E                        6  ; Transmit byte from accumulator.
005E                        7  
005E                        8  serial_tx:
005E  30 99 FD              9  	jnb	TI,	serial_tx
0061  C2 99                10  	clr	TI
0063  F5 99                11  	mov	SBUF,	a
0065  22                   12  	ret
0066                       13  
                         ; ==== serial.asm ====
0066                       56  .include ../serial/rx.inc
                         ; ==== ../serial/rx.inc ====
0066                        1  
0066                        2  ; *** serial/rx.inc ***
0066                        3  
0066                        4  ; >> char serial_rx <<
0066                        5  
0066                        6  ; Receive byte into accumulator.
0066                        7  
0066                        8  serial_rx:
0066  30 98 FD              9  	jnb	RI,	serial_rx
0069  C2 98                10  	clr	RI
006B  E5 99                11  	mov	a,	SBUF
006D  22                   12  	ret
006E                       13  
                         ; ==== serial.asm ====
