                         ; ==== ../serial/init.inc ====
0100                        1  
0100                        2  ; *** serial/init.inc ***
0100                        3  
0100                        4  ; >> void serial_init() <<
0100                        5  
0100                        6  ; Initialize serial interface.
0100                        7  ; - assumes 20MHz clock and X2 mode
0100                        8  ; - uses internal baud rate generator
0100                        9  ; - speed: 9600 bits per second
0100                       10  ; Formula: BRL = 256 - (F_clk / (32 * Baud_Rate))
0100                       11  ; ---
0100                       12  ; See datasheet page 52 for details,
0100                       13  ; also note oscillator diagram on page 16!
0100                       14  
0100                       15  serial_init:
0100  75 98 52             16  	mov	SCON,	#0x52	; SM1, REN, TI
0103  75 9A BF             17  	mov	BRL,	#191	; 9600 @20MHz CLK
0106  75 9B 1E             18  	mov	BDRCON, #0x1e	; BRR, RBCK, TBCK, SPD
0109                       19  
0109  90 01 24             20  	mov	dptr,	#serial_rx
010C  85 82 30             21  	mov	IN,	DPL
010F  85 83 31             22  	mov	IN+1,	DPH
0112                       23  
0112  90 01 1C             24  	mov	dptr,	#serial_tx
0115  85 82 32             25  	mov	OUT,	DPL
0118  85 83 33             26  	mov	OUT+1,	DPH
011B                       27  
011B  22                   28  	ret
011C                       29  
