                         ; ==== ../util/dump.inc ====
04F8                        1  
04F8                        2  ; *** util/dump.inc ***
04F8                        3  
04F8                        4  ; >> uint32{r0-r3} dump(uint32{r0-r3} addr, uint8{a} count) <<
04F8                        5  
04F8                        6  ; Print hexdump from standard input to standard output.
04F8                        7  ; Starting value for address column in r0-r3.
04F8                        8  ; Number of bytes to print in a (0 means 256).
04F8                        9  ; r0-r3 contains next address upon exit.
04F8                       10  
04F8                       11  dump:
04F8  C0 F0                12  	push	b
04FA  C0 E0                13  	push	acc
04FC  F5 F0                14  	mov	b,	a
04FE  C0 04                15  	push	4
0500  C0 05                16  	push	5
0502  C0 06                17  	push	6
0504  C0 07                18  	push	7
0506                       19  
0506                       20  	; b: total bytes remaining
0506                       21  	; r0: buffer pointer
0506                       22  	; r1: read loop counter / padding size
0506                       23  	; r2: print loop counter
0506                       24  
0506                       25  	; r4-7: address label
0506  91 EB                26  	acall	xch_r0123_r4567
0508                       27  
0508                       28  	; allocate 16 byte array on stack
0508  E5 81                29  	mov	a,	sp
050A  F8                   30  	mov	r0,	a
050B  24 10                31  	add	a,	#16
050D  F5 81                32  	mov	sp,	a
050F                       33  
050F                       34  dump__line_loop:
050F                       35  	; read into buffer
050F  79 10                36  	mov	r1,	#16
0511                       37  dump__read_loop:
0511  91 E6                38  	acall	read_char
0513  08                   39  	inc	r0
0514  F6                   40  	mov	@r0,	a
0515  D5 F0 03             41  	djnz	b,	dump__read_continue
0518  19                   42  	dec	r1
0519  80 02                43  	sjmp	dump__read_end
051B                       44  dump__read_continue:
051B  D9 F4                45  	djnz	r1,	dump__read_loop
051D                       46  dump__read_end:
051D                       47  
051D                       48  	; print address column
051D  91 EB                49  	acall	xch_r0123_r4567
051F  91 A0                50  	acall	print_hex_32
0521  91 EB                51  	acall	xch_r0123_r4567
0523  74 3A                52  	mov	a,	#':'
0525  91 7B                53  	acall	print_char
0527                       54  
0527                       55  	; if r1 is nonzero here, we have a shorter line
0527                       56  	; the value in r1 is the number of padding bytes
0527                       57  
0527                       58  	; wind back pointer
0527  E8                   59  	mov	a,	r0
0528  24 F0                60  	add	a,	#-16
052A  29                   61  	add	a,	r1
052B  F8                   62  	mov	r0,	a
052C                       63  
052C                       64  	; print hex
052C  7A 10                65  	mov	r2,	#16
052E                       66  dump__print_hex_loop:
052E  08                   67  	inc	r0
052F  EA                   68  	mov	a,	r2
0530  54 03                69  	anl	a,	#3	; mod 4
0532  70 04                70  	jnz	dump__print_hex_no_gap
0534  74 20                71  	mov	a,	#' ' ; gap after every 4 bytes
0536  91 7B                72  	acall	print_char
0538                       73  dump__print_hex_no_gap:
0538  EA                   74  	mov	a,	r2
0539  D3                   75  	setb	c
053A  99                   76  	subb	a,	r1
053B  50 08                77  	jnc	dump__print_hex_no_padding
053D  74 20                78  	mov	a,	#' ' ; padding for shorter line
053F  91 7B                79  	acall	print_char
0541  91 7B                80  	acall	print_char
0543  80 03                81  	sjmp	dump__print_hex_next
0545                       82  dump__print_hex_no_padding:
0545  E6                   83  	mov	a,	@r0
0546  91 80                84  	acall	print_hex_8
0548                       85  dump__print_hex_next:
0548  74 20                86  	mov	a,	#' ' ; space between bytes
054A  91 7B                87  	acall	print_char
054C  DA E0                88  	djnz	r2,	dump__print_hex_loop
054E                       89  
054E                       90  	; wind back again
054E  E8                   91  	mov	a,	r0
054F  24 F0                92  	add	a,	#-16
0551  F8                   93  	mov	r0,	a
0552                       94  
0552                       95  	; print ascii
0552  74 20                96  	mov	a,	#' '
0554  91 7B                97  	acall	print_char
0556  74 7C                98  	mov	a,	#'|'
0558  91 7B                99  	acall	print_char
055A  74 10               100  	mov	a,	#16
055C  C3                  101  	clr	c
055D  99                  102  	subb	a,	r1
055E  F9                  103  	mov	r1,	a ; number of bytes to print
055F  FA                  104  	mov	r2,	a
0560                      105  dump__print_ascii_loop:
0560  08                  106  	inc	r0
0561  E6                  107  	mov	a,	@r0
0562  B4 20 00            108  	cjne	a,	#0x20,	dump__print_ascii_check1
0565                      109  dump__print_ascii_check1:
0565  40 05               110  	jc	dump__print_ascii_replace
0567  B4 7F 00            111  	cjne	a,	#0x7f,	dump__print_ascii_check2
056A                      112  dump__print_ascii_check2:
056A  40 02               113  	jc	dump__print_ascii_continue
056C                      114  dump__print_ascii_replace:
056C  74 2E               115  	mov	a,	#'.'
056E                      116  dump__print_ascii_continue:
056E  91 7B               117  	acall	print_char
0570  DA EE               118  	djnz	r2,	dump__print_ascii_loop
0572  74 7C               119  	mov	a,	#'|'
0574  91 7B               120  	acall	print_char
0576  74 0D               121  	mov	a,	#13
0578  91 7B               122  	acall	print_char
057A  74 0A               123  	mov	a,	#10
057C  91 7B               124  	acall	print_char
057E                      125  
057E                      126  	; wind back again
057E  E8                  127  	mov	a,	r0
057F  24 F0               128  	add	a,	#-16
0581  F8                  129  	mov	r0,	a
0582                      130  
0582                      131  	; next address
0582  EC                  132  	mov	a,	r4
0583  29                  133  	add	a,	r1
0584  FC                  134  	mov	r4,	a
0585  ED                  135  	mov	a,	r5
0586  34 00               136  	addc	a,	#0
0588  FD                  137  	mov	r5,	a
0589  EE                  138  	mov	a,	r6
058A  34 00               139  	addc	a,	#0
058C  FE                  140  	mov	r6,	a
058D  EF                  141  	mov	a,	r7
058E  34 00               142  	addc	a,	#0
0590  FF                  143  	mov	r7,	a
0591                      144  
0591  E5 F0               145  	mov	a,	b
0593  60 02               146  	jz	dump__end
0595  A1 0F               147  	ajmp	dump__line_loop
0597                      148  
0597                      149  dump__end:
0597                      150  	; deallocate array from stack
0597  E5 81               151  	mov	a,	sp
0599  24 F0               152  	add	a,	#-16
059B  F5 81               153  	mov	sp,	a
059D                      154  
059D  91 EB               155  	acall	xch_r0123_r4567
059F                      156  
059F  D0 07               157  	pop	7
05A1  D0 06               158  	pop	6
05A3  D0 05               159  	pop	5
05A5  D0 04               160  	pop	4
05A7  D0 E0               161  	pop	acc
05A9  D0 F0               162  	pop	b
05AB  22                  163  	ret
05AC                      164  
