                         ; ==== ../sd/config.equ ====
0000                        1  
0000                        2  ; *** sd/config.equ ***
0000                        3  
0000                        4  ; SPCON register configuration for SD card:
0000                        5  ; .-----.-------.-------.---------------------------------------.
0000                        6  ; | bit | name	| value | remark				|
0000                        7  ; |-----|-------|-------|---------------------------------------|
0000                        8  ; | 7	| SPR2	| 1	| SPR2:0 = 101-> Fclk_periph / 64	|
0000                        9  ; | 6	| SPEN	| 1	| Set to enable the SPI			|
0000                       10  ; | 5	| SSDIS | 1	| Set to disable /SS input		|
0000                       11  ; | 4	| MSTR	| 1	| Set to configure the SPI as a master	|
0000                       12  ; | 3	| CPOL	| 0	| Cleared to have SCK idle at '0'	|
0000                       13  ; | 2	| CPHA	| 0	| Cleared to sample on leading edge	|
0000                       14  ; | 1	| SPR1	| 0	| (see above)				|
0000                       15  ; | 0	| SPR0	| 1	| (see above)	speed: 312.5 kHz	|
0000                       16  ; '-----'-------'-------'---------------------------------------'
0000                       17  
00F1                       18  .equ	sd_spi_config,	0xf1
0000                       19  
0091                       20  .flag	sd_pin_cs,	p1.1
