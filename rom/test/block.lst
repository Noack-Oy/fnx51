047B                        3  
047B                        4  ; >> void print_char(char a) <<
047B                        5  
047B                        6  ; Print char from accumulator.
047B                        7  ; Indirect call to function behind OUT pointer.
047B                        8  
047B                        9  print_char:
047B  C0 32                10  	push	OUT
047D  C0 33                11  	push	OUT+1
047F  22                   12  	ret
