04B1                        1  
04B1                        2  ; *** print/text.inc ***
04B1                        3  
04B1                        4  ; >> void print_text(char* dptr) <<
04B1                        5  
04B1                        6  ; Print null-terminated string from program code.
04B1                        7  ; Aborts if no null terminator is found after 256 bytes.
04B1                        8  
04B1                        9  print_text:
04B1  C0 E0                10  	push	ACC
04B3  C0 00                11  	push	0
04B5                       12  
04B5  E4                   13  	clr	a
04B6  F8                   14  	mov	r0,	a
04B7                       15  print_text__loop:
04B7  93                   16  	movc	a,	@a+dptr
04B8  60 06                17  	jz	print_text__end
04BA  91 7B                18  	acall	print_char
04BC  08                   19  	inc	r0
04BD  E8                   20  	mov	a,	r0
04BE  70 F7                21  	jnz	print_text__loop
04C0                       22  
04C0                       23  print_text__end:
04C0  D0 00                24  	pop	0
04C2  D0 E0                25  	pop	ACC
04C4  22                   26  	ret
04C5                       27  
