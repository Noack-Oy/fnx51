                   
                   ; *****************************
                   ; * Block Device Test Program *
                   ; *****************************
                   
                   ; This program uses the block device layer
                   ; to read data from an SD card.
                   
                   
                   ; **********************
                   ; * Header Definitions *
                   ; **********************
                   
                   ; *** global/variables.equ ***
                   
                   ; variables in internal RAM
                   
                   ; 0x00-0x1f: register banks 0-3
                   ; 0x20-0x2f: bit addressable variables
                   
0000:              .equ    in,             0x30    ; pointer to input handling 
0000:              .equ    out,            0x32    ; pointer to ouput handling 
                   
0000:              .equ    stream_in,      0x34    ; input stream position
0000:              .equ    stream_out,     0x36    ; output stream position
                   
0000:              .equ    memory_list,    0x38    ; pointer to heap list head
0000:              .equ    memory_start,   0x40    ; first allocatable address
0000:              .equ    memory_end,     0x42    ; last allocatable address
                   
0000:              .equ    block_read,     0x44    ; pointers to block device d
0000:              .equ    block_write,    0x46    ; code (read and write funct
0000:              .equ    block_cache,    0x48    ; pointer to block cache dat
                   
0000:              .equ    fatfs_info,     0x50    ; pointer to FAT file system
                   
0000:              .equ    stack,          0x60    ; beginning of stack (grows 
                   
                   ; *** global/sfr.equ ***
                   
                   ; global SFRs
                   
0000:              .equ    auxr,   0x8e    ; auxiliary register 0
0000:              .equ    auxr1,  0xa2    ; auxiliary register 1
                   
                   ; *** serial/sfr.equ ***
                   
                   ; Special function registers for serial interface.
                   ; See chapter 14 of AT89C51ED2 datasheet, page 48ff.
                   
                   ; Internal Baud Rate Generator (BRG), see datasheet page 52.
0000:                      .equ    BRL,    0x9A    ; baud rate reload value
0000:                      .equ    BDRCON, 0x9B    ; BRG control register
                   
                   ; *** spi/sfr.equ ***
                   
                   ; Special function registers for serial peripheral interface
                   ; See chapter 16 of AT89C51ED2 datasheet
                   
0000:              .equ    spcon,  0xc3    ; Serial Peripheral Control Register
0000:              .equ    spsta,  0xc4    ; Serial Peripheral Status Register
0000:              .equ    spdat,  0xc5    ; Serial Peripheral Data Register
                   
                   ; *** sd/config.equ ***
                   
                   ; SPCON register configuration for SD card:
                   ; .-----.-------.-------.-----------------------------------
                   ; | bit | name  | value | remark                            
                   ; |-----|-------|-------|-----------------------------------
                   ; | 7   | SPR2  | 1     | SPR2:0 = 101-> Fclk_periph / 64   
                   ; | 6   | SPEN  | 1     | Set to enable the SPI             
                   ; | 5   | SSDIS | 1     | Set to disable /SS input          
                   ; | 4   | MSTR  | 1     | Set to configure the SPI as a mast
                   ; | 3   | CPOL  | 0     | Cleared to have SCK idle at '0'   
                   ; | 2   | CPHA  | 0     | Cleared to sample on leading edge 
                   ; | 1   | SPR1  | 0     | (see above)                       
                   ; | 0   | SPR0  | 1     | (see above)   speed: 312.5 kHz    
                   ; '-----'-------'-------'-----------------------------------
                   
0000:              .equ    sd_spi_config,  0xf1
                   
0000:              .flag   sd_pin_cs,      p1.1
                   
                   ; *************
                   ; * Main Code *
                   ; *************
                   
                   ; *** test/block.asm ***
                   
0000:              .org    0
                   
                   ; *** global/init.inc ***
                   
                   ; Initialize stack pointer and global variables.
                   ; This must be included early in the main program.
                   
                   global_init:
0000: 75 81 60             mov     SP,#STACK
                   
                   ; Select register bank zero, clear processor flags
0003: 75 D0 00             mov     PSW,#0
                   
                   ; Fill internal RAM with markers for uninitialized data
0006: 78 00                mov     r0,#0 ; write pointer
                   
0008: 74 3F                mov     a,#0x3f ; '?' for uninitialized registers
                   global_init__1:
000A: 08                   inc     r0 ; first iteration skips address 0, r0 liv
000B: F6                   mov     @r0,a
000C: B8 1F FB             cjne    r0,#0x1f,global_init__1
                   
000F: 74 2A                mov     a,#0x2a ; '*' for uninitialized variables
                   global_init__2:
0011: 08                   inc     r0
0012: F6                   mov     @r0,a
0013: B8 5F FB             cjne    r0,#STACK-1,global_init__2
                   
0016: 74 7E                mov     a,#0x7e ; '~' for stack and above
                   global_init__3:
0018: 08                   inc     r0
0019: F6                   mov     @r0,a
001A: B8 FF FB             cjne    r0,#0xff,global_init__3
                   
001D: 31 00                acall   serial_init
001F: 51 AA                acall   memory_init
0021: 31 37                acall   sd_init
0023: 60 02                jz      __1
0025: B1 A2                acall   panic ; sd init error
                   __1:
0027: 71 D7                acall   block_init
                   
0029: 90 00 B2             mov     dptr,#ok_string
002C: 91 A7                acall   print_text
                   
002E: E4                   clr     a
002F: F8                   mov     r0,a
0030: F9                   mov     r1,a
0031: FA                   mov     r2,a
0032: FB                   mov     r3,a
0033: 91 04                acall   block_load
                   
                           ; dump whole first sector
0035: 85 82 34             mov     stream_in,dpl
0038: 85 83 35             mov     stream_in+1,dph
003B: E4                   clr     a
003C: F8                   mov     r0,a
003D: F9                   mov     r1,a
003E: FA                   mov     r2,a
003F: FB                   mov     r3,a
0040: 90 04 BB             mov     dptr,#stream_xram_read
0043: 85 82 30             mov     in,dpl
0046: 85 83 31             mov     in+1,dph
0049: 91 EE                acall   dump
004B: 91 EE                acall   dump
004D: A8 34                mov     r0,stream_in
004F: A9 35                mov     r1,stream_in+1
0051: 19                   dec     r1
0052: 19                   dec     r1
                   
0053: 90 00 B4             mov     dptr,#newline
0056: 91 A7                acall   print_text
                   
                           ; dump partition table
0058: 90 01 BE             mov     dptr,#446
005B: E8                   mov     a,r0
005C: 25 82                add     a,dpl
005E: F5 34                mov     stream_in,a
0060: E9                   mov     a,r1
0061: 35 83                addc    a,dph
0063: F5 35                mov     stream_in+1,a
0065: E4                   clr     a
0066: F8                   mov     r0,a
0067: F9                   mov     r1,a
0068: 74 40                mov     a,#4*16
006A: 91 EE                acall   dump
                   
006C: 90 00 B4             mov     dptr,#newline
006F: 91 A7                acall   print_text
                   
                           ; get lba of first partition
0071: E5 34                mov     a,stream_in
0073: C3                   clr     c
0074: 94 38                subb    a,#4*16-8
0076: F5 82                mov     dpl,a
0078: E5 35                mov     a,stream_in+1
007A: 94 00                subb    a,#0
007C: F5 83                mov     dph,a
007E: E0                   movx    a,@dptr
007F: A3                   inc     dptr
0080: F8                   mov     r0,a
0081: E0                   movx    a,@dptr
0082: A3                   inc     dptr
0083: F9                   mov     r1,a
0084: E0                   movx    a,@dptr
0085: A3                   inc     dptr
0086: FA                   mov     r2,a
0087: E0                   movx    a,@dptr
0088: A3                   inc     dptr
0089: FB                   mov     r3,a
                   
008A: 91 96                acall   print_hex_32
008C: 90 00 B4             mov     dptr,#newline
008F: 91 A7                acall   print_text
                   
                           ; load and dump volume id sector
0091: 91 04                acall   block_load
0093: 85 82 34             mov     stream_in,dpl
0096: 85 83 35             mov     stream_in+1,dph
0099: E4                   clr     a
009A: F8                   mov     r0,a
009B: F9                   mov     r1,a
009C: FA                   mov     r2,a
009D: FB                   mov     r3,a
009E: 90 04 BB             mov     dptr,#stream_xram_read
00A1: 85 82 30             mov     in,dpl
00A4: 85 83 31             mov     in+1,dph
00A7: 91 EE                acall   dump
00A9: 91 EE                acall   dump
                   
00AB: 90 00 B4             mov     dptr,#newline
00AE: 91 A7                acall   print_text
                   
                   
                   halt:
00B0: 80 FE                sjmp    halt
                   
                   ok_string:
00B2: 4F 4B                .db     "OK" 
                   newline: 
00B4: 0D 0A 00             .db     13, 10, 0
                   
0100:              .org    0x0100
                   
                   ; *********************
                   ; * Library Functions *
                   ; *********************
                   
                   ; *** serial/init.inc ***
                   
                   ; >> void serial_init() <<
                   
                   ; Initialize serial interface.
                   ; - assumes 20MHz clock and X2 mode
                   ; - uses internal baud rate generator
                   ; - speed: 9600 bits per second
                   ; Formula: BRL = 256 - (F_clk / (32 * Baud_Rate))
                   ; ---
                   ; See datasheet page 52 for details,
                   ; also note oscillator diagram on page 16!
                   
                   serial_init:
0100: 75 98 52             mov     SCON,   #0x52   ; SM1, REN, TI
0103: 75 9A BF             mov     BRL,    #191    ; 9600 @20MHz CLK
0106: 75 9B 1E             mov     BDRCON, #0x1e   ; BRR, RBCK, TBCK, SPD
                   
0109: 90 01 24             mov     dptr,   #serial_rx
010C: 85 82 30             mov     IN,     DPL
010F: 85 83 31             mov     IN+1,   DPH
                   
0112: 90 01 1C             mov     dptr,   #serial_tx
0115: 85 82 32             mov     OUT,    DPL
0118: 85 83 33             mov     OUT+1,  DPH
                   
011B: 22                   ret
                   
                   ; *** serial/tx.inc ***
                   
                   ; >> void serial_tx(char a) <<
                   
                   ; Transmit byte from accumulator.
                   
                   serial_tx:
011C: 30 99 FD             jnb     TI,     serial_tx
011F: C2 99                clr     TI
0121: F5 99                mov     SBUF,   a
0123: 22                   ret
                   
                   ; *** serial/rx.inc ***
                   
                   ; >> char serial_rx <<
                   
                   ; Receive byte into accumulator.
                   
                   serial_rx:
0124: 30 98 FD             jnb     RI,     serial_rx
0127: C2 98                clr     RI
0129: E5 99                mov     a,      SBUF
012B: 22                   ret
                   
                   
                   ; *** spi/transfer.inc ***
                   
                   ; >> char{a} serial_transfer(char{a} data) <<
                   
                   ; SPI transfer function: send byte from a, read response int
                   
                   spi_transfer:
012C: F5 C5                mov     spdat,a
                   
                   spi_transfer__wait:
012E: E5 C4                mov     a,spsta
0130: 54 80                anl     a,#0x80 ;check SPIF bit
0132: 60 FA                jz      spi_transfer__wait
                   
0134: E5 C5                mov     a,spdat
0136: 22                   ret
                   
                   ; *** sd/init.inc ***
                   
                   ; >> uint8{a},uint32{r0-r3} sd_init() <<
                   
                   ; Initialize SD card, return error code in a, OCR in r0-r3.
                   sd_init:
                           ; r5 is used as temp store for error code
0137: C0 05                push    5
0139: C0 82                push    dpl
013B: C0 83                push    dph
                   
013D: 75 C3 F1             mov     spcon,#sd_spi_config
0140: 31 84                acall   sd_warmup
0142: 31 99                acall   sd_select
                   
0144: 7D 05                mov     r5,#5   ; 5: no idle response to cmd0
0146: 31 A8                acall   sd_cmd0
0148: B4 01 31             cjne    a,#1,sd_init__end
                   
014B: 1D                   dec     r5      ; 4: no idle response to cmd8
014C: 31 C8                acall   sd_cmd8
014E: B4 01 2B             cjne    a,#1,sd_init__end
0151: 1D                   dec     r5      ; 3: invalid cmd8 response
0152: BB 00 27             cjne    r3,#0x00,sd_init__end
0155: BA 00 24             cjne    r2,#0x00,sd_init__end
0158: B9 01 21             cjne    r1,#0x01,sd_init__end
015B: B8 AA 1E             cjne    r0,#0xaa,sd_init__end
                   
015E: 7D 64                mov     r5,#100 ; retry counter
                   sd_init__loop:
0160: 31 DD                acall   sd_acmd41
0162: 60 0A                jz      sd_init__continue
0164: 74 0A                mov     a,#10
0166: 91 55                acall   delay_ms_8
0168: DD F6                djnz    r5,sd_init__loop
016A: 7D 02                mov     r5,#2   ; 2: acmd41 ready response timeout
016C: 80 0E                sjmp    sd_init__end
                   
                   sd_init__continue:
016E: 7D 01                mov     r5,#1   ; 1: no ready response to cmd58
0170: 51 25                acall   sd_cmd58
                   
0172: 1D                   dec     r5      ; 0: success
                   
0173: 90 02 80             mov     dptr,#sd_block_read
0176: 85 82 44             mov     block_read,dpl
0179: 85 83 45             mov     block_read+1,dph
                   
                   sd_init__end:
017C: ED                   mov     a,r5    ; error code -> return value
017D: D0 83                pop     dph
017F: D0 82                pop     dpl
0181: D0 05                pop     5
0183: 22                   ret
                   
                   ; *** sd/warmup.inc ***
                   
                   ; >> void sd_warmup() <<
                   
                   ; send 80 warmup pulses to sclk while cs is high
                   sd_warmup:
0184: C0 E0                push    acc
0186: C0 F0                push    b
0188: D2 91                setb    sd_pin_cs ; p1.1
018A: 75 F0 0A             mov     b,#10
                   sd_warmup_loop:
018D: 74 FF                mov     a,#0xff
018F: 31 2C                acall   spi_transfer
0191: D5 F0 F9             djnz    b,sd_warmup_loop
0194: D0 F0                pop     b
0196: D0 E0                pop     acc
0198: 22                   ret
                   
                   ; *** sd/select.inc ***
                   
                   ; >> void sd_select() <<
                   
                   ; Activate the SD card
                   sd_select:
0199: C0 E0                push    acc
019B: 74 FF                mov     a,#0xff
019D: 31 2C                acall   spi_transfer
019F: C2 91                clr     sd_pin_cs
01A1: 74 FF                mov     a,#0xff
01A3: 31 2C                acall   spi_transfer
01A5: D0 E0                pop     acc
01A7: 22                   ret
                   
                   ; *** sd/cmd0.inc ***
                   
                   ; >> char{a} sd_cmd0() <<
                   
                   ; CMD0: go to idle state
                   sd_cmd0:
01A8: C0 00                push    0
01AA: C0 01                push    1
01AC: C0 02                push    2
01AE: C0 03                push    3
01B0: C0 04                push    4
01B2: E4                   clr     a
01B3: F8                   mov     r0,a
01B4: F9                   mov     r1,a
01B5: FA                   mov     r2,a
01B6: FB                   mov     r3,a
01B7: 7C 94                mov     r4,#0x94
01B9: 51 36                acall   sd_command
01BB: 51 50                acall   sd_response1
01BD: D0 04                pop     4
01BF: D0 03                pop     3
01C1: D0 02                pop     2
01C3: D0 01                pop     1
01C5: D0 00                pop     0
01C7: 22                   ret
                   
                   ; *** sd/cmd8.inc ***
                   
                   ; >> uint8{a},uint32{r0-r3} sd_cmd8() <<
                   
                   ; CMD8: send interface condition
                   sd_cmd8:
01C8: C0 04                push    4
01CA: 74 08                mov     a,#8
01CC: 78 AA                mov     r0,#0xaa
01CE: 79 01                mov     r1,#0x01
01D0: 7A 00                mov     r2,#0x00
01D2: 7B 00                mov     r3,#0x00
01D4: 7C 86                mov     r4,#0x86
01D6: 51 36                acall   sd_command
01D8: 51 62                acall   sd_response7
01DA: D0 04                pop     4
01DC: 22                   ret
                   
                   ; *** sd/acmd41.inc ***
                   
                   ; >> char{a} sd_acmd41() <<
                   
                   ; ACMD41: send operation condition
                   sd_acmd41:
01DD: 51 04                acall   sd_cmd55
01DF: B4 01 21             cjne    a,#1,sd_acmd41__end
01E2: C0 00                push    0
01E4: C0 01                push    1
01E6: C0 02                push    2
01E8: C0 03                push    3
01EA: C0 04                push    4
01EC: E4                   clr     a
01ED: F8                   mov     r0,a
01EE: F9                   mov     r1,a
01EF: FA                   mov     r2,a
01F0: 7B 40                mov     r3,#0x40 ; indicates high capacity support
01F2: FC                   mov     r4,a
01F3: 74 29                mov     a,#41
01F5: 51 36                acall   sd_command
01F7: 51 50                acall   sd_response1
01F9: D0 04                pop     4
01FB: D0 03                pop     3
01FD: D0 02                pop     2
01FF: D0 01                pop     1
0201: D0 00                pop     0
                   sd_acmd41__end:
0203: 22                   ret
                   
                   ; *** sd/cmd55.inc ***
                   
                   ; >> char{a} sd_cmd55() <<
                   
                   ; CMD55: application specific command (prefix)
                   sd_cmd55:
0204: C0 00                push    0
0206: C0 01                push    1
0208: C0 02                push    2
020A: C0 03                push    3
020C: C0 04                push    4
020E: E4                   clr     a
020F: F8                   mov     r0,a
0210: F9                   mov     r1,a
0211: FA                   mov     r2,a
0212: FB                   mov     r3,a
0213: FC                   mov     r4,a
0214: 74 37                mov     a,#55
0216: 51 36                acall   sd_command
0218: 51 50                acall   sd_response1
021A: D0 04                pop     4
021C: D0 03                pop     3
021E: D0 02                pop     2
0220: D0 01                pop     1
0222: D0 00                pop     0
0224: 22                   ret
                   
                   ; *** sd/cmd58.inc ***
                   
                   ; >> uint8{a},uint32{r0-r3} sd_cmd58() <<
                   
                   ; CMD58: read operation conditions register
                   sd_cmd58:
0225: C0 04                push    4
0227: E4                   clr     a
0228: F8                   mov     r0,a
0229: F9                   mov     r1,a
022A: FA                   mov     r2,a
022B: FB                   mov     r3,a
022C: FC                   mov     r4,a
022D: 74 3A                mov     a,#58
022F: 51 36                acall   sd_command
0231: 51 62                acall   sd_response3
0233: D0 04                pop     4
0235: 22                   ret
                   
                   ; *** sd/command.inc ***
                   
                   ; >> void sd_command(uint8{a} cmd, uint32{r0-r3} arg, uint8{
                   
                   ; Issue a command to the SD card
                   sd_command:
0236: C0 E0                push    acc
                           ; transmit command
0238: 44 40                orl     a,#0x40 ; transmission bit
023A: 31 2C                acall   spi_transfer
                           ; transmit argument
023C: EB                   mov     a,r3
023D: 31 2C                acall   spi_transfer
023F: EA                   mov     a,r2
0240: 31 2C                acall   spi_transfer
0242: E9                   mov     a,r1
0243: 31 2C                acall   spi_transfer
0245: E8                   mov     a,r0
0246: 31 2C                acall   spi_transfer
                           ; transmit crc
0248: EC                   mov     a,r4
0249: 44 01                orl     a,#0x01 ; end bit
024B: 31 2C                acall   spi_transfer
024D: D0 E0                pop     acc
024F: 22                   ret
                   
                   ; *** sd/response.inc ***
                   
                   ; >> uint8{a} sd_response1() <<
                   
                   ; Read response from SD card in 'R1' format into a
                   sd_response1:
0250: C0 F0                push    b
0252: 85 08 F0             mov     b,8     ; number of tries
                   sd_response1__loop:
0255: 74 FF                mov     a,#0xff
0257: 31 2C                acall   spi_transfer
0259: B4 FF 03             cjne    a,#0xff,sd_response1__end       ; success
025C: D5 F0 F6             djnz    b,sd_response1__loop    ; retry / timeout
                   sd_response1__end:
025F: D0 F0                pop     b
0261: 22                   ret
                   
                   ; >> uint8{a}, uint32{r0-r3} sd_response3() <<
                   
                   ; Read response from SD card in 'R3' format into a and r0-r3
                   sd_response3: ; same as R7
                   
                   ; >> uint8{a}, uint32{r0-r3} sd_response7() <<
                   
                   ; Read response from SD card in 'R7' format into a and r0-r3
                   sd_response7:
0262: 51 50                acall   sd_response1
0264: B4 02 00             cjne    a,#0x02,sd_response7__1
                   sd_response7__1:
0267: 40 01                jc      sd_response7__2
0269: 22                   ret     ; error in R1 response
                   sd_response7__2:
026A: F8                   mov     r0,a
026B: 74 FF                mov     a,#0xff
026D: 31 2C                acall   spi_transfer
026F: FB                   mov     r3,a
0270: 74 FF                mov     a,#0xff
0272: 31 2C                acall   spi_transfer
0274: FA                   mov     r2,a
0275: 74 FF                mov     a,#0xff
0277: 31 2C                acall   spi_transfer
0279: F9                   mov     r1,a
027A: 74 FF                mov     a,#0xff
027C: 31 2C                acall   spi_transfer
027E: C8                   xch     a,r0
027F: 22                   ret
                   
                   ; *** sd/block_read.inc ***
                   
                   ; >> uint16{r4-r5} sd_block_read(
                   ;       uint32{r0-r3} block_address,
                   ;       char *{dptr}&destination) <<
                   
                   ; Read block at address from sd card, write to RAM at dptr.
                   ; Return CRC in r4-r5, block address unchanged,
                   ; dptr pointing to first byte after read block.
                   
                   sd_block_read:
0280: C0 E0                push    acc
                   
                           ; send CMD17 (single block read)
0282: 74 11                mov     a,#17
0284: 7C FF                mov     r4,#0xff ; command CRC, ignored
0286: 51 36                acall   sd_command
                   sd_block_read__wait:
0288: 51 50                acall   sd_response1
028A: B4 FE FB             cjne    a,#0xfe,sd_block_read__wait
028D: 7D 00                mov     r5,#0 ; loop counter
                           ; this loop will run 256 times,
                           ; two bytes are read per iteration
                   sd_block_read__loop:
028F: 74 FF                mov     a,#0xff
0291: 31 2C                acall   spi_transfer
0293: F0                   movx    @dptr,a
0294: A3                   inc     dptr
0295: 74 FF                mov     a,#0xff
0297: 31 2C                acall   spi_transfer
0299: F0                   movx    @dptr,a
029A: A3                   inc     dptr
029B: DD F2                djnz    r5,sd_block_read__loop
                           ; read block CRC
029D: 74 FF                mov     a,#0xff
029F: 31 2C                acall   spi_transfer
02A1: FD                   mov     r5,a
02A2: 74 FF                mov     a,#0xff
02A4: 31 2C                acall   spi_transfer
02A6: FC                   mov     r4,a
                   
02A7: D0 E0                pop     acc
02A9: 22                   ret
                   
                   
                   ; *** memory/init.inc ***
                   
                   ; >> void memory_init(() <<
                   
                   ; Enable xram, initialize memory allocator data structures
                   
                   memory_init:
                   
02AA: C0 E0                push    acc
02AC: C0 82                push    dpl
02AE: C0 83                push    dph
                   
                           ; use xram
02B0: 53 8E E1             anl     auxr,#0xe1      ; clear extram, xrs0-2
02B3: 43 8E 10             orl     auxr,#0x10      ; set xrs2 (size 1792 bytes)
                   
                           ; clear xram with dummy value
02B6: 90 00 00             mov     dptr,#0
                   memory_init__1:
02B9: 74 23                mov     a,#0x23
02BB: F0                   movx    @dptr,a
02BC: A3                   inc     dptr
02BD: 74 07                mov     a,#0x07 ; xram goes up to 0x06ff
02BF: B5 83 F7             cjne    a,dph,memory_init__1
                   
                           ; initialize memory list
02C2: 90 00 00             mov     dptr,#0
02C5: 85 82 38             mov     memory_list,dpl
02C8: 85 83 39             mov     memory_list+1,dph
                           ; list head: pointer to first block
02CB: 74 04                mov     a,#4
02CD: F5 40                mov     memory_start,a
02CF: F0                   movx    @dptr,a
02D0: A3                   inc     dptr
02D1: E4                   clr     a
02D2: F5 41                mov     memory_start+1,a
02D4: F0                   movx    @dptr,a
02D5: A3                   inc     dptr
