04C5                        1  
04C5                        2  ; *** stream/xram_read.inc ***
04C5                        3  
04C5                        4  ; >> char{a} stream_xram_read() <<
04C5                        5  
04C5                        6  ; Read byte from on-chip expanded RAM at stream input pointer.
04C5                        7  ; 16 bit value of the stream pointer is used and incremented.
04C5                        8  
04C5                        9  stream_xram_read:
04C5  C0 8E                10  	push	auxr
04C7  C0 82                11  	push	dpl
04C9  C0 83                12  	push	dph
04CB                       13  
04CB  53 8E E1             14  	anl	auxr,#0xe1	; clear extram, xrs0-2
04CE  43 8E 10             15  	orl	auxr,#0x10	; set xrs2 (size 1792 bytes)
04D1                       16  
04D1  85 34 82             17  	mov	dpl,stream_in
04D4  85 35 83             18  	mov	dph,stream_in+1
04D7                       19  
04D7  E0                   20  	movx	a,@dptr
04D8  A3                   21  	inc	dptr
04D9  85 82 34             22  	mov	stream_in,dpl
04DC  85 83 35             23  	mov	stream_in+1,dph
04DF                       24  
04DF  D0 83                25  	pop	dph
04E1  D0 82                26  	pop	dpl
04E3  D0 8E                27  	pop	auxr
04E5  22                   28  	ret
04E6                       29  
