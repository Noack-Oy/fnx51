011C                      173  .equ panic_out, serial_tx
05AC                      174  .include ../util/panic.inc
                         ; ==== ../util/panic.inc ====
05AC                        1  
05AC                        2  ; *** panic/panic.inc ***
05AC                        3  
05AC                        4  ; >> void panic() <<
05AC                        5  
05AC                        6  ; Unrecoverable error handler.
05AC                        7  ; Print caller address and halt.
05AC                        8  
05AC                        9  panic:
05AC  C2 AF                10  	clr	ea	; disable interrupts
05AE  F8                   11  	mov	r0,a	; save a
05AF                       12  	; display panic text
05AF  90 01 1C             13  	mov	dptr,#panic_out
05B2  85 82 32             14  	mov	out,dpl
05B5  85 83 33             15  	mov	out+1,dph
05B8  90 05 DF             16  	mov	dptr,#panic_text
