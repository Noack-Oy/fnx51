                         ; ==== ../print/hex.inc ====
0480                        1  
0480                        2  ; *** print/hex.inc ***
0480                        3  
0480                        4  ; >> void print_hex_8(char a) <<
0480                        5  
0480                        6  ; Print hexadecimal number from accumulator.
0480                        7  
0480                        8  print_hex_8:
0480  C4                    9  	swap	a	; high nibble first
0481  91 84                10  	acall	print_hex_8__nibble
0483  C4                   11  	swap	a
0484                       12  print_hex_8__nibble:
0484  C0 E0                13  	push	ACC
0486  54 0F                14  	anl	a,	#0x0f
0488  24 90                15  	add	a,	#0x90
048A  D4                   16  	da	a
048B  34 40                17  	addc	a,	#0x40
048D  D4                   18  	da	a
048E  44 20                19  	orl	a,	#0x20	; lower case
0490  91 7B                20  	acall	print_char
0492  D0 E0                21  	pop	ACC
0494  22                   22  	ret
0495                       23  
0495                       24  ; >> void print_hex_16(int r0r1) <<
0495                       25  
0495                       26  ; Print hexadecimal number from r0-r1.
0495                       27  
0495                       28  print_hex_16:
0495  C0 E0                29  	push	ACC
0497  E9                   30  	mov	a,	r1	; MSB first
0498  91 80                31  	acall	print_hex_8
049A  E8                   32  	mov	a,	r0	; LSB second
049B  91 80                33  	acall	print_hex_8
049D  D0 E0                34  	pop	ACC
049F  22                   35  	ret
04A0                       36  
04A0                       37  ; >> void print_hex_32(long r0r1r2r3) <<
04A0                       38  
04A0                       39  ; Print hexadecimal number from r0-r3.
04A0                       40  
04A0                       41  print_hex_32:
04A0  C0 E0                42  	push	ACC
04A2  EB                   43  	mov	a,	r3	; MSB first
04A3  91 80                44  	acall	print_hex_8
04A5  EA                   45  	mov	a,	r2
04A6  91 80                46  	acall	print_hex_8
04A8  E9                   47  	mov	a,	r1
04A9  91 80                48  	acall	print_hex_8
04AB  E8                   49  	mov	a,	r0	; LSB last
04AC  91 80                50  	acall	print_hex_8
04AE  D0 E0                51  	pop	ACC
04B0  22                   52  	ret
04B1                       53  
