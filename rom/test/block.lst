045C                        1  
045C                        2  ; *** block/flush.inc ***
045C                        3  
045C                        4  ; >> void block_flush() <<
045C                        5  
045C                        6  ; Flush the current block. Writes data and clears dirty flag.
045C                        7  
045C                        8  block_flush:
045C  12 05 AC              9  	lcall	panic ; not implemented yet
045F                       10  
                         ; ==== block.asm ====
045F                      163  
045F                      164  .include ../util/delay.inc
                         ; ==== ../util/delay.inc ====
045F                        1  
045F                        2  ; *** util/delay.inc ***
045F                        3  
045F                        4  ; >> void delay_ms_8(uint8{a} duration) <<
045F                        5  
045F                        6  ; 1-256 millisecond delay, duration given in a.
045F                        7  ; Assumes 20MHz clock and X2 mode.
045F                        8  ; Actual delay is slightly longer.
045F                        9  delay_ms_8:
045F                       10  
045F  C0 E0                11  	push	acc
0461  C0 F0                12  	push	b
0463                       13  
0463                       14  	; This loop is repeated a times (256 if a is zero).
0463                       15  	; The goal is to stretch each repeat to one millisecond.
0463                       16  delay_ms_8__loop1:
0463                       17  	; Each millisecond is 20k clock periods.
0463                       18  	; In X2 mode, a machine cycle is 6 clock periods.
0463                       19  	; Therefore, a millisecond is approx. 3334 machine cycles.
0463  75 F0 B9             20  	mov	b,#185	; n = 185	cycles:	  2
0466                       21  delay_ms_8__loop2:
0466  C0 E0                22  	push	acc			; n*2 = 370
0468  C0 F0                23  	push	b			; n*2 = 370
046A  A4                   24  	mul	ab			; n*4 = 740
046B  A4                   25  	mul	ab			; n*4 = 740
046C  D0 F0                26  	pop	b			; n*2 = 370
046E  D0 E0                27  	pop	acc			; n*2 = 370
0470  D5 F0 F3             28  	djnz	b,delay_ms_8__loop2	; n*2 = 370
0473  D5 E0 ED             29  	djnz	acc,delay_ms_8__loop1	;	  2
0476                       30  					; Sum: 3334
0476  D0 F0                31  	pop	b
0478  D0 E0                32  	pop	acc
047A  22                   33  	ret
047B                       34  
