0137                        1  
0137                        2  ; *** sd/init.inc ***
0137                        3  
0137                        4  ; >> uint8{a},uint32{r0-r3} sd_init() <<
0137                        5  
0137                        6  ; Initialize SD card, return error code in a, OCR in r0-r3.
0137                        7  sd_init:
0137                        8  	; r5 is used as temp store for error code
0137  C0 05                 9  	push	5
0139  C0 82                10  	push	dpl
013B  C0 83                11  	push	dph
013D                       12  
013D  75 C3 F1             13  	mov	spcon,#sd_spi_config
0140  12 01 8B             14  	lcall	sd_warmup
0143  12 01 A0             15  	lcall	sd_select
0146                       16  
0146  7D 05                17  	mov	r5,#5	; 5: no idle response to cmd0
0148  12 01 AF             18  	lcall	sd_cmd0
014B  B4 01 35             19  	cjne	a,#1,sd_init__end
014E                       20  
014E  1D                   21  	dec	r5	; 4: no idle response to cmd8
014F  12 01 CF             22  	lcall	sd_cmd8
0152  B4 01 2E             23  	cjne	a,#1,sd_init__end
0155  1D                   24  	dec	r5	; 3: invalid cmd8 response
0156  BB 00 2A             25  	cjne	r3,#0x00,sd_init__end
0159  BA 00 27             26  	cjne	r2,#0x00,sd_init__end
015C  B9 01 24             27  	cjne	r1,#0x01,sd_init__end
015F  B8 AA 21             28  	cjne	r0,#0xaa,sd_init__end
0162                       29  
0162  7D 64                30  	mov	r5,#100	; retry counter
0164                       31  sd_init__loop:
0164  12 01 E4             32  	lcall	sd_acmd41
0167  60 0B                33  	jz	sd_init__continue
0169  74 0A                34  	mov	a,#10
016B  12 04 5F             35  	lcall	delay_ms_8
016E  DD F4                36  	djnz	r5,sd_init__loop
0170  7D 02                37  	mov	r5,#2	; 2: acmd41 ready response timeout
0172  80 0F                38  	sjmp	sd_init__end
0174                       39  
0174                       40  sd_init__continue:
0174  7D 01                41  	mov	r5,#1	; 1: no ready response to cmd58
0176  12 02 2C             42  	lcall	sd_cmd58
0179                       43  
0179  1D                   44  	dec	r5	; 0: success
017A                       45  
017A  90 02 87             46  	mov	dptr,#sd_block_read
017D  85 82 44             47  	mov	block_read,dpl
0180  85 83 45             48  	mov	block_read+1,dph
0183                       49  
0183                       50  sd_init__end:
0183  ED                   51  	mov	a,r5	; error code -> return value
0184  D0 83                52  	pop	dph
0186  D0 82                53  	pop	dpl
0188  D0 05                54  	pop	5
018A  22                   55  	ret
018B                       56  
