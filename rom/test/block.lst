04EB                        1  
04EB                        2  ; *** util/xch.inc ***
04EB                        3  
04EB                        4  ; >> void xch_r0123_r4567(uint32 &r0r1r2r3, uint32 &r4r5r6r7) <<
04EB                        5  
04EB                        6  ; Exchange registers r0-r3 with r4-r7.
04EB                        7  
04EB                        8  xch_r0123_r4567:
04EB                        9  	; r0 <-> r4
04EB  C8                   10  	xch	a,	r0
04EC  CC                   11  	xch	a,	r4
04ED  C8                   12  	xch	a,	r0
04EE                       13  	; r1 <-> r5
04EE  C9                   14  	xch	a,	r1
04EF  CD                   15  	xch	a,	r5
04F0  C9                   16  	xch	a,	r1
04F1                       17  	; r2 <-> r6
04F1  CA                   18  	xch	a,	r2
04F2  CE                   19  	xch	a,	r6
04F3  CA                   20  	xch	a,	r2
04F4                       21  	; r3 <-> r7
04F4  CB                   22  	xch	a,	r3
04F5  CF                   23  	xch	a,	r7
04F6  CB                   24  	xch	a,	r3
04F7                       25  	; a remains unchanged
04F7  22                   26  	ret
04F8                       27  
