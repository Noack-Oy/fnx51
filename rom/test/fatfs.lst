059C                        1  
059C                        2  ; *** fatfs/init.inc ***
059C                        3  
059C                        4  ; >> void fatfs_init() <<
059C                        5  
059C                        6  ; Initialize FAT file system.
059C                        7  ; Search for a valid FAT file system on the current block device.
059C                        8  ; Memory is allocated to store the necessary data to handle the file
059C                        9  ; system, and a pointer to that is put into the fatfs_info variable in
059C                       10  ; internal RAM. Currently only FAT32 on MBR partition 0 is supported.
059C                       11  
059C                       12  fatfs_init:
059C  C0 E0                13  	push	acc
059E  C0 F0                14  	push	b
05A0  C0 82                15  	push	dpl
05A2  C0 83                16  	push	dph
05A4  05 A2                17  	inc	auxr1
05A6  C0 82                18  	push	dpl
05A8  C0 83                19  	push	dph
05AA                       20  	; void function: r0-r7 all preserved
05AA  C0 00                21  	push	0
05AC  C0 01                22  	push	1
05AE  C0 02                23  	push	2
05B0  C0 03                24  	push	3
05B2  C0 04                25  	push	4
05B4  C0 05                26  	push	5
05B6  C0 06                27  	push	6
05B8  C0 07                28  	push	7
05BA                       29  
05BA  A8 15                30  	mov	r0,fatfs_info_size
05BC  79 00                31  	mov	r1,#0
05BE  12 02 FF             32  	lcall	memory_allocate
05C1  85 82 50             33  	mov	fatfs_info,dpl
05C4  85 83 51             34  	mov	fatfs_info+1,dph
05C7                       35  
05C7                       36  	; read sector 0 (MBR)
05C7  E4                   37  	clr	a
05C8  F8                   38  	mov	r0,a
05C9  F9                   39  	mov	r1,a
05CA  FA                   40  	mov	r2,a
05CB  FB                   41  	mov	r3,a
05CC  12 05 4A             42  	lcall	block_load
05CF                       43  
05CF  12 06 C9             44  	lcall	fatfs_init__check_signature
05D2                       45  
05D2                       46  	; partition table begins at offset:	446 = 0x1be
05D2                       47  	; the type code is at that +4:		450 = 0x1c2
05D2  E5 82                48  	mov	a,dpl
05D4  24 C2                49  	add	a,#0xc2
05D6  F5 82                50  	mov	dpl,a
05D8  E5 83                51  	mov	a,dph
05DA  34 01                52  	addc	a,#0x01
05DC  F5 83                53  	mov	dph,a
05DE  E0                   54  	movx	a,@dptr	; read type code
05DF  C3                   55  	clr	c
05E0  94 0B                56  	subb	a,#0x0b
05E2  60 06                57  	jz	fatfs_init__type_code_ok
05E4  14                   58  	dec	a ; also accept 0x0c
05E5  60 03                59  	jz	fatfs_init__type_code_ok
05E7  12 09 B0             60  	lcall	panic ; invalid type code
05EA                       61  fatfs_init__type_code_ok:
05EA                       62  
05EA                       63  	; read partition start LBA at another +4 offset from type code
05EA  A3                   64  	inc	dptr
05EB  A3                   65  	inc	dptr
05EC  A3                   66  	inc	dptr
05ED  A3                   67  	inc	dptr
05EE  05 A2                68  	inc	auxr1
05F0                       69  	; ... and store into fatfs_info (at offset 0)
05F0  85 50 82             70  	mov	dpl,fatfs_info
05F3  85 51 83             71  	mov	dph,fatfs_info+1
05F6  78 04                72  	mov	r0,#4
05F8  12 08 57             73  	lcall	dptr_copy
05FB                       74  
05FB                       75  	; read FAT32 volume ID (first sector in partition)
05FB  85 50 82             76  	mov	dpl,fatfs_info
05FE  85 51 83             77  	mov	dph,fatfs_info+1
0601  12 08 6A             78  	lcall	dptr_read_32
0604  12 05 4A             79  	lcall	block_load
0607                       80  
0607  12 06 C9             81  	lcall	fatfs_init__check_signature
060A                       82  
060A                       83  	; validate bytes per sector (offset 0x0b), must be 512
060A  E5 82                84  	mov	a,dpl
060C  24 0B                85  	add	a,#0x0b
060E  F5 82                86  	mov	dpl,a
0610  E5 83                87  	mov	a,dph
0612  34 00                88  	addc	a,#0x00
0614  F5 83                89  	mov	dph,a
0616  E0                   90  	movx	a,@dptr ; low byte: must be 0x00
0617  60 03                91  	jz	fatfs_init__bps_ok_1
0619  12 09 B0             92  	lcall	panic	; invalid bytes per sector
061C                       93  fatfs_init__bps_ok_1:
061C  A3                   94  	inc	dptr
061D  E0                   95  	movx	a,@dptr ; high byte: must be 0x02
061E  64 02                96  	xrl	a,#0x02
0620  60 03                97  	jz	fatfs_init__bps_ok_2
0622  12 09 B0             98  	lcall	panic	; invalid bytes per sector
0625                       99  fatfs_init__bps_ok_2:
0625  A3                  100  	inc	dptr
0626                      101  
0626                      102  	; read sectors per cluster (offset 0x0d) and validate
0626  E0                  103  	movx	a,@dptr
0627  70 03               104  	jnz	fatfs_init__spc_ok_1
0629  12 09 B0            105  	lcall	panic	; zero sectors per cluster not allowed
062C                      106  fatfs_init__spc_ok_1:
062C  F5 F0               107  	mov	b,a
062E  14                  108  	dec	a
062F  55 F0               109  	anl	a,b	; power of two check: (x & (x-1)) == 0
0631  60 03               110  	jz	fatfs_init__spc_ok_2
0633  12 09 B0            111  	lcall	panic	; sectors per cluster must be power of 2
0636                      112  fatfs_init__spc_ok_2:
0636  E5 F0               113  	mov	a,b	; value in b is also used later below!
0638                      114  	; ... and store into fatfs_info data structure at offset 4
0638  05 A2               115  	inc	auxr1	; switch to other dptr
063A  85 50 82            116  	mov	dpl,fatfs_info
063D  85 51 83            117  	mov	dph,fatfs_info+1
0640  A3                  118  	inc	dptr
0641  A3                  119  	inc	dptr
0642  A3                  120  	inc	dptr
0643  A3                  121  	inc	dptr
0644  F0                  122  	movx	@dptr,a
0645  05 A2               123  	inc	auxr1	; restore original dptr
0647  A3                  124  	inc	dptr
0648                      125  
0648                      126  	; read number of reserved sectors at offset 0x0e
0648  E0                  127  	movx	a,@dptr
0649  FC                  128  	mov	r4,a
064A  A3                  129  	inc	dptr
064B  E0                  130  	movx	a,@dptr
064C  FD                  131  	mov	r5,a
064D  E4                  132  	clr	a
064E  FE                  133  	mov	r6,a
064F  FF                  134  	mov	r7,a
0650  A3                  135  	inc	dptr
0651                      136  	; now calculate fat1_lba = part_lba + reserved_sectors
0651  05 A2               137  	inc	auxr1
0653  85 50 82            138  	mov	dpl,fatfs_info
0656  85 51 83            139  	mov	dph,fatfs_info+1
0659  12 08 6A            140  	lcall	dptr_read_32 ; also moves dptr forward to offset 4
065C  12 07 DD            141  	lcall	add_32
065F                      142  	; and store into fatfs_info data structure at offset 5
065F  A3                  143  	inc	dptr
0660  12 08 7B            144  	lcall	dptr_write_32 ; advances to offset 9
0663  05 A2               145  	inc	auxr1 ; swich back to block read pointer
0665                      146  
0665                      147  	; validate number of FATs at offset 0x10, must always be 2
0665  E0                  148  	movx	a,@dptr
0666  64 02               149  	xrl	a,#0x02
0668  60 03               150  	jz	fatfs_init__nof_ok
066A  12 09 B0            151  	lcall	panic	; invalid number of FATs
066D                      152  fatfs_init__nof_ok:
066D                      153  
066D                      154  	; skip forward to offset 0x24 (+0x14)
066D  E5 82               155  	mov	a,dpl
066F  24 14               156  	add	a,#0x14
0671  F5 82               157  	mov	dpl,a
0673  E5 83               158  	mov	a,dph
0675  34 00               159  	addc	a,#0x00
0677  F5 83               160  	mov	dph,a
0679                      161  
0679                      162  	; r0-r3 still has fat1_lba here from above, shunt into r4-r7
0679  12 08 3C            163  	lcall	xch_r0123_r4567
067C                      164  
067C                      165  	; read sectors per fat at offset 0x24
067C  12 08 6A            166  	lcall	dptr_read_32	; advances to offset 0x28
067F                      167  	; now calculate fat2_lba by adding sectors per FAT to fat1_lba
067F  12 08 3C            168  	lcall	xch_r0123_r4567
0682  12 07 DD            169  	lcall	add_32
0685                      170  	; and store into fatfs_info data structure at offset 9
0685  05 A2               171  	inc	auxr1 ; swich to fatfs_info write pointer
0687  12 08 7B            172  	lcall	dptr_write_32	; advances to offset 13
068A                      173  	; now if we add sectors per FAT again, get cluster_lba
068A  12 07 DD            174  	lcall	add_32
068D                      175  	; however, that is the address of cluster 2,
068D                      176  	; we wind back to the (nonexistent) cluster 0,
068D                      177  	; this makes math easier later
068D  AC F0               178  	mov	r4,b	; b should still have sectors per cluster here
068F  E4                  179  	clr	a
0690  FD                  180  	mov	r5,a
0691  FE                  181  	mov	r6,a
0692  FF                  182  	mov	r7,a
0693  12 07 EE            183  	lcall	sub_32
0696  12 07 EE            184  	lcall	sub_32
0699                      185  	; now we can store cluster_lba at the current offset (13)
0699  12 08 7B            186  	lcall	dptr_write_32 ; advances to offset 17
069C  05 A2               187  	inc	auxr1	; back to the block reading pointer
069E                      188  
069E                      189  	; move forward to offset 0x2c
069E  A3                  190  	inc	dptr
069F  A3                  191  	inc	dptr
06A0  A3                  192  	inc	dptr
06A1  A3                  193  	inc	dptr
06A2                      194  	; now read the cluster number for the root directory
06A2  12 08 6A            195  	lcall	dptr_read_32
06A5                      196  	; ... and store into fatfs_info at current offset (17)
06A5  05 A2               197  	inc	auxr1
06A7  12 08 7B            198  	lcall	dptr_write_32
06AA                      199  
06AA                      200  	; phew! that was a lot of shunting data around. we are done now.
06AA                      201  
06AA  D0 07               202  	pop	7
06AC  D0 06               203  	pop	6
06AE  D0 05               204  	pop	5
06B0  D0 04               205  	pop	4
06B2  D0 03               206  	pop	3
06B4  D0 02               207  	pop	2
06B6  D0 01               208  	pop	1
06B8  D0 00               209  	pop	0
06BA  D0 83               210  	pop	dph
06BC  D0 82               211  	pop	dpl
06BE  05 A2               212  	inc	auxr1
06C0  D0 83               213  	pop	dph
06C2  D0 82               214  	pop	dpl
06C4  D0 F0               215  	pop	b
06C6  D0 E0               216  	pop	acc
06C8  22                  217  	ret
06C9                      218  
06C9                      219  fatfs_init__check_signature:
06C9  E5 82               220  	mov	a,dpl
06CB  24 FE               221  	add	a,#0xfe
06CD  F5 82               222  	mov	dpl,a
06CF  E5 83               223  	mov	a,dph
06D1  34 01               224  	addc	a,#0x01
06D3  F5 83               225  	mov	dph,a
06D5  E0                  226  	movx	a,@dptr ; read fist signature byte at offset 510
06D6  64 55               227  	xrl	a,#0x55
06D8  60 03               228  	jz	fatfs_init__check_signature_ok_1
06DA  12 09 B0            229  	lcall	panic ; invalid signature
06DD                      230  fatfs_init__check_signature_ok_1:
06DD  A3                  231  	inc	dptr
06DE  E0                  232  	movx	a,@dptr ; read second signature byte at offset 511
06DF  64 AA               233  	xrl	a,#0xaa
06E1  60 03               234  	jz	fatfs_init__check_signature_ok_2
06E3  12 09 B0            235  	lcall	panic ; invalid signature
06E6                      236  fatfs_init__check_signature_ok_2:
06E6  A3                  237  	inc	dptr ; this moves dptr to offset 512
06E7  15 83               238  	dec	dph  ; so we can now wind back to the beginning
06E9  15 83               239  	dec	dph  ; by decrementing dph twice
06EB  22                  240  	ret
