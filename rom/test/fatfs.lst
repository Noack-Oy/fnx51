0360: B4 FF 03             cjne    a,#0xff,sd_response1__end       ; success
0363: D5 F0 F6             djnz    b,sd_response1__loop    ; retry / timeout
                   sd_response1__end:
0366: D0 F0                pop     b
0368: 22                   ret
                   
