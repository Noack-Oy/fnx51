                         ; ==== fatfs.asm ====
08FC                      184  .include ../util/dump.inc
                         ; ==== ../util/dump.inc ====
08FC                        1  
08FC                        2  ; *** util/dump.inc ***
08FC                        3  
08FC                        4  ; >> uint32{r0-r3} dump(uint32{r0-r3} addr, uint8{a} count) <<
08FC                        5  
08FC                        6  ; Print hexdump from standard input to standard output.
08FC                        7  ; Starting value for address column in r0-r3.
08FC                        8  ; Number of bytes to print in a (0 means 256).
08FC                        9  ; r0-r3 contains next address upon exit.
08FC                       10  
08FC                       11  dump:
08FC  C0 F0                12  	push	b
08FE  C0 E0                13  	push	acc
0900  F5 F0                14  	mov	b,	a
0902  C0 04                15  	push	4
0904  C0 05                16  	push	5
0906  C0 06                17  	push	6
0908  C0 07                18  	push	7
090A                       19  
090A                       20  	; b: total bytes remaining
090A                       21  	; r0: buffer pointer
090A                       22  	; r1: read loop counter / padding size
090A                       23  	; r2: print loop counter
090A                       24  
090A                       25  	; r4-7: address label
090A  11 3C                26  	acall	xch_r0123_r4567
090C                       27  
090C                       28  	; allocate 16 byte array on stack
090C  E5 81                29  	mov	a,	sp
090E  F8                   30  	mov	r0,	a
090F  24 10                31  	add	a,	#16
0911  F5 81                32  	mov	sp,	a
0913                       33  
0913                       34  dump__line_loop:
0913                       35  	; read into buffer
0913  79 10                36  	mov	r1,	#16
0915                       37  dump__read_loop:
0915  11 F7                38  	acall	read_char
0917  08                   39  	inc	r0
0918  F6                   40  	mov	@r0,	a
0919  D5 F0 03             41  	djnz	b,	dump__read_continue
091C  19                   42  	dec	r1
091D  80 02                43  	sjmp	dump__read_end
091F                       44  dump__read_continue:
091F  D9 F4                45  	djnz	r1,	dump__read_loop
0921                       46  dump__read_end:
0921                       47  
0921                       48  	; print address column
0921  11 3C                49  	acall	xch_r0123_r4567
0923  11 B1                50  	acall	print_hex_32
0925  11 3C                51  	acall	xch_r0123_r4567
0927  74 3A                52  	mov	a,	#':'
0929  11 8C                53  	acall	print_char
092B                       54  
092B                       55  	; if r1 is nonzero here, we have a shorter line
092B                       56  	; the value in r1 is the number of padding bytes
092B                       57  
092B                       58  	; wind back pointer
092B  E8                   59  	mov	a,	r0
092C  24 F0                60  	add	a,	#-16
092E  29                   61  	add	a,	r1
092F  F8                   62  	mov	r0,	a
0930                       63  
0930                       64  	; print hex
0930  7A 10                65  	mov	r2,	#16
0932                       66  dump__print_hex_loop:
