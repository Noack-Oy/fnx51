07DD                      171  
07DD                      172  .include ../math/arith32.inc
                         ; ==== ../math/arith32.inc ====
07DD                        1  
07DD                        2  ; *** math/arith32.inc ***
07DD                        3  
07DD                        4  ; >> uint32{r0-r3} add_32(uint32{r0-r3} x, uint32{r4-r7} y) <<
07DD                        5  
07DD                        6  ; 32 bit addition, x := x + y
07DD                        7  
07DD                        8  add_32:
07DD  C0 E0                 9  	push	acc
07DF                       10  
07DF  E8                   11  	mov	a,r0
07E0  2C                   12  	add	a,r4
07E1  F8                   13  	mov	r0,a
07E2                       14  
07E2  E9                   15  	mov	a,r1
07E3  3D                   16  	addc	a,r5
07E4  F9                   17  	mov	r1,a
07E5                       18  
07E5  EA                   19  	mov	a,r2
07E6  3E                   20  	addc	a,r6
07E7  FA                   21  	mov	r2,a
07E8                       22  
07E8  EB                   23  	mov	a,r3
07E9  3F                   24  	addc	a,r7
07EA  FB                   25  	mov	r3,a
07EB                       26  
07EB  D0 E0                27  	pop	acc
07ED  22                   28  	ret
07EE                       29  
07EE                       30  
07EE                       31  ; >> uint32{r0-r3} sub_32(uint32{r0-r3} x, uint32{r4-r7} y) <<
07EE                       32  
07EE                       33  ; 32 bit subtraction, x := x - y
07EE                       34  
07EE                       35  sub_32:
07EE  C0 E0                36  	push	acc
07F0                       37  
07F0  C3                   38  	clr	c
07F1                       39  
07F1  E8                   40  	mov	a,r0
07F2  9C                   41  	subb	a,r4
07F3  F8                   42  	mov	r0,a
07F4                       43  
07F4  E9                   44  	mov	a,r1
07F5  9D                   45  	subb	a,r5
07F6  F9                   46  	mov	r1,a
07F7                       47  
07F7  EA                   48  	mov	a,r2
07F8  9E                   49  	subb	a,r6
07F9  FA                   50  	mov	r2,a
07FA                       51  
07FA  EB                   52  	mov	a,r3
07FB  9F                   53  	subb	a,r7
07FC  FB                   54  	mov	r3,a
07FD                       55  
07FD  D0 E0                56  	pop	acc
07FF  22                   57  	ret
0800                       58  
0800                       59  
0800                       60  ; >> uint32{r0-r3} shl_32(uint32{r0-r3} value, uint8{a} count) <<
0800                       61  
0800                       62  ; Shift 32-bit value left by count bits (count in a).
0800                       63  ; Equivalent to: value <<= count
0800                       64  
0800                       65  shl_32:
0800  C0 E0                66  	push	acc
0802  C0 F0                67  	push	b
0804                       68  
0804  F5 F0                69  	mov	b,a			; shift count to b for loop counter
0806                       70  shl_32__loop:
0806  E5 F0                71  	mov	a,b
0808  60 11                72  	jz	shl_32__done		; when b==0, done
080A  15 F0                73  	dec	b			; decrement shift counter
080C                       74  	
080C                       75  	; Shift r0-r3 left by 1 position
080C  C3                   76  	clr	c
080D  E8                   77  	mov	a,r0
080E  33                   78  	rlc	a
080F  F8                   79  	mov	r0,a
0810  E9                   80  	mov	a,r1
0811  33                   81  	rlc	a
0812  F9                   82  	mov	r1,a
0813  EA                   83  	mov	a,r2
0814  33                   84  	rlc	a
0815  FA                   85  	mov	r2,a
0816  EB                   86  	mov	a,r3
0817  33                   87  	rlc	a
0818  FB                   88  	mov	r3,a
0819  80 EB                89  	sjmp	shl_32__loop
081B                       90  
081B                       91  shl_32__done:
081B  D0 F0                92  	pop	b
081D  D0 E0                93  	pop	acc
081F  22                   94  	ret
0820                       95  
