                         ; ==== ../print/hex.inc ====
0891                        1  
0891                        2  ; *** print/hex.inc ***
0891                        3  
0891                        4  ; >> void print_hex_8(char a) <<
0891                        5  
0891                        6  ; Print hexadecimal number from accumulator.
0891                        7  
0891                        8  print_hex_8:
0891  C4                    9  	swap	a	; high nibble first
0892  11 95                10  	acall	print_hex_8__nibble
0894  C4                   11  	swap	a
0895                       12  print_hex_8__nibble:
0895  C0 E0                13  	push	ACC
0897  54 0F                14  	anl	a,	#0x0f
0899  24 90                15  	add	a,	#0x90
089B  D4                   16  	da	a
089C  34 40                17  	addc	a,	#0x40
089E  D4                   18  	da	a
089F  44 20                19  	orl	a,	#0x20	; lower case
08A1  11 8C                20  	acall	print_char
08A3  D0 E0                21  	pop	ACC
08A5  22                   22  	ret
08A6                       23  
08A6                       24  ; >> void print_hex_16(int r0r1) <<
08A6                       25  
08A6                       26  ; Print hexadecimal number from r0-r1.
08A6                       27  
08A6                       28  print_hex_16:
08A6  C0 E0                29  	push	ACC
08A8  E9                   30  	mov	a,	r1	; MSB first
08A9  11 91                31  	acall	print_hex_8
08AB  E8                   32  	mov	a,	r0	; LSB second
08AC  11 91                33  	acall	print_hex_8
08AE  D0 E0                34  	pop	ACC
08B0  22                   35  	ret
08B1                       36  
08B1                       37  ; >> void print_hex_32(long r0r1r2r3) <<
08B1                       38  
08B1                       39  ; Print hexadecimal number from r0-r3.
08B1                       40  
08B1                       41  print_hex_32:
08B1  C0 E0                42  	push	ACC
08B3  EB                   43  	mov	a,	r3	; MSB first
08B4  11 91                44  	acall	print_hex_8
08B6  EA                   45  	mov	a,	r2
08B7  11 91                46  	acall	print_hex_8
08B9  E9                   47  	mov	a,	r1
08BA  11 91                48  	acall	print_hex_8
08BC  E8                   49  	mov	a,	r0	; LSB last
08BD  11 91                50  	acall	print_hex_8
08BF  D0 E0                51  	pop	ACC
08C1  22                   52  	ret
08C2                       53  
