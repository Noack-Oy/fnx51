0000                        5  
0000                        6  .equ	fatfs_info_part_lba,	0;..3	LBA where partition begins
0004                        7  .equ	fatfs_info_cluster_size,4;	number of sectors per cluster
0005                        8  .equ	fatfs_info_fat1_lba,	5;..8	LBA where FAT#1 begins
0009                        9  .equ	fatfs_info_fat2_lba,	9;..12	LBA where FAT#2 begins
000D                       10  .equ	fatfs_info_cluster_lba,	13;..16	LBA of theoretical cluster #0
0000                       11  ; NOTE: Clusters #0 and #1 do not exist. The first valid cluster is #2.
0011                       12  .equ	fatfs_info_root_dir,	17;..20	cluster # of root directory
0015                       13  .equ	fatfs_info_size,	21
