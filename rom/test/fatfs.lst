08F7                        2  ; *** read/char.inc ***
08F7                        3  
08F7                        4  ; >> char read_char() <<
08F7                        5  
08F7                        6  ; Read char into accumulator.
08F7                        7  ; Indirect call to function behind IN pointer.
08F7                        8  
08F7                        9  read_char:
08F7  C0 30                10  	push	IN
08F9  C0 31                11  	push	IN+1
08FB  22                   12  	ret
