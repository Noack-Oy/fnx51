                         ; ==== ../stream/xram_read.inc ====
08D6                        1  
08D6                        2  ; *** stream/xram_read.inc ***
08D6                        3  
08D6                        4  ; >> char{a} stream_xram_read() <<
08D6                        5  
08D6                        6  ; Read byte from on-chip expanded RAM at stream input pointer.
08D6                        7  ; 16 bit value of the stream pointer is used and incremented.
08D6                        8  
08D6                        9  stream_xram_read:
08D6  C0 8E                10  	push	auxr
08D8  C0 82                11  	push	dpl
08DA  C0 83                12  	push	dph
08DC                       13  
08DC  53 8E E1             14  	anl	auxr,#0xe1	; clear extram, xrs0-2
08DF  43 8E 10             15  	orl	auxr,#0x10	; set xrs2 (size 1792 bytes)
08E2                       16  
08E2  85 34 82             17  	mov	dpl,stream_in
08E5  85 35 83             18  	mov	dph,stream_in+1
08E8                       19  
08E8  E0                   20  	movx	a,@dptr
08E9  A3                   21  	inc	dptr
08EA  85 82 34             22  	mov	stream_in,dpl
08ED  85 83 35             23  	mov	stream_in+1,dph
08F0                       24  
08F0  D0 83                25  	pop	dph
08F2  D0 82                26  	pop	dpl
08F4  D0 8E                27  	pop	auxr
08F6  22                   28  	ret
08F7                       29  
