03E0                        4  ; >> void memory_release(char *{dptr} addr, uint16{r0r1} size) <<
03E0                        5  
03E0                        6  ; Release a previously allocated block. `addr` must be the pointer
03E0                        7  ; returned by memory_allocate, `size` the same value passed to it.
03E0                        8  
03E0                        9  memory_release:
03E0  C0 A8                10  	push	ie
