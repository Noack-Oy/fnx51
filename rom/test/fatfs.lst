                         ; ==== fatfs.asm ====
06EC                      169  .include ../fatfs/cluster.inc
                         ; ==== ../fatfs/cluster.inc ====
06EC                        1  
06EC                        2  ; *** fatfs/cluster.inc ***
06EC                        3  
06EC                        4  ; >> uint32{r0-r3} fatfs_cluster_to_lba(uint32{r0-r3} cluster) <<
06EC                        5  
06EC                        6  ; Convert cluster number to first sector LBA.
06EC                        7  ; Uses the formula: LBA = cluster_lba + (cluster * cluster_size)
06EC                        8  ; Note: cluster_lba is already adjusted for theoretical cluster #0,
06EC                        9  ; so no subtraction of 2 is needed.
06EC                       10  
06EC                       11  fatfs_cluster_to_lba:
06EC  C0 E0                12  	push	acc
06EE  C0 F0                13  	push	b
06F0  C0 82                14  	push	dpl
06F2  C0 83                15  	push	dph
06F4  C0 04                16  	push	4
06F6  C0 05                17  	push	5
06F8  C0 06                18  	push	6
06FA  C0 07                19  	push	7
06FC                       20  
06FC                       21  	; Load cluster_size from fatfs_info+4
06FC  85 50 82             22  	mov	dpl,fatfs_info
06FF  85 51 83             23  	mov	dph,fatfs_info+1
0702  74 04                24  	mov	a,#fatfs_info_cluster_size
0704  12 08 49             25  	lcall	dptr_index
0707  E0                   26  	movx	a,@dptr
0708  F5 F0                27  	mov	b,a			; b = cluster_size
070A                       28  
070A                       29  	; Calculate log2 of cluster_size by counting right shifts until we get 1
070A                       30  	; cluster_size must be a power of 2 (1, 2, 4, 8, 16, 32, 64, 128)
070A  E5 F0                31  	mov	a,b			; a = cluster_size
070C  7C 00                32  	mov	r4,#0			; shift count starts at 0
070E                       33  fatfs_cluster_to_lba__count_loop:
070E  B4 01 02             34  	cjne	a,#0x01,fatfs_cluster_to_lba__not_one
0711  80 0C                35  	sjmp	fatfs_cluster_to_lba__shifts_counted
0713                       36  fatfs_cluster_to_lba__not_one:
0713  60 07                37  	jz	fatfs_cluster_to_lba__bad_size	; zero is invalid
0715  C3                   38  	clr	c
0716  13                   39  	rrc	a			; right shift by 1
0717  40 03                40  	jc	fatfs_cluster_to_lba__bad_size	; not a power of 2 if carry set
0719  0C                   41  	inc	r4			; increment shift count
071A  80 F2                42  	sjmp	fatfs_cluster_to_lba__count_loop
071C                       43  fatfs_cluster_to_lba__bad_size:
071C                       44  	; Invalid cluster size (not a power of 2)
071C  12 09 B0             45  	lcall	panic
071F                       46  
071F                       47  fatfs_cluster_to_lba__shifts_counted:
071F                       48  	; Now r4 has the shift count
071F                       49  	; Shift r0-r3 left by r4 positions (cluster * cluster_size)
071F  EC                   50  	mov	a,r4
0720  12 08 00             51  	lcall	shl_32
0723                       52  
0723                       53  	; r0-r3 now contains cluster * cluster_size
0723                       54  	; Now we need to add cluster_lba from fatfs_info+13
0723                       55  	; Move shifted cluster to r4-r7
0723  12 08 3C             56  	lcall	xch_r0123_r4567
0726                       57  
0726                       58  	; Load cluster_lba into r0-r3
0726  85 50 82             59  	mov	dpl,fatfs_info
0729  85 51 83             60  	mov	dph,fatfs_info+1
072C  74 0D                61  	mov	a,#fatfs_info_cluster_lba
072E  12 08 49             62  	lcall	dptr_index
0731  12 08 6A             63  	lcall	dptr_read_32		; r0-r3 = cluster_lba
0734                       64  
0734                       65  	; Add cluster offset: r0-r3 += r4-r7
0734  12 07 DD             66  	lcall	add_32
0737                       67  
0737  D0 07                68  	pop	7
0739  D0 06                69  	pop	6
073B  D0 05                70  	pop	5
073D  D0 04                71  	pop	4
073F  D0 83                72  	pop	dph
0741  D0 82                73  	pop	dpl
0743  D0 F0                74  	pop	b
0745  D0 E0                75  	pop	acc
0747  22                   76  	ret
0748                       77  
                         ; ==== fatfs.asm ====
0748                      170  .include ../fatfs/chain.inc
                         ; ==== ../fatfs/chain.inc ====
0748                        1  
0748                        2  ; *** fatfs/chain.inc ***
0748                        3  
0748                        4  ; A "chain handle" abstracts cluster-chain traversal. Directories and
0748                        5  ; files both look like a linear sequence of 512-byte blocks; the handle
0748                        6  ; owns the state needed to map a relative block number to an LBA.
0748                        7  ;
0748                        8  ; See chain.equ for the layout (first cluster, current cluster).
0748                        9  ;
0748                       10  ; Lifecycle convention (mirrored by dir and file handles, which extend
0748                       11  ; the chain handle by adding fields after fatfs_chain_size):
0748                       12  ;
0748                       13  ;   *_init   — initialize a pre-allocated struct. No allocation.
0748                       14  ;   *_deinit — release sub-resources. No deallocation. Pairs with _init.
0748                       15  ;   *_open   — convenience: memory_allocate + _init. Standalone use.
0748                       16  ;   *_close  — convenience: _deinit + memory_release. Standalone use.
0748                       17  ;
0748                       18  ; Extension types call only _init / _deinit on the chain prefix; they
0748                       19  ; own the outer allocation themselves.
0748                       20  
0748                       21  
0748                       22  ; >> void fatfs_chain_init(char *{dptr} handle, uint32{r0-r3} first_cluster) <<
0748                       23  
0748                       24  ; Initialize a pre-allocated chain handle at dptr with first and
0748                       25  ; current cluster both set to first_cluster. Preserves dptr and r0-r3.
0748                       26  
0748                       27  fatfs_chain_init:
0748  C0 82                28  	push	dpl
074A  C0 83                29  	push	dph
074C                       30  
074C  12 08 7B             31  	lcall	dptr_write_32	; handle[first] = first_cluster
074F  12 08 7B             32  	lcall	dptr_write_32	; handle[current] = first_cluster
0752                       33  
0752  D0 83                34  	pop	dph
0754  D0 82                35  	pop	dpl
0756  22                   36  	ret
0757                       37  
0757                       38  
0757                       39  ; >> void fatfs_chain_deinit(char *{dptr} handle) <<
0757                       40  
0757                       41  ; Release sub-resources held by the chain handle. Currently a no-op;
0757                       42  ; declared so extension types can call it unconditionally.
0757                       43  
0757                       44  fatfs_chain_deinit:
0757  22                   45  	ret
0758                       46  
0758                       47  
0758                       48  ; >> char *{dptr} fatfs_chain_open(uint32{r0-r3} first_cluster) <<
0758                       49  
0758                       50  ; Allocate a chain handle on the heap and initialize it with
0758                       51  ; first_cluster. Returns a pointer to the handle in dptr.
0758                       52  
0758                       53  fatfs_chain_open:
0758  C0 00                54  	push	0
075A  C0 01                55  	push	1
075C                       56  
075C  78 08                57  	mov	r0,#fatfs_chain_size
075E  79 00                58  	mov	r1,#0
0760  12 02 FF             59  	lcall	memory_allocate	; dptr = handle, r0-r7 preserved
0763                       60  
0763  D0 01                61  	pop	1
0765  D0 00                62  	pop	0
0767                       63  	; r0-r3 hold the caller's first_cluster again (memory_allocate
0767                       64  	; preserved r2-r3 across the call; r0r1 we restored above).
0767  12 07 48             65  	lcall	fatfs_chain_init
076A  22                   66  	ret
076B                       67  
076B                       68  
076B                       69  ; >> void fatfs_chain_close(char *{dptr} handle) <<
076B                       70  
076B                       71  ; Deinitialize a chain handle and free its allocation.
076B                       72  
076B                       73  fatfs_chain_close:
076B  C0 00                74  	push	0
076D  C0 01                75  	push	1
076F                       76  
076F  12 07 57             77  	lcall	fatfs_chain_deinit
0772  78 08                78  	mov	r0,#fatfs_chain_size
0774  79 00                79  	mov	r1,#0
0776  12 03 E0             80  	lcall	memory_release
0779                       81  
0779  D0 01                82  	pop	1
077B  D0 00                83  	pop	0
077D  22                   84  	ret
077E                       85  
077E                       86  
077E                       87  ; >> char *{dptr'} fatfs_chain_ensure_block(char *{dptr} handle, uint32{r0-r3} block) <<
077E                       88  
077E                       89  ; Make sure the chain's `block`-th 512-byte block is loaded in the
077E                       90  ; block cache, and return a borrowed dptr to the cached data in dptr'
077E                       91  ; (the alternate data pointer). dptr (the handle) is preserved so
077E                       92  ; callers don't have to stash it across the call.
077E                       93  ;
077E                       94  ; Borrowed: valid only until the next block_load (e.g. another
077E                       95  ; ensure_block call on any chain). Caller must copy out what it needs
077E                       96  ; and not retain the pointer.
077E                       97  ;
077E                       98  ; Step 1 stub: only block == 0 is supported. Real traversal lands when
077E                       99  ; the first caller needs to follow a chain past its first cluster, at
077E                      100  ; which point fatfs_chain_next_cluster joins this file too.
077E                      101  
077E                      102  fatfs_chain_ensure_block:
077E  C0 E0               103  	push	acc
0780  C0 00               104  	push	0			; preserve r0-r3 (input, not output)
0782  C0 01               105  	push	1
0784  C0 02               106  	push	2
0786  C0 03               107  	push	3
0788  C0 82               108  	push	dpl			; preserve dptr (handle) for the caller
078A  C0 83               109  	push	dph
078C                      110  
078C                      111  	; verify block == 0 (stub limitation)
078C  E8                  112  	mov	a,r0
078D  49                  113  	orl	a,r1
078E  4A                  114  	orl	a,r2
078F  4B                  115  	orl	a,r3
0790  60 03               116  	jz	fatfs_chain_ensure_block__zero
0792  12 09 B0            117  	lcall	panic	; chain traversal not implemented yet
0795                      118  fatfs_chain_ensure_block__zero:
0795                      119  
0795                      120  	; read first cluster number from handle[first] into r0-r3.
0795  12 08 6A            121  	lcall	dptr_read_32
0798                      122  
0798                      123  	; convert cluster number to first sector LBA
0798  12 06 EC            124  	lcall	fatfs_cluster_to_lba
079B                      125  
079B                      126  	; load that block into the alternate dptr so the caller's dptr
079B                      127  	; (= handle) survives. We switch slots, block_load writes the
079B                      128  	; cached pointer into the now-active slot, then we switch back.
079B  05 A2               129  	inc	auxr1
079D  12 05 4A            130  	lcall	block_load	; dptr' (now active) = cached
07A0  05 A2               131  	inc	auxr1		; back to the caller's slot
07A2                      132  
07A2  D0 83               133  	pop	dph
07A4  D0 82               134  	pop	dpl
07A6  D0 03               135  	pop	3
07A8  D0 02               136  	pop	2
07AA  D0 01               137  	pop	1
07AC  D0 00               138  	pop	0
07AE  D0 E0               139  	pop	acc
07B0  22                  140  	ret
07B1                      141  
07B1                      142  
07B1                      143  ; >> void fatfs_chain_load_block(char *{dptr} handle, uint32{r0-r3} block, char *{dptr'} dst) <<
07B1                      144  
07B1                      145  ; Convenience wrapper that loads a chain block into the caller's own
07B1                      146  ; 512-byte buffer (passed as dst in the alternate dptr). Built on
07B1                      147  ; fatfs_chain_ensure_block plus a 512-byte memcpy.
07B1                      148  ;
07B1                      149  ; May not see callers in practice — dir-iter and file-read both prefer
07B1                      150  ; ensure_block so they can copy only the bytes they actually need.
07B1                      151  
07B1                      152  fatfs_chain_load_block:
07B1  C0 00               153  	push	0			; dptr_copy uses r0 as count
07B3                      154  
07B3                      155  	; Save handle (slot 0). ensure_block preserves it, but we'll
07B3                      156  	; temporarily overwrite slot 0 with dst to feed dptr_copy; need
07B3                      157  	; the handle back at exit.
07B3  C0 82               158  	push	dpl
07B5  C0 83               159  	push	dph
07B7                      160  
07B7                      161  	; Save dst (slot 1) — ensure_block will overwrite it with the
07B7                      162  	; cached pointer.
07B7  05 A2               163  	inc	auxr1
07B9  C0 82               164  	push	dpl
07BB  C0 83               165  	push	dph
07BD  05 A2               166  	inc	auxr1
07BF                      167  
07BF                      168  	; ensure_block leaves slot 0 = handle (preserved) and slot 1 =
07BF                      169  	; cached (the borrowed pointer). dst is on the stack.
07BF  12 07 7E            170  	lcall	fatfs_chain_ensure_block
07C2                      171  
07C2                      172  	; Pop dst into slot 0 (overwriting handle for now). Stack top is
07C2                      173  	; dst.dph; below: dst.dpl; below: handle.dph, handle.dpl.
07C2  D0 83               174  	pop	dph
07C4  D0 82               175  	pop	dpl
07C6                      176  	; slot 0 = dst, slot 1 = cached.
07C6                      177  
07C6                      178  	; dptr_copy with r0 = 0 copies 256 bytes (djnz wraps). Twice = 512.
07C6  78 00               179  	mov	r0,#0
07C8  12 08 57            180  	lcall	dptr_copy
07CB  78 00               181  	mov	r0,#0
07CD  12 08 57            182  	lcall	dptr_copy
07D0                      183  	; slot 0 = dst+512, slot 1 = cached+512.
07D0                      184  
07D0                      185  	; Restore dst (slot 0): two `dec dph` subtract 512 (dpl rolled
07D0                      186  	; around an even number of times during the 512 inc dptrs).
07D0  15 83               187  	dec	dph
07D2  15 83               188  	dec	dph
07D4                      189  
07D4                      190  	; Pop the saved handle into slot 1. The slots end up physically
07D4                      191  	; swapped relative to entry (slot 0 = dst, slot 1 = handle), but
07D4                      192  	; the calling convention only cares about `dptr` and `dptr'`
07D4                      193  	; holding the right values, not which physical slot they live in.
07D4  05 A2               194  	inc	auxr1
07D6  D0 83               195  	pop	dph
07D8  D0 82               196  	pop	dpl
07DA                      197  	; active (slot 1) = handle, inactive (slot 0) = dst.
07DA                      198  
07DA  D0 00               199  	pop	0
07DC  22                  200  	ret
07DD                      201  
