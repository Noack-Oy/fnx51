001D                       28  
001D  12 01 00             29  	lcall	serial_init
0020  12 02 B1             30  	lcall	memory_init
0023  12 01 37             31  	lcall	sd_init
0026  60 03                32  	jz	__1
0028  12 09 B0             33  	lcall	panic ; sd init error
002B                       34  __1:
002B  12 05 1D             35  	lcall	block_init
002E                       36  
002E  90 00 BE             37  	mov	dptr,#ok_string
0031  12 08 C2             38  	lcall	print_text
0034                       39  
0034                       40  	; this is where the interesting part starts
0034  12 05 9C             41  	lcall	fatfs_init
0037                       42  
0037                       43  	; dump fatfs_info data structure
0037                       44  
0037  85 50 34             45  	mov	stream_in,fatfs_info
003A  85 51 35             46  	mov	stream_in+1,fatfs_info+1
003D  E4                   47  	clr	a
003E  F8                   48  	mov	r0,a
003F  F9                   49  	mov	r1,a
0040  FA                   50  	mov	r2,a
0041  FB                   51  	mov	r3,a
0042  90 08 D6             52  	mov	dptr,#stream_xram_read
0045  85 82 30             53  	mov	in,dpl
0048  85 83 31             54  	mov	in+1,dph
004B  74 15                55  	mov	a,#fatfs_info_size
004D  12 08 FC             56  	lcall	dump
0050                       57  
0050  90 00 C0             58  	mov	dptr,#newline
0053  12 08 C2             59  	lcall	print_text
0056                       60  
0056                       61  	; Load root directory cluster (from fatfs_info+17) into r0-r3
0056  85 50 82             62  	mov	dpl,fatfs_info
0059  85 51 83             63  	mov	dph,fatfs_info+1
005C  74 11                64  	mov	a,#fatfs_info_root_dir
005E  12 08 49             65  	lcall	dptr_index
0061                       66  	; now dptr points to fatfs_info + offset 17 (root directory cluster)
0061  12 08 6A             67  	lcall	dptr_read_32
0064                       68  	; r0-r3 now contains the root cluster number - print it to verify
0064  12 08 B1             69  	lcall	print_hex_32
0067  90 00 C0             70  	mov	dptr,#newline
006A  12 08 C2             71  	lcall	print_text
006D                       72  	; now call cluster_to_lba with this value
006D  12 06 EC             73  	lcall	fatfs_cluster_to_lba
0070  12 08 B1             74  	lcall	print_hex_32
0073  90 00 C0             75  	mov	dptr,#newline
0076  12 08 C2             76  	lcall	print_text
0079                       77  
0079                       78  	; *** chain handle exercise ***
0079                       79  	; open a chain on the root directory cluster, ensure block 0
0079                       80  	; (the first sector of the root dir) is loaded, dump the first
0079                       81  	; 32 bytes of it (one directory entry), close the chain.
0079                       82  
0079                       83  	; reload the root cluster number into r0-r3
0079  85 50 82             84  	mov	dpl,fatfs_info
007C  85 51 83             85  	mov	dph,fatfs_info+1
007F  74 11                86  	mov	a,#fatfs_info_root_dir
0081  12 08 49             87  	lcall	dptr_index
0084  12 08 6A             88  	lcall	dptr_read_32
0087                       89  
0087                       90  	; open chain; dptr = handle on return
0087  12 07 58             91  	lcall	fatfs_chain_open
008A                       92  
008A                       93  	; ensure block 0 of the chain is loaded. ensure_block preserves
008A                       94  	; the handle in dptr and returns the borrowed cached pointer in
008A                       95  	; dptr'.
008A  E4                   96  	clr	a
008B  F8                   97  	mov	r0,a
008C  F9                   98  	mov	r1,a
008D  FA                   99  	mov	r2,a
008E  FB                  100  	mov	r3,a
008F  12 07 7E            101  	lcall	fatfs_chain_ensure_block
0092                      102  
0092                      103  	; Read cached pointer out of dptr' into stream_in, then reuse
0092                      104  	; the same slot to load the read helper for dump. dptr (handle)
0092                      105  	; survives throughout.
0092  05 A2               106  	inc	auxr1
0094  85 82 34            107  	mov	stream_in,dpl
0097  85 83 35            108  	mov	stream_in+1,dph
009A  90 08 D6            109  	mov	dptr,#stream_xram_read
009D  85 82 30            110  	mov	in,dpl
00A0  85 83 31            111  	mov	in+1,dph
00A3  05 A2               112  	inc	auxr1
00A5                      113  
00A5  E4                  114  	clr	a
00A6  F8                  115  	mov	r0,a
00A7  F9                  116  	mov	r1,a
00A8  FA                  117  	mov	r2,a
00A9  FB                  118  	mov	r3,a
00AA  74 20               119  	mov	a,#32
00AC  12 08 FC            120  	lcall	dump
00AF                      121  
00AF                      122  	; print_text wants its string pointer in the active dptr; park
00AF                      123  	; the immediate in dptr' so the handle in dptr survives.
00AF  05 A2               124  	inc	auxr1
00B1  90 00 C0            125  	mov	dptr,#newline
00B4  12 08 C2            126  	lcall	print_text
00B7  05 A2               127  	inc	auxr1
00B9                      128  
00B9  12 07 6B            129  	lcall	fatfs_chain_close
00BC                      130  
00BC                      131  halt:
00BC  80 FE               132  	sjmp	halt
