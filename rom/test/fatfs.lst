054A                        2  ; *** block/load.inc ***
054A                        3  
054A                        4  ; >> char *{dptr}block_load(uint32{r0-r3} block_address) <<
054A                        5  
054A                        6  ; Load a block into memory if necessary, return pointer to data.
054A                        7  ; If the requested block is already cached, no read is done.
054A                        8  ; Loading a block makes all previously returned data pointers invalid.
054A                        9  ; Effectively, only the most recently loaded block is guaranteed to be
054A                       10  ; present in memory, and is called the "current" block.
054A                       11  ; If the current block is dirty and needs to be evicted from memory,
054A                       12  ; it is flushed automatically before loading another one.
054A                       13  
054A                       14  block_load:
054A  C0 E0                15  	push	acc
054C  C0 04                16  	push	4
054E  C0 05                17  	push	5
0550                       18  
0550  85 48 82             19  	mov	dpl,block_cache
0553  85 49 83             20  	mov	dph,block_cache+1
0556                       21  
0556                       22  	; compare requested address with current
0556  E0                   23  	movx	a,@dptr
0557  A3                   24  	inc	dptr
0558  68                   25  	xrl	a,r0
0559  70 12                26  	jnz	block_load__do_read_1
055B                       27  
055B  E0                   28  	movx	a,@dptr
055C  A3                   29  	inc	dptr
055D  69                   30  	xrl	a,r1
055E  70 0E                31  	jnz	block_load__do_read_2
0560                       32  
0560  E0                   33  	movx	a,@dptr
0561  A3                   34  	inc	dptr
0562  6A                   35  	xrl	a,r2
0563  70 0A                36  	jnz	block_load__do_read_3
0565                       37  
0565  E0                   38  	movx	a,@dptr
0566  A3                   39  	inc	dptr
0567  6B                   40  	xrl	a,r3
0568  70 06                41  	jnz	block_load__do_read_4
056A                       42  
056A                       43  	; requested block is already cached
056A  A3                   44  	inc	dptr ; skip dirty flag, points to data now
056B  80 20                45  	sjmp	block_load__end
056D                       46  
056D                       47  block_load__do_read_1:
056D  A3                   48  	inc	dptr
056E                       49  block_load__do_read_2:
056E  A3                   50  	inc	dptr
056F                       51  block_load__do_read_3:
056F  A3                   52  	inc	dptr
0570                       53  block_load__do_read_4:
0570                       54  
0570                       55  	; check dirty flag:
0570  E0                   56  	movx	a,@dptr
0571  A3                   57  	inc	dptr
0572  60 02                58  	jz	block_load__do_read_5
0574  B1 99                59  	acall	block_flush
0576                       60  
0576                       61  block_load__do_read_5:
0576  B1 94                62  	acall	block_load__read_icall
0578                       63  	; TODO: check CRC (r4-r5)
0578                       64  
0578                       65  	; save current block address
0578  85 48 82             66  	mov	dpl,block_cache
057B  85 49 83             67  	mov	dph,block_cache+1
057E  E8                   68  	mov	a,r0
057F  F0                   69  	movx	@dptr,a
0580  A3                   70  	inc	dptr
0581  E9                   71  	mov	a,r1
0582  F0                   72  	movx	@dptr,a
0583  A3                   73  	inc	dptr
0584  EA                   74  	mov	a,r2
0585  F0                   75  	movx	@dptr,a
0586  A3                   76  	inc	dptr
0587  EB                   77  	mov	a,r3
0588  F0                   78  	movx	@dptr,a
0589  A3                   79  	inc	dptr
058A                       80  	; clear dirty flag
058A  E4                   81  	clr	a
058B  F0                   82  	movx	@dptr,a
058C  A3                   83  	inc	dptr
058D                       84  	; dptr points to loaded block data now
058D                       85  
058D                       86  block_load__end:
058D  D0 05                87  	pop	5
058F  D0 04                88  	pop	4
0591  D0 E0                89  	pop	acc
0593  22                   90  	ret
0594                       91  
