0849                        1  
0849                        2  ; *** util/dptr.inc ***
0849                        3  
0849                        4  ; >> void dptr_index(char *{dptr}&base, uint8{a} offset) <<
0849                        5  
0849                        6  ; Add offset in a to dptr, preserving all registers including a.
0849                        7  ; Useful for accessing structure fields at known offsets.
0849                        8  
0849                        9  dptr_index:
0849  C0 E0                10  	push	acc
084B  25 82                11  	add	a,dpl
084D  F5 82                12  	mov	dpl,a
084F  E4                   13  	clr	a
0850  35 83                14  	addc	a,dph
0852  F5 83                15  	mov	dph,a
0854  D0 E0                16  	pop	acc
0856  22                   17  	ret
0857                       18  
0857                       19  
0857                       20  ; >> void dptr_copy(uint8{r0} n, char *{dptr} &dst, char *{dptr'} &src) <<
0857                       21  
0857                       22  ; Use dual data pointers to copy n (given in r0) bytes to dst (initial
0857                       23  ; dptr) from src (other dptr). In the end both pointers point to the
0857                       24  ; first dst/src bytes after the copied blocks.
0857                       25  
0857                       26  dptr_copy:
0857  C0 E0                27  	push	acc
0859  C0 00                28  	push	0
085B                       29  
085B                       30  dptr_copy__loop:
085B  05 A2                31  	inc	auxr1
085D  E0                   32  	movx	a,@dptr
085E  A3                   33  	inc	dptr
085F  05 A2                34  	inc	auxr1
0861  F0                   35  	movx	@dptr,a
0862  A3                   36  	inc	dptr
0863  D8 F6                37  	djnz	r0,dptr_copy__loop
0865                       38  
0865  D0 00                39  	pop	0
0867  D0 E0                40  	pop	acc
0869  22                   41  	ret
086A                       42  
086A                       43  
086A                       44  ; >> uint32{r0-r3} dptr_read_32(uint32 *{dptr}&addr) <<
086A                       45  
086A                       46  ; Read 32 bit value into r0-r3 via movx from @dptr.
086A                       47  ; Data pointer is returned in advanced position (first byte after).
086A                       48  
086A                       49  dptr_read_32:
086A  C0 E0                50  	push	acc
086C                       51  
086C  E0                   52  	movx	a,@dptr
086D  F8                   53  	mov	r0,a
086E  A3                   54  	inc	dptr
086F                       55  
086F  E0                   56  	movx	a,@dptr
0870  F9                   57  	mov	r1,a
0871  A3                   58  	inc	dptr
0872                       59  
0872  E0                   60  	movx	a,@dptr
0873  FA                   61  	mov	r2,a
0874  A3                   62  	inc	dptr
0875                       63  
0875  E0                   64  	movx	a,@dptr
0876  FB                   65  	mov	r3,a
0877  A3                   66  	inc	dptr
0878                       67  
0878  D0 E0                68  	pop	acc
087A  22                   69  	ret
087B                       70  
087B                       71  
087B                       72  ; >> void dptr_write_32(uint32 *{dptr}&addr, uint32{r0-r3} value <<
087B                       73  
087B                       74  ; Write 32 bit value from r0-r3 via movx to @dptr.
087B                       75  ; Data pointer is returned in advanced position (first byte after).
087B                       76  
087B                       77  dptr_write_32:
087B  C0 E0                78  	push	acc
087D                       79  
087D  E8                   80  	mov	a,r0
087E  F0                   81  	movx	@dptr,a
087F  A3                   82  	inc	dptr
0880                       83  
0880  E9                   84  	mov	a,r1
0881  F0                   85  	movx	@dptr,a
0882  A3                   86  	inc	dptr
0883                       87  
0883  EA                   88  	mov	a,r2
0884  F0                   89  	movx	@dptr,a
0885  A3                   90  	inc	dptr
0886                       91  
0886  EB                   92  	mov	a,r3
0887  F0                   93  	movx	@dptr,a
0888  A3                   94  	inc	dptr
0889                       95  
0889  D0 E0                96  	pop	acc
088B  22                   97  	ret
