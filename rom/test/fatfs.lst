052D  85 82 48             18  	mov	block_cache,dpl
0530  85 83 49             19  	mov	block_cache+1,dph
0533  E5 FF                20  	mov	a,0xff
0535  F0                   21  	movx	@dptr,a	; invalid current block address (0xffffffff)
0536  A3                   22  	inc	dptr
0537  F0                   23  	movx	@dptr,a
0538  A3                   24  	inc	dptr
0539  F0                   25  	movx	@dptr,a
053A  A3                   26  	inc	dptr
053B  F0                   27  	movx	@dptr,a
053C  A3                   28  	inc	dptr
