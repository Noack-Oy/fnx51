                   
                   ; ***************************************
                   ; * FAT File System Device Test Program *
                   ; ***************************************
                   
                   ; This program tests the FAT file system implementation.
                   
                   
                   ; **********************
                   ; * Header Definitions *
                   ; **********************
                   
                   ; *** global/variables.equ ***
                   
                   ; variables in internal RAM
                   
                   ; 0x00-0x1f: register banks 0-3
                   ; 0x20-0x2f: bit addressable variables
                   
0000:              .equ    in,             0x30    ; pointer to input handling 
0000:              .equ    out,            0x32    ; pointer to ouput handling 
                   
0000:              .equ    stream_in,      0x34    ; input stream position
0000:              .equ    stream_out,     0x36    ; output stream position
                   
0000:              .equ    memory_list,    0x38    ; pointer to heap list head
0000:              .equ    memory_start,   0x40    ; first allocatable address
0000:              .equ    memory_end,     0x42    ; last allocatable address
                   
0000:              .equ    block_read,     0x44    ; pointers to block device d
0000:              .equ    block_write,    0x46    ; code (read and write funct
0000:              .equ    block_cache,    0x48    ; pointer to block cache dat
                   
0000:              .equ    fatfs_info,     0x50    ; pointer to FAT file system
                   
0000:              .equ    stack,          0x60    ; beginning of stack (grows 
                   
                   ; *** global/sfr.equ ***
                   
                   ; global SFRs
                   
0000:              .equ    auxr,   0x8e    ; auxiliary register 0
0000:              .equ    auxr1,  0xa2    ; auxiliary register 1
                   
                   ; *** serial/sfr.equ ***
                   
                   ; Special function registers for serial interface.
                   ; See chapter 14 of AT89C51ED2 datasheet, page 48ff.
                   
                   ; Internal Baud Rate Generator (BRG), see datasheet page 52.
0000:                      .equ    BRL,    0x9A    ; baud rate reload value
0000:                      .equ    BDRCON, 0x9B    ; BRG control register
                   
                   ; *** spi/sfr.equ ***
                   
                   ; Special function registers for serial peripheral interface
                   ; See chapter 16 of AT89C51ED2 datasheet
                   
0000:              .equ    spcon,  0xc3    ; Serial Peripheral Control Register
0000:              .equ    spsta,  0xc4    ; Serial Peripheral Status Register
0000:              .equ    spdat,  0xc5    ; Serial Peripheral Data Register
                   
                   ; *** sd/config.equ ***
                   
                   ; SPCON register configuration for SD card:
                   ; .-----.-------.-------.-----------------------------------
                   ; | bit | name  | value | remark                            
                   ; |-----|-------|-------|-----------------------------------
                   ; | 7   | SPR2  | 1     | SPR2:0 = 101-> Fclk_periph / 64   
                   ; | 6   | SPEN  | 1     | Set to enable the SPI             
                   ; | 5   | SSDIS | 1     | Set to disable /SS input          
                   ; | 4   | MSTR  | 1     | Set to configure the SPI as a mast
                   ; | 3   | CPOL  | 0     | Cleared to have SCK idle at '0'   
                   ; | 2   | CPHA  | 0     | Cleared to sample on leading edge 
                   ; | 1   | SPR1  | 0     | (see above)                       
                   ; | 0   | SPR0  | 1     | (see above)   speed: 312.5 kHz    
                   ; '-----'-------'-------'-----------------------------------
                   
0000:              .equ    sd_spi_config,  0xf1
                   
0000:              .flag   sd_pin_cs,      p1.1
                   
                   ; *** fatfs/info.equ ***
                   
                   ; offsets for fatfs_info data structure
                   
0000:              .equ    fatfs_info_part_lba,    0;..3   LBA where partition 
0000:              .equ    fatfs_info_cluster_size,4;      number of sectors pe
0000:              .equ    fatfs_info_fat1_lba,    5;..8   LBA where FAT#1 begi
0000:              .equ    fatfs_info_fat2_lba,    9;..12  LBA where FAT#2 begi
0000:              .equ    fatfs_info_cluster_lba, 13;..16 LBA of theoretical c
                   ; NOTE: Clusters #0 and #1 do not exist. The first valid clu
0000:              .equ    fatfs_info_root_dir,    17;..20 cluster # of root di
0000:              .equ    fatfs_info_size,        21
                   
                   ; *** fatfs/chain.equ ***
                   
                   ; offsets for the chain handle data structure (see chain.inc
                   ; Extension types (dir, file) add their own fields after fat
                   
0000:              .equ    fatfs_chain_first,      0;..3   first cluster number
0000:              .equ    fatfs_chain_current,    4;..7   current cluster numb
0000:              .equ    fatfs_chain_size,       8
                   
                   ; *************
                   ; * Main Code *
                   ; *************
                   
                   ; *** test/fatfs.asm ***
                   
0000:              .org    0
                   
                   ; *** global/init.inc ***
                   
                   ; Initialize stack pointer and global variables.
                   ; This must be included early in the main program.
                   
                   global_init:
0000: 75 81 60             mov     SP,#STACK
                   
                   ; Select register bank zero, clear processor flags
0003: 75 D0 00             mov     PSW,#0
                   
                   ; Fill internal RAM with markers for uninitialized data
0006: 78 00                mov     r0,#0 ; write pointer
                   
0008: 74 3F                mov     a,#0x3f ; '?' for uninitialized registers
                   global_init__1:
000A: 08                   inc     r0 ; first iteration skips address 0, r0 liv
000B: F6                   mov     @r0,a
000C: B8 1F FB             cjne    r0,#0x1f,global_init__1
                   
000F: 74 2A                mov     a,#0x2a ; '*' for uninitialized variables
                   global_init__2:
0011: 08                   inc     r0
0012: F6                   mov     @r0,a
0013: B8 5F FB             cjne    r0,#STACK-1,global_init__2
                   
0016: 74 7E                mov     a,#0x7e ; '~' for stack and above
                   global_init__3:
0018: 08                   inc     r0
0019: F6                   mov     @r0,a
001A: B8 FF FB             cjne    r0,#0xff,global_init__3
                   
001D: 12 02 00             lcall   serial_init
0020: 12 03 B1             lcall   memory_init
0023: 12 02 37             lcall   sd_init
0026: 60 03                jz      __1
0028: 12 0B FF             lcall   panic ; sd init error
                   __1:
002B: 12 06 1D             lcall   block_init
                   
002E: 90 00 FC             mov     dptr,#ok_string
0031: 12 0B 11             lcall   print_text
                   
                           ; this is where the interesting part starts
0034: 12 06 9C             lcall   fatfs_init
                   
                           ; dump fatfs_info data structure
                   
0037: 85 50 34             mov     stream_in,fatfs_info
003A: 85 51 35             mov     stream_in+1,fatfs_info+1
003D: E4                   clr     a
003E: F8                   mov     r0,a
003F: F9                   mov     r1,a
0040: FA                   mov     r2,a
0041: FB                   mov     r3,a
0042: 90 0B 25             mov     dptr,#stream_xram_read
0045: 85 82 30             mov     in,dpl
0048: 85 83 31             mov     in+1,dph
004B: 74 15                mov     a,#fatfs_info_size
004D: 12 0B 4B             lcall   dump
                   
0050: 90 00 FE             mov     dptr,#newline
0053: 12 0B 11             lcall   print_text
                   
                           ; Load root directory cluster (from fatfs_info+17) i
0056: 85 50 82             mov     dpl,fatfs_info
0059: 85 51 83             mov     dph,fatfs_info+1
005C: 74 11                mov     a,#fatfs_info_root_dir
005E: 12 0A 98             lcall   dptr_index
                           ; now dptr points to fatfs_info + offset 17 (root di
0061: 12 0A B9             lcall   dptr_read_32
                           ; r0-r3 now contains the root cluster number - print
0064: 12 0B 00             lcall   print_hex_32
0067: 90 00 FE             mov     dptr,#newline
006A: 12 0B 11             lcall   print_text
                           ; now call cluster_to_lba with this value
006D: 12 07 EC             lcall   fatfs_cluster_to_lba
0070: 12 0B 00             lcall   print_hex_32
0073: 90 00 FE             mov     dptr,#newline
0076: 12 0B 11             lcall   print_text
                   
                           ; *** chain handle exercise ***
                           ; open a chain on the root directory cluster, ensure
                           ; (the first sector of the root dir) is loaded, dump
                           ; 32 bytes of it (one directory entry), close the ch
                   
                           ; reload the root cluster number into r0-r3
0079: 85 50 82             mov     dpl,fatfs_info
007C: 85 51 83             mov     dph,fatfs_info+1
007F: 74 11                mov     a,#fatfs_info_root_dir
0081: 12 0A 98             lcall   dptr_index
0084: 12 0A B9             lcall   dptr_read_32
                   
                           ; open chain; dptr = handle on return
0087: 12 08 58             lcall   fatfs_chain_open
                   
                           ; ensure block 0 of the chain is loaded. ensure_bloc
                           ; the handle in dptr and returns the borrowed cached
                           ; dptr'.
008A: E4                   clr     a
008B: F8                   mov     r0,a
008C: F9                   mov     r1,a
008D: FA                   mov     r2,a
008E: FB                   mov     r3,a
008F: 12 08 7E             lcall   fatfs_chain_ensure_block
                   
                           ; Read cached pointer out of dptr' into stream_in, t
                           ; the same slot to load the read helper for dump. dp
                           ; survives throughout.
0092: 05 A2                inc     auxr1
0094: 85 82 34             mov     stream_in,dpl
0097: 85 83 35             mov     stream_in+1,dph
009A: 90 0B 25             mov     dptr,#stream_xram_read
009D: 85 82 30             mov     in,dpl
00A0: 85 83 31             mov     in+1,dph
00A3: 05 A2                inc     auxr1
                   
00A5: E4                   clr     a
00A6: F8                   mov     r0,a
00A7: F9                   mov     r1,a
00A8: FA                   mov     r2,a
00A9: FB                   mov     r3,a
00AA: 74 20                mov     a,#32
00AC: 12 0B 4B             lcall   dump
                   
                           ; print_text wants its string pointer in the active 
                           ; the immediate in dptr' so the handle in dptr survi
00AF: 05 A2                inc     auxr1
00B1: 90 00 FE             mov     dptr,#newline
00B4: 12 0B 11             lcall   print_text
00B7: 05 A2                inc     auxr1
                   
00B9: 12 08 6B             lcall   fatfs_chain_close
                   
                           ; *** dir iterator exercise ***
                           ; open a dir iterator on the root cluster, dump each
                           ; entry until end-of-directory, close.
                   
00BC: 85 50 82             mov     dpl,fatfs_info
00BF: 85 51 83             mov     dph,fatfs_info+1
00C2: 74 11                mov     a,#fatfs_info_root_dir
00C4: 12 0A 98             lcall   dptr_index
00C7: 12 0A B9             lcall   dptr_read_32
00CA: 12 09 12             lcall   fatfs_dir_open          ; dptr = dir handle
                   
                   dir_loop:
                           ; dir_next preserves dptr (handle in dptr), returns 
                           ; and entry pointer in dptr'.
00CD: 12 09 58             lcall   fatfs_dir_next
00D0: 70 25                jnz     dir_done
                   
                           ; Swap dptr roles so the dump / print_text below can
                           ; active dptr freely while the handle hides in dptr'
                           ; is contractually required to preserve dptr', so we
                           ; handle back with a second swap before looping.
00D2: 05 A2                inc     auxr1
00D4: 85 82 34             mov     stream_in,dpl           ; (active = entry bu
00D7: 85 83 35             mov     stream_in+1,dph
                   
00DA: E4                   clr     a
00DB: F8                   mov     r0,a
00DC: F9                   mov     r1,a
00DD: FA                   mov     r2,a
00DE: FB                   mov     r3,a
00DF: 90 0B 25             mov     dptr,#stream_xram_read
00E2: 85 82 30             mov     in,dpl
00E5: 85 83 31             mov     in+1,dph
00E8: 74 20                mov     a,#32
00EA: 12 0B 4B             lcall   dump
                   
00ED: 90 00 FE             mov     dptr,#newline
00F0: 12 0B 11             lcall   print_text
                   
00F3: 05 A2                inc     auxr1                   ; swap back: active 
00F5: 80 D6                sjmp    dir_loop
                   
                   dir_done:
00F7: 12 09 41             lcall   fatfs_dir_close
                   
                   halt:
00FA: 80 FE                sjmp    halt
                   
                   ok_string:
00FC: 4F 4B                .db     "OK" 
                   newline: 
00FE: 0D 0A 00             .db     13, 10, 0
                   
0200:              .org    0x0200
                   
                   ; *********************
                   ; * Library Functions *
                   ; *********************
                   
                   ; *** serial/init.inc ***
                   
                   ; >> void serial_init() <<
                   
                   ; Initialize serial interface.
                   ; - assumes 20MHz clock and X2 mode
                   ; - uses internal baud rate generator
                   ; - speed: 9600 bits per second
                   ; Formula: BRL = 256 - (F_clk / (32 * Baud_Rate))
                   ; ---
                   ; See datasheet page 52 for details,
                   ; also note oscillator diagram on page 16!
                   
                   serial_init:
0200: 75 98 52             mov     SCON,   #0x52   ; SM1, REN, TI
0203: 75 9A BF             mov     BRL,    #191    ; 9600 @20MHz CLK
0206: 75 9B 1E             mov     BDRCON, #0x1e   ; BRR, RBCK, TBCK, SPD
                   
0209: 90 02 24             mov     dptr,   #serial_rx
020C: 85 82 30             mov     IN,     DPL
020F: 85 83 31             mov     IN+1,   DPH
                   
0212: 90 02 1C             mov     dptr,   #serial_tx
0215: 85 82 32             mov     OUT,    DPL
0218: 85 83 33             mov     OUT+1,  DPH
                   
021B: 22                   ret
                   
                   ; *** serial/tx.inc ***
                   
                   ; >> void serial_tx(char a) <<
                   
                   ; Transmit byte from accumulator.
                   
                   serial_tx:
021C: 30 99 FD             jnb     TI,     serial_tx
021F: C2 99                clr     TI
0221: F5 99                mov     SBUF,   a
0223: 22                   ret
                   
                   ; *** serial/rx.inc ***
                   
                   ; >> char serial_rx <<
                   
                   ; Receive byte into accumulator.
                   
                   serial_rx:
0224: 30 98 FD             jnb     RI,     serial_rx
0227: C2 98                clr     RI
0229: E5 99                mov     a,      SBUF
022B: 22                   ret
                   
                   
                   ; *** spi/transfer.inc ***
                   
                   ; >> char{a} serial_transfer(char{a} data) <<
                   
                   ; SPI transfer function: send byte from a, read response int
                   
                   spi_transfer:
022C: F5 C5                mov     spdat,a
                   
                   spi_transfer__wait:
022E: E5 C4                mov     a,spsta
0230: 54 80                anl     a,#0x80 ;check SPIF bit
0232: 60 FA                jz      spi_transfer__wait
                   
0234: E5 C5                mov     a,spdat
0236: 22                   ret
                   
                   ; *** sd/init.inc ***
                   
                   ; >> uint8{a},uint32{r0-r3} sd_init() <<
                   
                   ; Initialize SD card, return error code in a, OCR in r0-r3.
                   sd_init:
                           ; r5 is used as temp store for error code
0237: C0 05                push    5
0239: C0 82                push    dpl
023B: C0 83                push    dph
                   
023D: 75 C3 F1             mov     spcon,#sd_spi_config
0240: 12 02 8B             lcall   sd_warmup
0243: 12 02 A0             lcall   sd_select
                   
0246: 7D 05                mov     r5,#5   ; 5: no idle response to cmd0
0248: 12 02 AF             lcall   sd_cmd0
024B: B4 01 35             cjne    a,#1,sd_init__end
                   
024E: 1D                   dec     r5      ; 4: no idle response to cmd8
024F: 12 02 CF             lcall   sd_cmd8
0252: B4 01 2E             cjne    a,#1,sd_init__end
0255: 1D                   dec     r5      ; 3: invalid cmd8 response
0256: BB 00 2A             cjne    r3,#0x00,sd_init__end
0259: BA 00 27             cjne    r2,#0x00,sd_init__end
025C: B9 01 24             cjne    r1,#0x01,sd_init__end
025F: B8 AA 21             cjne    r0,#0xaa,sd_init__end
                   
0262: 7D 64                mov     r5,#100 ; retry counter
                   sd_init__loop:
0264: 12 02 E4             lcall   sd_acmd41
0267: 60 0B                jz      sd_init__continue
0269: 74 0A                mov     a,#10
026B: 12 0A 6F             lcall   delay_ms_8
026E: DD F4                djnz    r5,sd_init__loop
0270: 7D 02                mov     r5,#2   ; 2: acmd41 ready response timeout
0272: 80 0F                sjmp    sd_init__end
                   
                   sd_init__continue:
0274: 7D 01                mov     r5,#1   ; 1: no ready response to cmd58
0276: 12 03 2C             lcall   sd_cmd58
                   
0279: 1D                   dec     r5      ; 0: success
                   
027A: 90 03 87             mov     dptr,#sd_block_read
027D: 85 82 44             mov     block_read,dpl
0280: 85 83 45             mov     block_read+1,dph
                   
                   sd_init__end:
0283: ED                   mov     a,r5    ; error code -> return value
0284: D0 83                pop     dph
0286: D0 82                pop     dpl
0288: D0 05                pop     5
028A: 22                   ret
                   
                   ; *** sd/warmup.inc ***
                   
                   ; >> void sd_warmup() <<
                   
                   ; send 80 warmup pulses to sclk while cs is high
                   sd_warmup:
028B: C0 E0                push    acc
028D: C0 F0                push    b
028F: D2 91                setb    sd_pin_cs ; p1.1
0291: 75 F0 0A             mov     b,#10
                   sd_warmup_loop:
