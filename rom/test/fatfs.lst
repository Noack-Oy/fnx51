09B0                        4  ; >> void panic() <<
09B0                        5  
09B0                        6  ; Unrecoverable error handler.
09B0                        7  ; Print caller address and halt.
09B0                        8  
09B0                        9  panic:
09B0  C2 AF                10  	clr	ea	; disable interrupts
09B2  F8                   11  	mov	r0,a	; save a
09B3                       12  	; display panic text
09B3  90 01 1C             13  	mov	dptr,#panic_out
09B6  85 82 32             14  	mov	out,dpl
09B9  85 83 33             15  	mov	out+1,dph
09BC  90 09 E3             16  	mov	dptr,#panic_text
09BF  11 C2                17  	acall	print_text
09C1                       18  	; get return address from stack
09C1  D0 E0                19  	pop	acc
09C3  FA                   20  	mov	r2,a
09C4  D0 E0                21  	pop	acc
09C6                       22  	; subtract two to get call instruction address
09C6  C3                   23  	clr	c
09C7  94 02                24  	subb	a,#2
09C9  F9                   25  	mov	r1,a
09CA  EA                   26  	mov	a,r2
09CB  94 00                27  	subb	a,#0
