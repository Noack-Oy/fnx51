                   ; *** sd/command.inc ***
                   
                   ; >> void sd_command(uint8{a} cmd, uint32{r0-r3} arg, uint8{
                   
                   ; Issue a command to the SD card
                   sd_command:
033D: C0 E0                push    acc
                           ; transmit command
033F: 44 40                orl     a,#0x40 ; transmission bit
0341: 51 2C                acall   spi_transfer
                           ; transmit argument
0343: EB                   mov     a,r3
0344: 51 2C                acall   spi_transfer
0346: EA                   mov     a,r2
0347: 51 2C                acall   spi_transfer
0349: E9                   mov     a,r1
034A: 51 2C                acall   spi_transfer
034C: E8                   mov     a,r0
034D: 51 2C                acall   spi_transfer
                           ; transmit crc
034F: EC                   mov     a,r4
0350: 44 01                orl     a,#0x01 ; end bit
0352: 51 2C                acall   spi_transfer
0354: D0 E0                pop     acc
0356: 22                   ret
                   
                   ; *** sd/response.inc ***
                   
