01A0                      151  .include ../sd/select.inc
                         ; ==== ../sd/select.inc ====
01A0                        1  
01A0                        2  ; *** sd/select.inc ***
01A0                        3  
01A0                        4  ; >> void sd_select() <<
01A0                        5  
01A0                        6  ; Activate the SD card
01A0                        7  sd_select:
01A0  C0 E0                 8  	push	acc
01A2  74 FF                 9  	mov	a,#0xff
01A4  31 2C                10  	acall	spi_transfer
01A6  C2 91                11  	clr	sd_pin_cs
01A8  74 FF                12  	mov	a,#0xff
01AA  31 2C                13  	acall	spi_transfer
01AC  D0 E0                14  	pop	acc
01AE  22                   15  	ret
