0820                      173  
0820                      174  .include ../util/delay.inc
                         ; ==== ../util/delay.inc ====
0820                        1  
0820                        2  ; *** util/delay.inc ***
0820                        3  
0820                        4  ; >> void delay_ms_8(uint8{a} duration) <<
0820                        5  
0820                        6  ; 1-256 millisecond delay, duration given in a.
0820                        7  ; Assumes 20MHz clock and X2 mode.
0820                        8  ; Actual delay is slightly longer.
0820                        9  delay_ms_8:
0820                       10  
0820  C0 E0                11  	push	acc
0822  C0 F0                12  	push	b
0824                       13  
0824                       14  	; This loop is repeated a times (256 if a is zero).
0824                       15  	; The goal is to stretch each repeat to one millisecond.
0824                       16  delay_ms_8__loop1:
0824                       17  	; Each millisecond is 20k clock periods.
0824                       18  	; In X2 mode, a machine cycle is 6 clock periods.
0824                       19  	; Therefore, a millisecond is approx. 3334 machine cycles.
0824  75 F0 B9             20  	mov	b,#185	; n = 185	cycles:	  2
0827                       21  delay_ms_8__loop2:
0827  C0 E0                22  	push	acc			; n*2 = 370
0829  C0 F0                23  	push	b			; n*2 = 370
082B  A4                   24  	mul	ab			; n*4 = 740
082C  A4                   25  	mul	ab			; n*4 = 740
082D  D0 F0                26  	pop	b			; n*2 = 370
082F  D0 E0                27  	pop	acc			; n*2 = 370
0831  D5 F0 F3             28  	djnz	b,delay_ms_8__loop2	; n*2 = 370
0834  D5 E0 ED             29  	djnz	acc,delay_ms_8__loop1	;	  2
0837                       30  					; Sum: 3334
0837  D0 F0                31  	pop	b
0839  D0 E0                32  	pop	acc
083B  22                   33  	ret
083C                       34  
                         ; ==== fatfs.asm ====
083C                      175  .include ../util/xch.inc
                         ; ==== ../util/xch.inc ====
083C                        1  
083C                        2  ; *** util/xch.inc ***
083C                        3  
083C                        4  ; >> void xch_r0123_r4567(uint32 &r0r1r2r3, uint32 &r4r5r6r7) <<
083C                        5  
083C                        6  ; Exchange registers r0-r3 with r4-r7.
083C                        7  
083C                        8  xch_r0123_r4567:
083C                        9  	; r0 <-> r4
083C  C8                   10  	xch	a,	r0
083D  CC                   11  	xch	a,	r4
083E  C8                   12  	xch	a,	r0
083F                       13  	; r1 <-> r5
083F  C9                   14  	xch	a,	r1
0840  CD                   15  	xch	a,	r5
0841  C9                   16  	xch	a,	r1
0842                       17  	; r2 <-> r6
0842  CA                   18  	xch	a,	r2
0843  CE                   19  	xch	a,	r6
0844  CA                   20  	xch	a,	r2
0845                       21  	; r3 <-> r7
0845  CB                   22  	xch	a,	r3
0846  CF                   23  	xch	a,	r7
0847  CB                   24  	xch	a,	r3
0848                       25  	; a remains unchanged
0848  22                   26  	ret
0849                       27  
