047F  A3                  140  	inc	dptr	; prev->size
0480  E0                  141  	movx	a,@dptr ; -.
0481  28                  142  	add	a,r0	;  |- += size
0482  F0                  143  	movx	@dptr,a ;  |
0483  A3                  144  	inc	dptr	;  |
0484  E0                  145  	movx	a,@dptr ;  |
0485  39                  146  	addc	a,r1	;  |
0486  F0                  147  	movx	@dptr,a ; -'
0487  EE                  148  	mov	a,r6	; -.
0488  FA                  149  	mov	r2,a	;  |- block = prev
0489  EF                  150  	mov	a,r7	;  |
048A  FB                  151  	mov	r3,a	; -'
048B  80 1D               152  	sjmp	memory_release__10
