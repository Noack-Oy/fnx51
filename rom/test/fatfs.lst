03E4                       12  
03E4  C0 E0                13  	push	acc
03E6  C0 82                14  	push	dpl
03E8  C0 83                15  	push	dph
03EA                       16  
03EA                       17  	; void function: r0-r7 all preserved
03EA  C0 00                18  	push	0
03EC  C0 01                19  	push	1
03EE  C0 02                20  	push	2
03F0  C0 03                21  	push	3
03F2  C0 04                22  	push	4
03F4  C0 05                23  	push	5
03F6  C0 06                24  	push	6
03F8  C0 07                25  	push	7
03FA                       26  
03FA                       27  	; copy address from dptr into r2r3 for the body's use;
03FA                       28  	; size stays in r0r1 (where the caller put it)
03FA  AA 82                29  	mov	r2,dpl
03FC  AB 83                30  	mov	r3,dph
03FE                       31  
03FE                       32  	; r0r1: size, r2r3: block addr;
03FE                       33  	; r6r7 takes over the prev-pointer role during the list walk.
03FE                       34  
