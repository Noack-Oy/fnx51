08C2                        1  
08C2                        2  ; *** print/text.inc ***
08C2                        3  
08C2                        4  ; >> void print_text(char* dptr) <<
08C2                        5  
08C2                        6  ; Print null-terminated string from program code.
08C2                        7  ; Aborts if no null terminator is found after 256 bytes.
08C2                        8  
08C2                        9  print_text:
08C2  C0 E0                10  	push	ACC
08C4  C0 00                11  	push	0
08C6                       12  
08C6  E4                   13  	clr	a
08C7  F8                   14  	mov	r0,	a
08C8                       15  print_text__loop:
08C8  93                   16  	movc	a,	@a+dptr
08C9  60 06                17  	jz	print_text__end
08CB  11 8C                18  	acall	print_char
08CD  08                   19  	inc	r0
08CE  E8                   20  	mov	a,	r0
08CF  70 F7                21  	jnz	print_text__loop
08D1                       22  
08D1                       23  print_text__end:
08D1  D0 00                24  	pop	0
08D3  D0 E0                25  	pop	ACC
08D5  22                   26  	ret
08D6                       27  
