                   
                   ; ***************************************
                   ; * FAT File System Device Test Program *
                   ; ***************************************
                   
                   ; This program tests the FAT file system implementation.
                   
                   
                   ; **********************
                   ; * Header Definitions *
                   ; **********************
                   
                   ; *** global/variables.equ ***
                   
                   ; variables in internal RAM
                   
                   ; 0x00-0x1f: register banks 0-3
                   ; 0x20-0x2f: bit addressable variables
                   
0000:              .equ    in,             0x30    ; pointer to input handling 
0000:              .equ    out,            0x32    ; pointer to ouput handling 
                   
0000:              .equ    stream_in,      0x34    ; input stream position
0000:              .equ    stream_out,     0x36    ; output stream position
                   
0000:              .equ    memory_list,    0x38    ; pointer to heap list head
0000:              .equ    memory_start,   0x40    ; first allocatable address
0000:              .equ    memory_end,     0x42    ; last allocatable address
                   
0000:              .equ    block_read,     0x44    ; pointers to block device d
0000:              .equ    block_write,    0x46    ; code (read and write funct
0000:              .equ    block_cache,    0x48    ; pointer to block cache dat
                   
0000:              .equ    fatfs_info,     0x50    ; pointer to FAT file system
                   
0000:              .equ    stack,          0x60    ; beginning of stack (grows 
                   
                   ; *** global/sfr.equ ***
                   
                   ; global SFRs
                   
0000:              .equ    auxr,   0x8e    ; auxiliary register 0
0000:              .equ    auxr1,  0xa2    ; auxiliary register 1
                   
                   ; *** serial/sfr.equ ***
                   
                   ; Special function registers for serial interface.
                   ; See chapter 14 of AT89C51ED2 datasheet, page 48ff.
                   
                   ; Internal Baud Rate Generator (BRG), see datasheet page 52.
0000:                      .equ    BRL,    0x9A    ; baud rate reload value
0000:                      .equ    BDRCON, 0x9B    ; BRG control register
                   
                   ; *** spi/sfr.equ ***
                   
                   ; Special function registers for serial peripheral interface
                   ; See chapter 16 of AT89C51ED2 datasheet
                   
0000:              .equ    spcon,  0xc3    ; Serial Peripheral Control Register
0000:              .equ    spsta,  0xc4    ; Serial Peripheral Status Register
0000:              .equ    spdat,  0xc5    ; Serial Peripheral Data Register
                   
                   ; *** sd/config.equ ***
                   
                   ; SPCON register configuration for SD card:
                   ; .-----.-------.-------.-----------------------------------
                   ; | bit | name  | value | remark                            
                   ; |-----|-------|-------|-----------------------------------
                   ; | 7   | SPR2  | 1     | SPR2:0 = 101-> Fclk_periph / 64   
                   ; | 6   | SPEN  | 1     | Set to enable the SPI             
                   ; | 5   | SSDIS | 1     | Set to disable /SS input          
                   ; | 4   | MSTR  | 1     | Set to configure the SPI as a mast
                   ; | 3   | CPOL  | 0     | Cleared to have SCK idle at '0'   
                   ; | 2   | CPHA  | 0     | Cleared to sample on leading edge 
                   ; | 1   | SPR1  | 0     | (see above)                       
                   ; | 0   | SPR0  | 1     | (see above)   speed: 312.5 kHz    
                   ; '-----'-------'-------'-----------------------------------
                   
0000:              .equ    sd_spi_config,  0xf1
                   
0000:              .flag   sd_pin_cs,      p1.1
                   
                   ; *** fatfs/info.equ ***
                   
                   ; offsets for fatfs_info data structure
                   
0000:              .equ    fatfs_info_part_lba,    0;..3   LBA where partition 
0000:              .equ    fatfs_info_cluster_size,4;      number of sectors pe
0000:              .equ    fatfs_info_fat1_lba,    5;..8   LBA where FAT#1 begi
0000:              .equ    fatfs_info_fat2_lba,    9;..12  LBA where FAT#2 begi
0000:              .equ    fatfs_info_cluster_lba, 13;..16 LBA of theoretical c
                   ; NOTE: Clusters #0 and #1 do not exist. The first valid clu
0000:              .equ    fatfs_info_root_dir,    17;..20 cluster # of root di
0000:              .equ    fatfs_info_size,        21
                   
                   ; *** fatfs/chain.equ ***
                   
                   ; offsets for the chain handle data structure (see chain.inc
                   ; Extension types (dir, file) add their own fields after fat
                   
0000:              .equ    fatfs_chain_first,      0;..3   first cluster number
0000:              .equ    fatfs_chain_current,    4;..7   current cluster numb
0000:              .equ    fatfs_chain_size,       8
                   
                   ; *************
                   ; * Main Code *
                   ; *************
                   
                   ; *** test/fatfs.asm ***
                   
0000:              .org    0
                   
                   ; *** global/init.inc ***
                   
                   ; Initialize stack pointer and global variables.
                   ; This must be included early in the main program.
                   
                   global_init:
0000: 75 81 60             mov     SP,#STACK
                   
                   ; Select register bank zero, clear processor flags
0003: 75 D0 00             mov     PSW,#0
                   
                   ; Fill internal RAM with markers for uninitialized data
0006: 78 00                mov     r0,#0 ; write pointer
                   
0008: 74 3F                mov     a,#0x3f ; '?' for uninitialized registers
                   global_init__1:
000A: 08                   inc     r0 ; first iteration skips address 0, r0 liv
000B: F6                   mov     @r0,a
000C: B8 1F FB             cjne    r0,#0x1f,global_init__1
                   
000F: 74 2A                mov     a,#0x2a ; '*' for uninitialized variables
                   global_init__2:
0011: 08                   inc     r0
0012: F6                   mov     @r0,a
0013: B8 5F FB             cjne    r0,#STACK-1,global_init__2
                   
0016: 74 7E                mov     a,#0x7e ; '~' for stack and above
                   global_init__3:
0018: 08                   inc     r0
0019: F6                   mov     @r0,a
001A: B8 FF FB             cjne    r0,#0xff,global_init__3
                   
001D: 12 01 00             lcall   serial_init
0020: 12 02 B1             lcall   memory_init
0023: 12 01 37             lcall   sd_init
0026: 60 03                jz      __1
0028: 12 09 A2             lcall   panic ; sd init error
                   __1:
002B: 12 05 1D             lcall   block_init
                   
002E: 90 00 C4             mov     dptr,#ok_string
0031: 12 08 B4             lcall   print_text
                   
                           ; this is where the interesting part starts
0034: 12 05 9C             lcall   fatfs_init
                   
                           ; dump fatfs_info data structure
                   
0037: 85 50 34             mov     stream_in,fatfs_info
003A: 85 51 35             mov     stream_in+1,fatfs_info+1
003D: E4                   clr     a
003E: F8                   mov     r0,a
003F: F9                   mov     r1,a
0040: FA                   mov     r2,a
0041: FB                   mov     r3,a
0042: 90 08 C8             mov     dptr,#stream_xram_read
0045: 85 82 30             mov     in,dpl
0048: 85 83 31             mov     in+1,dph
004B: 74 15                mov     a,#fatfs_info_size
004D: 12 08 EE             lcall   dump
                   
0050: 90 00 C6             mov     dptr,#newline
0053: 12 08 B4             lcall   print_text
                   
                           ; Load root directory cluster (from fatfs_info+17) i
0056: 85 50 82             mov     dpl,fatfs_info
0059: 85 51 83             mov     dph,fatfs_info+1
005C: 74 11                mov     a,#fatfs_info_root_dir
005E: 12 08 3B             lcall   dptr_index
                           ; now dptr points to fatfs_info + offset 17 (root di
0061: 12 08 5C             lcall   dptr_read_32
                           ; r0-r3 now contains the root cluster number - print
0064: 12 08 A3             lcall   print_hex_32
0067: 90 00 C6             mov     dptr,#newline
006A: 12 08 B4             lcall   print_text
                           ; now call cluster_to_lba with this value
006D: 12 06 EC             lcall   fatfs_cluster_to_lba
0070: 12 08 A3             lcall   print_hex_32
0073: 90 00 C6             mov     dptr,#newline
0076: 12 08 B4             lcall   print_text
                   
                           ; *** chain handle exercise ***
                           ; open a chain on the root directory cluster, ensure
                           ; (the first sector of the root dir) is loaded, dump
                           ; 32 bytes of it (one directory entry), close the ch
                   
                           ; reload the root cluster number into r0-r3
0079: 85 50 82             mov     dpl,fatfs_info
007C: 85 51 83             mov     dph,fatfs_info+1
007F: 74 11                mov     a,#fatfs_info_root_dir
0081: 12 08 3B             lcall   dptr_index
0084: 12 08 5C             lcall   dptr_read_32
                   
                           ; open chain; dptr = handle on return
0087: 12 07 58             lcall   fatfs_chain_open
                   
                           ; Stash the handle in dptr' (the alternate dptr) so 
                           ; have to save it on the stack across ensure_block /
                           ; print_text. ensure_block returns the cache pointer
                           ; and is contractually required to preserve dptr'.
008A: AC 82                mov     r4,dpl
008C: AD 83                mov     r5,dph
008E: 05 A2                inc     auxr1
0090: 8C 82                mov     dpl,r4
0092: 8D 83                mov     dph,r5
0094: 05 A2                inc     auxr1
                           ; both dptr and dptr' now point at the handle
                   
                           ; ensure block 0 of the chain is loaded; dptr = cach
0096: E4                   clr     a
0097: F8                   mov     r0,a
0098: F9                   mov     r1,a
0099: FA                   mov     r2,a
009A: FB                   mov     r3,a
009B: 12 07 7E             lcall   fatfs_chain_ensure_block
                   
                           ; dump the first 32 bytes of the cached block (one d
                           ; stream_in is the base address; the dump function r
                           ; routine pointed to by `in`, starting at offset r0-
009E: 85 82 34             mov     stream_in,dpl
00A1: 85 83 35             mov     stream_in+1,dph
00A4: E4                   clr     a
00A5: F8                   mov     r0,a
00A6: F9                   mov     r1,a
00A7: FA                   mov     r2,a
00A8: FB                   mov     r3,a
00A9: 90 08 C8             mov     dptr,#stream_xram_read
00AC: 85 82 30             mov     in,dpl
00AF: 85 83 31             mov     in+1,dph
00B2: 74 20                mov     a,#32
00B4: 12 08 EE             lcall   dump
                   
00B7: 90 00 C6             mov     dptr,#newline
00BA: 12 08 B4             lcall   print_text
                   
                           ; close the chain — handle is sitting in dptr', sw
00BD: 05 A2                inc     auxr1
00BF: 12 07 6B             lcall   fatfs_chain_close
                   
                   halt:
00C2: 80 FE                sjmp    halt
                   
                   ok_string:
00C4: 4F 4B                .db     "OK" 
                   newline: 
00C6: 0D 0A 00             .db     13, 10, 0
                   
0100:              .org    0x0100
                   
                   ; *********************
                   ; * Library Functions *
                   ; *********************
                   
                   ; *** serial/init.inc ***
                   
                   ; >> void serial_init() <<
                   
                   ; Initialize serial interface.
                   ; - assumes 20MHz clock and X2 mode
                   ; - uses internal baud rate generator
                   ; - speed: 9600 bits per second
                   ; Formula: BRL = 256 - (F_clk / (32 * Baud_Rate))
                   ; ---
                   ; See datasheet page 52 for details,
                   ; also note oscillator diagram on page 16!
                   
                   serial_init:
0100: 75 98 52             mov     SCON,   #0x52   ; SM1, REN, TI
0103: 75 9A BF             mov     BRL,    #191    ; 9600 @20MHz CLK
0106: 75 9B 1E             mov     BDRCON, #0x1e   ; BRR, RBCK, TBCK, SPD
                   
0109: 90 01 24             mov     dptr,   #serial_rx
010C: 85 82 30             mov     IN,     DPL
010F: 85 83 31             mov     IN+1,   DPH
                   
0112: 90 01 1C             mov     dptr,   #serial_tx
0115: 85 82 32             mov     OUT,    DPL
0118: 85 83 33             mov     OUT+1,  DPH
                   
011B: 22                   ret
                   
                   ; *** serial/tx.inc ***
                   
                   ; >> void serial_tx(char a) <<
                   
                   ; Transmit byte from accumulator.
                   
                   serial_tx:
011C: 30 99 FD             jnb     TI,     serial_tx
011F: C2 99                clr     TI
0121: F5 99                mov     SBUF,   a
0123: 22                   ret
                   
                   ; *** serial/rx.inc ***
                   
                   ; >> char serial_rx <<
                   
                   ; Receive byte into accumulator.
                   
                   serial_rx:
0124: 30 98 FD             jnb     RI,     serial_rx
0127: C2 98                clr     RI
0129: E5 99                mov     a,      SBUF
012B: 22                   ret
                   
                   
                   ; *** spi/transfer.inc ***
                   
                   ; >> char{a} serial_transfer(char{a} data) <<
                   
                   ; SPI transfer function: send byte from a, read response int
                   
                   spi_transfer:
012C: F5 C5                mov     spdat,a
                   
                   spi_transfer__wait:
012E: E5 C4                mov     a,spsta
0130: 54 80                anl     a,#0x80 ;check SPIF bit
0132: 60 FA                jz      spi_transfer__wait
                   
0134: E5 C5                mov     a,spdat
0136: 22                   ret
                   
                   ; *** sd/init.inc ***
                   
                   ; >> uint8{a},uint32{r0-r3} sd_init() <<
                   
                   ; Initialize SD card, return error code in a, OCR in r0-r3.
                   sd_init:
                           ; r5 is used as temp store for error code
0137: C0 05                push    5
0139: C0 82                push    dpl
013B: C0 83                push    dph
                   
013D: 75 C3 F1             mov     spcon,#sd_spi_config
0140: 12 01 8B             lcall   sd_warmup
0143: 12 01 A0             lcall   sd_select
                   
0146: 7D 05                mov     r5,#5   ; 5: no idle response to cmd0
0148: 12 01 AF             lcall   sd_cmd0
014B: B4 01 35             cjne    a,#1,sd_init__end
                   
014E: 1D                   dec     r5      ; 4: no idle response to cmd8
014F: 12 01 CF             lcall   sd_cmd8
0152: B4 01 2E             cjne    a,#1,sd_init__end
0155: 1D                   dec     r5      ; 3: invalid cmd8 response
0156: BB 00 2A             cjne    r3,#0x00,sd_init__end
0159: BA 00 27             cjne    r2,#0x00,sd_init__end
015C: B9 01 24             cjne    r1,#0x01,sd_init__end
015F: B8 AA 21             cjne    r0,#0xaa,sd_init__end
                   
0162: 7D 64                mov     r5,#100 ; retry counter
                   sd_init__loop:
0164: 12 01 E4             lcall   sd_acmd41
0167: 60 0B                jz      sd_init__continue
0169: 74 0A                mov     a,#10
016B: 12 08 12             lcall   delay_ms_8
016E: DD F4                djnz    r5,sd_init__loop
0170: 7D 02                mov     r5,#2   ; 2: acmd41 ready response timeout
0172: 80 0F                sjmp    sd_init__end
                   
                   sd_init__continue:
0174: 7D 01                mov     r5,#1   ; 1: no ready response to cmd58
0176: 12 02 2C             lcall   sd_cmd58
                   
0179: 1D                   dec     r5      ; 0: success
                   
017A: 90 02 87             mov     dptr,#sd_block_read
017D: 85 82 44             mov     block_read,dpl
0180: 85 83 45             mov     block_read+1,dph
                   
                   sd_init__end:
0183: ED                   mov     a,r5    ; error code -> return value
0184: D0 83                pop     dph
0186: D0 82                pop     dpl
0188: D0 05                pop     5
018A: 22                   ret
                   
                   ; *** sd/warmup.inc ***
                   
                   ; >> void sd_warmup() <<
                   
                   ; send 80 warmup pulses to sclk while cs is high
                   sd_warmup:
018B: C0 E0                push    acc
018D: C0 F0                push    b
018F: D2 91                setb    sd_pin_cs ; p1.1
0191: 75 F0 0A             mov     b,#10
                   sd_warmup_loop:
0194: 74 FF                mov     a,#0xff
0196: 31 2C                acall   spi_transfer
0198: D5 F0 F9             djnz    b,sd_warmup_loop
019B: D0 F0                pop     b
019D: D0 E0                pop     acc
019F: 22                   ret
                   
                   ; *** sd/select.inc ***
                   
                   ; >> void sd_select() <<
                   
                   ; Activate the SD card
                   sd_select:
01A0: C0 E0                push    acc
01A2: 74 FF                mov     a,#0xff
01A4: 31 2C                acall   spi_transfer
01A6: C2 91                clr     sd_pin_cs
01A8: 74 FF                mov     a,#0xff
01AA: 31 2C                acall   spi_transfer
01AC: D0 E0                pop     acc
01AE: 22                   ret
                   
                   ; *** sd/cmd0.inc ***
                   
                   ; >> char{a} sd_cmd0() <<
                   
                   ; CMD0: go to idle state
                   sd_cmd0:
01AF: C0 00                push    0
01B1: C0 01                push    1
01B3: C0 02                push    2
01B5: C0 03                push    3
01B7: C0 04                push    4
01B9: E4                   clr     a
01BA: F8                   mov     r0,a
01BB: F9                   mov     r1,a
01BC: FA                   mov     r2,a
01BD: FB                   mov     r3,a
01BE: 7C 94                mov     r4,#0x94
01C0: 51 3D                acall   sd_command
01C2: 51 57                acall   sd_response1
01C4: D0 04                pop     4
01C6: D0 03                pop     3
01C8: D0 02                pop     2
01CA: D0 01                pop     1
01CC: D0 00                pop     0
01CE: 22                   ret
                   
                   ; *** sd/cmd8.inc ***
                   
                   ; >> uint8{a},uint32{r0-r3} sd_cmd8() <<
                   
                   ; CMD8: send interface condition
                   sd_cmd8:
01CF: C0 04                push    4
01D1: 74 08                mov     a,#8
01D3: 78 AA                mov     r0,#0xaa
01D5: 79 01                mov     r1,#0x01
01D7: 7A 00                mov     r2,#0x00
01D9: 7B 00                mov     r3,#0x00
01DB: 7C 86                mov     r4,#0x86
01DD: 51 3D                acall   sd_command
01DF: 51 69                acall   sd_response7
01E1: D0 04                pop     4
01E3: 22                   ret
                   
                   ; *** sd/acmd41.inc ***
                   
                   ; >> char{a} sd_acmd41() <<
                   
                   ; ACMD41: send operation condition
                   sd_acmd41:
01E4: 51 0B                acall   sd_cmd55
01E6: B4 01 21             cjne    a,#1,sd_acmd41__end
01E9: C0 00                push    0
01EB: C0 01                push    1
01ED: C0 02                push    2
01EF: C0 03                push    3
01F1: C0 04                push    4
01F3: E4                   clr     a
01F4: F8                   mov     r0,a
01F5: F9                   mov     r1,a
01F6: FA                   mov     r2,a
01F7: 7B 40                mov     r3,#0x40 ; indicates high capacity support
01F9: FC                   mov     r4,a
01FA: 74 29                mov     a,#41
01FC: 51 3D                acall   sd_command
01FE: 51 57                acall   sd_response1
0200: D0 04                pop     4
0202: D0 03                pop     3
0204: D0 02                pop     2
0206: D0 01                pop     1
0208: D0 00                pop     0
                   sd_acmd41__end:
020A: 22                   ret
                   
                   ; *** sd/cmd55.inc ***
                   
                   ; >> char{a} sd_cmd55() <<
                   
                   ; CMD55: application specific command (prefix)
                   sd_cmd55:
020B: C0 00                push    0
020D: C0 01                push    1
020F: C0 02                push    2
0211: C0 03                push    3
0213: C0 04                push    4
0215: E4                   clr     a
0216: F8                   mov     r0,a
0217: F9                   mov     r1,a
0218: FA                   mov     r2,a
0219: FB                   mov     r3,a
021A: FC                   mov     r4,a
021B: 74 37                mov     a,#55
021D: 51 3D                acall   sd_command
021F: 51 57                acall   sd_response1
0221: D0 04                pop     4
0223: D0 03                pop     3
0225: D0 02                pop     2
0227: D0 01                pop     1
0229: D0 00                pop     0
022B: 22                   ret
                   
                   ; *** sd/cmd58.inc ***
                   
                   ; >> uint8{a},uint32{r0-r3} sd_cmd58() <<
                   
                   ; CMD58: read operation conditions register
                   sd_cmd58:
022C: C0 04                push    4
022E: E4                   clr     a
022F: F8                   mov     r0,a
0230: F9                   mov     r1,a
0231: FA                   mov     r2,a
0232: FB                   mov     r3,a
0233: FC                   mov     r4,a
0234: 74 3A                mov     a,#58
0236: 51 3D                acall   sd_command
0238: 51 69                acall   sd_response3
023A: D0 04                pop     4
023C: 22                   ret
                   
                   ; *** sd/command.inc ***
                   
                   ; >> void sd_command(uint8{a} cmd, uint32{r0-r3} arg, uint8{
                   
                   ; Issue a command to the SD card
                   sd_command:
023D: C0 E0                push    acc
                           ; transmit command
023F: 44 40                orl     a,#0x40 ; transmission bit
0241: 31 2C                acall   spi_transfer
                           ; transmit argument
0243: EB                   mov     a,r3
0244: 31 2C                acall   spi_transfer
0246: EA                   mov     a,r2
0247: 31 2C                acall   spi_transfer
0249: E9                   mov     a,r1
024A: 31 2C                acall   spi_transfer
024C: E8                   mov     a,r0
024D: 31 2C                acall   spi_transfer
                           ; transmit crc
024F: EC                   mov     a,r4
0250: 44 01                orl     a,#0x01 ; end bit
0252: 31 2C                acall   spi_transfer
0254: D0 E0                pop     acc
0256: 22                   ret
                   
                   ; *** sd/response.inc ***
                   
                   ; >> uint8{a} sd_response1() <<
                   
                   ; Read response from SD card in 'R1' format into a
                   sd_response1:
0257: C0 F0                push    b
0259: 85 08 F0             mov     b,8     ; number of tries
                   sd_response1__loop:
025C: 74 FF                mov     a,#0xff
025E: 31 2C                acall   spi_transfer
0260: B4 FF 03             cjne    a,#0xff,sd_response1__end       ; success
0263: D5 F0 F6             djnz    b,sd_response1__loop    ; retry / timeout
                   sd_response1__end:
0266: D0 F0                pop     b
0268: 22                   ret
                   
                   ; >> uint8{a}, uint32{r0-r3} sd_response3() <<
                   
                   ; Read response from SD card in 'R3' format into a and r0-r3
                   sd_response3: ; same as R7
                   
                   ; >> uint8{a}, uint32{r0-r3} sd_response7() <<
                   
                   ; Read response from SD card in 'R7' format into a and r0-r3
                   sd_response7:
0269: 51 57                acall   sd_response1
026B: B4 02 00             cjne    a,#0x02,sd_response7__1
                   sd_response7__1:
026E: 40 01                jc      sd_response7__2
0270: 22                   ret     ; error in R1 response
                   sd_response7__2:
0271: F8                   mov     r0,a
0272: 74 FF                mov     a,#0xff
0274: 31 2C                acall   spi_transfer
0276: FB                   mov     r3,a
0277: 74 FF                mov     a,#0xff
0279: 31 2C                acall   spi_transfer
027B: FA                   mov     r2,a
027C: 74 FF                mov     a,#0xff
027E: 31 2C                acall   spi_transfer
0280: F9                   mov     r1,a
0281: 74 FF                mov     a,#0xff
0283: 31 2C                acall   spi_transfer
0285: C8                   xch     a,r0
0286: 22                   ret
                   
                   ; *** sd/block_read.inc ***
                   
                   ; >> uint16{r4-r5} sd_block_read(
                   ;       uint32{r0-r3} block_address,
                   ;       char *{dptr}&destination) <<
                   
                   ; Read block at address from sd card, write to RAM at dptr.
                   ; Return CRC in r4-r5, block address unchanged,
                   ; dptr pointing to first byte after read block.
                   
                   sd_block_read:
0287: C0 E0                push    acc
                   
                           ; send CMD17 (single block read)
0289: 74 11                mov     a,#17
028B: 7C FF                mov     r4,#0xff ; command CRC, ignored
028D: 51 3D                acall   sd_command
                   sd_block_read__wait:
028F: 51 57                acall   sd_response1
0291: B4 FE FB             cjne    a,#0xfe,sd_block_read__wait
0294: 7D 00                mov     r5,#0 ; loop counter
                           ; this loop will run 256 times,
                           ; two bytes are read per iteration
                   sd_block_read__loop:
0296: 74 FF                mov     a,#0xff
0298: 31 2C                acall   spi_transfer
029A: F0                   movx    @dptr,a
029B: A3                   inc     dptr
029C: 74 FF                mov     a,#0xff
029E: 31 2C                acall   spi_transfer
02A0: F0                   movx    @dptr,a
02A1: A3                   inc     dptr
02A2: DD F2                djnz    r5,sd_block_read__loop
                           ; read block CRC
