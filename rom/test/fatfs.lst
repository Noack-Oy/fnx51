                         ; ==== fatfs.asm ====
01AF                      152  .include ../sd/cmd0.inc
                         ; ==== ../sd/cmd0.inc ====
01AF                        1  
01AF                        2  ; *** sd/cmd0.inc ***
01AF                        3  
01AF                        4  ; >> char{a} sd_cmd0() <<
01AF                        5  
01AF                        6  ; CMD0: go to idle state
01AF                        7  sd_cmd0:
01AF  C0 00                 8  	push	0
01B1  C0 01                 9  	push	1
01B3  C0 02                10  	push	2
01B5  C0 03                11  	push	3
01B7  C0 04                12  	push	4
01B9  E4                   13  	clr	a
01BA  F8                   14  	mov	r0,a
01BB  F9                   15  	mov	r1,a
01BC  FA                   16  	mov	r2,a
01BD  FB                   17  	mov	r3,a
01BE  7C 94                18  	mov	r4,#0x94
01C0  51 3D                19  	acall	sd_command
01C2  51 57                20  	acall	sd_response1
01C4  D0 04                21  	pop	4
01C6  D0 03                22  	pop	3
01C8  D0 02                23  	pop	2
01CA  D0 01                24  	pop	1
01CC  D0 00                25  	pop	0
01CE  22                   26  	ret
01CF                       27  
                         ; ==== fatfs.asm ====
01CF                      153  .include ../sd/cmd8.inc
                         ; ==== ../sd/cmd8.inc ====
01CF                        1  
01CF                        2  ; *** sd/cmd8.inc ***
01CF                        3  
01CF                        4  ; >> uint8{a},uint32{r0-r3} sd_cmd8() <<
01CF                        5  
01CF                        6  ; CMD8: send interface condition
01CF                        7  sd_cmd8:
01CF  C0 04                 8  	push	4
01D1  74 08                 9  	mov	a,#8
01D3  78 AA                10  	mov	r0,#0xaa
01D5  79 01                11  	mov	r1,#0x01
01D7  7A 00                12  	mov	r2,#0x00
01D9  7B 00                13  	mov	r3,#0x00
01DB  7C 86                14  	mov	r4,#0x86
01DD  51 3D                15  	acall	sd_command
01DF  51 69                16  	acall	sd_response7
01E1  D0 04                17  	pop	4
01E3  22                   18  	ret
01E4                       19  
                         ; ==== fatfs.asm ====
01E4                      154  .include ../sd/acmd41.inc
                         ; ==== ../sd/acmd41.inc ====
01E4                        1  
01E4                        2  ; *** sd/acmd41.inc ***
01E4                        3  
01E4                        4  ; >> char{a} sd_acmd41() <<
01E4                        5  
01E4                        6  ; ACMD41: send operation condition
01E4                        7  sd_acmd41:
01E4  51 0B                 8  	acall	sd_cmd55
01E6  B4 01 21              9  	cjne	a,#1,sd_acmd41__end
01E9  C0 00                10  	push	0
01EB  C0 01                11  	push	1
01ED  C0 02                12  	push	2
01EF  C0 03                13  	push	3
01F1  C0 04                14  	push	4
01F3  E4                   15  	clr	a
01F4  F8                   16  	mov	r0,a
01F5  F9                   17  	mov	r1,a
01F6  FA                   18  	mov	r2,a
01F7  7B 40                19  	mov	r3,#0x40 ; indicates high capacity support
01F9  FC                   20  	mov	r4,a
01FA  74 29                21  	mov	a,#41
01FC  51 3D                22  	acall	sd_command
01FE  51 57                23  	acall	sd_response1
0200  D0 04                24  	pop	4
0202  D0 03                25  	pop	3
0204  D0 02                26  	pop	2
0206  D0 01                27  	pop	1
0208  D0 00                28  	pop	0
020A                       29  sd_acmd41__end:
020A  22                   30  	ret
020B                       31  
                         ; ==== fatfs.asm ====
020B                      155  .include ../sd/cmd55.inc
                         ; ==== ../sd/cmd55.inc ====
020B                        1  
020B                        2  ; *** sd/cmd55.inc ***
020B                        3  
020B                        4  ; >> char{a} sd_cmd55() <<
020B                        5  
020B                        6  ; CMD55: application specific command (prefix)
020B                        7  sd_cmd55:
020B  C0 00                 8  	push	0
020D  C0 01                 9  	push	1
020F  C0 02                10  	push	2
0211  C0 03                11  	push	3
0213  C0 04                12  	push	4
0215  E4                   13  	clr	a
0216  F8                   14  	mov	r0,a
0217  F9                   15  	mov	r1,a
0218  FA                   16  	mov	r2,a
0219  FB                   17  	mov	r3,a
021A  FC                   18  	mov	r4,a
021B  74 37                19  	mov	a,#55
021D  51 3D                20  	acall	sd_command
021F  51 57                21  	acall	sd_response1
0221  D0 04                22  	pop	4
0223  D0 03                23  	pop	3
0225  D0 02                24  	pop	2
0227  D0 01                25  	pop	1
0229  D0 00                26  	pop	0
022B  22                   27  	ret
022C                       28  
                         ; ==== fatfs.asm ====
022C                      156  .include ../sd/cmd58.inc
                         ; ==== ../sd/cmd58.inc ====
022C                        1  
022C                        2  ; *** sd/cmd58.inc ***
022C                        3  
022C                        4  ; >> uint8{a},uint32{r0-r3} sd_cmd58() <<
022C                        5  
022C                        6  ; CMD58: read operation conditions register
022C                        7  sd_cmd58:
022C  C0 04                 8  	push	4
022E  E4                    9  	clr	a
022F  F8                   10  	mov	r0,a
0230  F9                   11  	mov	r1,a
0231  FA                   12  	mov	r2,a
0232  FB                   13  	mov	r3,a
0233  FC                   14  	mov	r4,a
0234  74 3A                15  	mov	a,#58
0236  51 3D                16  	acall	sd_command
0238  51 69                17  	acall	sd_response3
023A  D0 04                18  	pop	4
023C  22                   19  	ret
023D                       20  
                         ; ==== fatfs.asm ====
023D                      157  .include ../sd/command.inc
                         ; ==== ../sd/command.inc ====
023D                        1  
023D                        2  ; *** sd/command.inc ***
023D                        3  
023D                        4  ; >> void sd_command(uint8{a} cmd, uint32{r0-r3} arg, uint8{r4} crc) <<
023D                        5  
023D                        6  ; Issue a command to the SD card
023D                        7  sd_command:
023D  C0 E0                 8  	push	acc
023F                        9  	; transmit command
023F  44 40                10  	orl	a,#0x40	; transmission bit
0241  31 2C                11  	acall	spi_transfer
0243                       12  	; transmit argument
0243  EB                   13  	mov	a,r3
0244  31 2C                14  	acall	spi_transfer
0246  EA                   15  	mov	a,r2
0247  31 2C                16  	acall	spi_transfer
0249  E9                   17  	mov	a,r1
024A  31 2C                18  	acall	spi_transfer
024C  E8                   19  	mov	a,r0
024D  31 2C                20  	acall	spi_transfer
024F                       21  	; transmit crc
024F  EC                   22  	mov	a,r4
0250  44 01                23  	orl	a,#0x01	; end bit
0252  31 2C                24  	acall	spi_transfer
0254  D0 E0                25  	pop	acc
0256  22                   26  	ret
0257                       27  
                         ; ==== fatfs.asm ====
0257                      158  .include ../sd/response.inc
                         ; ==== ../sd/response.inc ====
0257                        1  
0257                        2  ; *** sd/response.inc ***
0257                        3  
0257                        4  ; >> uint8{a} sd_response1() <<
0257                        5  
0257                        6  ; Read response from SD card in 'R1' format into a
0257                        7  sd_response1:
0257  C0 F0                 8  	push	b
0259  85 08 F0              9  	mov	b,8	; number of tries
025C                       10  sd_response1__loop:
025C  74 FF                11  	mov	a,#0xff
025E  31 2C                12  	acall	spi_transfer
0260  B4 FF 03             13  	cjne	a,#0xff,sd_response1__end	; success
0263  D5 F0 F6             14  	djnz	b,sd_response1__loop	; retry / timeout
0266                       15  sd_response1__end:
0266  D0 F0                16  	pop	b
0268  22                   17  	ret
0269                       18  
0269                       19  ; >> uint8{a}, uint32{r0-r3} sd_response3() <<
0269                       20  
0269                       21  ; Read response from SD card in 'R3' format into a and r0-r3
0269                       22  sd_response3: ; same as R7
0269                       23  
0269                       24  ; >> uint8{a}, uint32{r0-r3} sd_response7() <<
0269                       25  
0269                       26  ; Read response from SD card in 'R7' format into a and r0-r3
0269                       27  sd_response7:
0269  51 57                28  	acall	sd_response1
026B  B4 02 00             29  	cjne	a,#0x02,sd_response7__1
026E                       30  sd_response7__1:
026E  40 01                31  	jc	sd_response7__2
0270  22                   32  	ret	; error in R1 response
0271                       33  sd_response7__2:
0271  F8                   34  	mov	r0,a
0272  74 FF                35  	mov	a,#0xff
0274  31 2C                36  	acall	spi_transfer
0276  FB                   37  	mov	r3,a
0277  74 FF                38  	mov	a,#0xff
0279  31 2C                39  	acall	spi_transfer
027B  FA                   40  	mov	r2,a
027C  74 FF                41  	mov	a,#0xff
027E  31 2C                42  	acall	spi_transfer
0280  F9                   43  	mov	r1,a
0281  74 FF                44  	mov	a,#0xff
0283  31 2C                45  	acall	spi_transfer
0285  C8                   46  	xch	a,r0
0286  22                   47  	ret
0287                       48  
                         ; ==== fatfs.asm ====
0287                      159  .include ../sd/block_read.inc
                         ; ==== ../sd/block_read.inc ====
0287                        1  
0287                        2  ; *** sd/block_read.inc ***
0287                        3  
0287                        4  ; >> uint16{r4-r5} sd_block_read(
0287                        5  ;	uint32{r0-r3} block_address,
0287                        6  ;	char *{dptr}&destination) <<
0287                        7  
0287                        8  ; Read block at address from sd card, write to RAM at dptr.
0287                        9  ; Return CRC in r4-r5, block address unchanged,
0287                       10  ; dptr pointing to first byte after read block.
0287                       11  
0287                       12  sd_block_read:
0287  C0 E0                13  	push	acc
0289                       14  
0289                       15  	; send CMD17 (single block read)
0289  74 11                16  	mov	a,#17
028B  7C FF                17  	mov	r4,#0xff ; command CRC, ignored
028D  51 3D                18  	acall	sd_command
028F                       19  sd_block_read__wait:
028F  51 57                20  	acall	sd_response1
0291  B4 FE FB             21  	cjne	a,#0xfe,sd_block_read__wait
0294  7D 00                22  	mov	r5,#0 ; loop counter
0296                       23  	; this loop will run 256 times,
0296                       24  	; two bytes are read per iteration
0296                       25  sd_block_read__loop:
0296  74 FF                26  	mov	a,#0xff
0298  31 2C                27  	acall	spi_transfer
029A  F0                   28  	movx	@dptr,a
029B  A3                   29  	inc	dptr
029C  74 FF                30  	mov	a,#0xff
029E  31 2C                31  	acall	spi_transfer
02A0  F0                   32  	movx	@dptr,a
02A1  A3                   33  	inc	dptr
02A2  DD F2                34  	djnz	r5,sd_block_read__loop
02A4                       35  	; read block CRC
02A4  74 FF                36  	mov	a,#0xff
02A6  31 2C                37  	acall	spi_transfer
02A8  FD                   38  	mov	r5,a
02A9  74 FF                39  	mov	a,#0xff
02AB  31 2C                40  	acall	spi_transfer
02AD  FC                   41  	mov	r4,a
02AE                       42  
02AE  D0 E0                43  	pop	acc
02B0  22                   44  	ret
02B1                       45  
                         ; ==== fatfs.asm ====
02B1                      160  
02B1                      161  .include ../memory/init.inc
                         ; ==== ../memory/init.inc ====
02B1                        1  
02B1                        2  ; *** memory/init.inc ***
02B1                        3  
02B1                        4  ; >> void memory_init(() <<
02B1                        5  
02B1                        6  ; Enable xram, initialize memory allocator data structures
02B1                        7  
02B1                        8  memory_init:
02B1                        9  
02B1  C0 E0                10  	push	acc
02B3  C0 82                11  	push	dpl
02B5  C0 83                12  	push	dph
02B7                       13  
02B7                       14  	; use xram
02B7  53 8E E1             15  	anl	auxr,#0xe1	; clear extram, xrs0-2
02BA  43 8E 10             16  	orl	auxr,#0x10	; set xrs2 (size 1792 bytes)
02BD                       17  
02BD                       18  	; clear xram with dummy value
02BD  90 00 00             19  	mov	dptr,#0
02C0                       20  memory_init__1:
02C0  74 23                21  	mov	a,#0x23
02C2  F0                   22  	movx	@dptr,a
02C3  A3                   23  	inc	dptr
02C4  74 07                24  	mov	a,#0x07 ; xram goes up to 0x06ff
02C6  B5 83 F7             25  	cjne	a,dph,memory_init__1
02C9                       26  
02C9                       27  	; initialize memory list
02C9  90 00 00             28  	mov	dptr,#0
02CC  85 82 38             29  	mov	memory_list,dpl
02CF  85 83 39             30  	mov	memory_list+1,dph
02D2                       31  	; list head: pointer to first block
02D2  74 04                32  	mov	a,#4
02D4  F5 40                33  	mov	memory_start,a
02D6  F0                   34  	movx	@dptr,a
02D7  A3                   35  	inc	dptr
02D8  E4                   36  	clr	a
02D9  F5 41                37  	mov	memory_start+1,a
02DB  F0                   38  	movx	@dptr,a
02DC  A3                   39  	inc	dptr
02DD                       40  	; max address of allocatable memory: 0x06ff
02DD  75 42 FF             41  	mov	memory_end,#0xff
02E0  85 06 43             42  	mov	memory_end+1,0x06
02E3                       43  	; amount of free memory: 1792-4 = 1788 = 0x06fc
02E3  74 FC                44  	mov	a,#0xfc
02E5  F0                   45  	movx	@dptr,a
02E6  A3                   46  	inc	dptr
02E7  74 06                47  	mov	a,#0x06
02E9  F0                   48  	movx	@dptr,a
02EA  A3                   49  	inc	dptr
02EB                       50  	; first entry: pointer to next (null initially)
02EB  E4                   51  	clr	a
02EC  F0                   52  	movx	@dptr,a
02ED  A3                   53  	inc	dptr
02EE  F0                   54  	movx	@dptr,a
02EF  A3                   55  	inc	dptr
02F0                       56  	; size of block (same as free memory initially)
02F0  74 FC                57  	mov	a,#0xfc
02F2  F0                   58  	movx	@dptr,a
02F3  A3                   59  	inc	dptr
02F4  74 06                60  	mov	a,#0x06
02F6  F0                   61  	movx	@dptr,a
02F7  A3                   62  	inc	dptr
02F8                       63  
02F8  D0 83                64  	pop	dph
02FA  D0 82                65  	pop	dpl
02FC  D0 E0                66  	pop	acc
02FE                       67  
02FE  22                   68  	ret
02FF                       69  
                         ; ==== fatfs.asm ====
02FF                      162  .include ../memory/allocate.inc
                         ; ==== ../memory/allocate.inc ====
02FF                        1  
02FF                        2  ; *** memory/allocate.inc ***
02FF                        3  
02FF                        4  ; >> char *{dptr} memory_allocate(uint16{r0r1} size) <<
02FF                        5  
02FF                        6  ; Allocate `size` bytes, return pointer to the start of the block.
02FF                        7  
02FF                        8  memory_allocate:
02FF  C0 A8                 9  	push	ie
0301  C2 AF                10  	clr	ea
0303                       11  
0303  C0 E0                12  	push	acc
0305                       13  	; r0,r1 = size (input, preserved); r2-r7 are clobbered
0305  C0 00                14  	push	0
0307  C0 01                15  	push	1
0309  C0 02                16  	push	2
030B  C0 03                17  	push	3
030D  C0 04                18  	push	4
030F  C0 05                19  	push	5
0311  C0 06                20  	push	6
0313  C0 07                21  	push	7
0315  05 A2                22  	inc	auxr1
0317  C0 82                23  	push	dpl
0319  C0 83                24  	push	dph
031B                       25  
031B                       26  	; size lives in r0r1 throughout (modified by the rounding step,
031B                       27  	; restored by the matching pop at exit). The pointer is built up
031B                       28  	; in r4r5 and copied into dptr just before returning.
031B                       29  
031B  E8                   30  	mov	a,r0
031C  49                   31  	orl	a,r1
031D  70 03                32  	jnz	memory_allocate__0
031F  12 09 B0             33  	lcall	panic	; invalid size (0)
0322                       34  
0322                       35  memory_allocate__0:
0322                       36  	; rounding to next multiple of 4
0322  E8                   37  	mov	a,r0
0323  24 03                38  	add	a,#3
0325  54 FC                39  	anl	a,#0xfc
0327  F8                   40  	mov	r0,a
0328  E9                   41  	mov	a,r1
0329  34 00                42  	addc	a,#0
032B  F9                   43  	mov	r1,a
032C                       44  
032C                       45  	; set prev (r2,r3) and curr (r4r5) pointers
032C  AA 38                46  	mov	r2,memory_list
032E  AB 39                47  	mov	r3,memory_list+1
0330  8A 82                48  	mov	dpl,r2
0332  8B 83                49  	mov	dph,r3
0334  E0                   50  	movx	a,@dptr
0335  FC                   51  	mov	r4,a
0336  A3                   52  	inc	dptr
0337  E0                   53  	movx	a,@dptr
0338  FD                   54  	mov	r5,a
0339                       55  
0339                       56  memory_allocate__loop:
0339  EC                   57  	mov	a,r4
033A  4D                   58  	orl	a,r5
033B  70 03                59  	jnz	memory_allocate__0a
033D  12 09 B0             60  	lcall	panic	; no large enough free block found
0340                       61  memory_allocate__0a:
0340                       62  	; compare curr->size with required size
0340  8C 82                63  	mov	dpl,r4
0342  8D 83                64  	mov	dph,r5
0344  A3                   65  	inc	dptr
0345  A3                   66  	inc	dptr	; dptr is now &(curr->size)
0346  E0                   67  	movx	a,@dptr
0347  FE                   68  	mov	r6,a	; store low byte for later (cannot easily dec dptr)
0348  A3                   69  	inc	dptr	; compare high byte first
0349  C3                   70  	clr	c
034A  E0                   71  	movx	a,@dptr
034B  99                   72  	subb	a,r1
034C  70 1C                73  	jnz	memory_allocate__1
034E  EE                   74  	mov	a,r6
034F  98                   75  	subb	a,r0
0350  70 18                76  	jnz	memory_allocate__1
0352                       77  
0352                       78  	; block size is exact match
0352  8A 82                79  	mov	dpl,r2	; prev
0354  8B 83                80  	mov	dph,r3
0356  05 A2                81  	inc	auxr1	;*switch data pointers
0358  8C 82                82  	mov	dpl,r4	; curr
035A  8D 83                83  	mov	dph,r5
035C                       84  	; prev->next = curr->next
035C  E0                   85  	movx	a,@dptr
035D  A3                   86  	inc	dptr
035E  05 A2                87  	inc	auxr1	;*
0360  F0                   88  	movx	@dptr,a
0361  A3                   89  	inc	dptr
0362  05 A2                90  	inc	auxr1	;*
0364  E0                   91  	movx	a,@dptr
0365  05 A2                92  	inc	auxr1	;*
0367  F0                   93  	movx	@dptr,a
0368  80 47                94  	sjmp	memory_allocate__success
036A                       95  
036A                       96  memory_allocate__1:
036A  50 0F                97  	jnc	memory_allocate__2 ; jump if curr is larger than required
036C                       98  	; too small, move on to next entry in list
036C  EC                   99  	mov	a,r4	; -.
036D  FA                  100  	mov	r2,a	;  |- prev = curr
036E  ED                  101  	mov	a,r5	;  |
036F  FB                  102  	mov	r3,a	; -'
0370  8C 82               103  	mov	dpl,r4	; -.
0372  8D 83               104  	mov	dph,r5	;  |
0374  E0                  105  	movx	a,@dptr ;  |
0375  FC                  106  	mov	r4,a	;  |- curr = curr->next
0376  A3                  107  	inc	dptr	;  |
0377  E0                  108  	movx	a,@dptr ;  |
0378  FD                  109  	mov	r5,a	; -'
0379  80 BE               110  	sjmp	memory_allocate__loop
037B                      111  
037B                      112  memory_allocate__2:
037B                      113  	; split big block
037B  8A 82               114  	mov	dpl,r2	; prev
037D  8B 83               115  	mov	dph,r3	;
037F  EC                  116  	mov	a,r4	; -.
0380  28                  117  	add	a,r0	;  |
0381  FA                  118  	mov	r2,a	;  |
0382  F0                  119  	movx	@dptr,a ;  |
0383  A3                  120  	inc	dptr	;  |- prev->next = curr+size
0384  ED                  121  	mov	a,r5	;  |               '---.---'
0385  39                  122  	addc	a,r1	;  |  pointer to leftover block
0386  FB                  123  	mov	r3,a	;  |  also gets stored in r2r3
0387  F0                  124  	movx	@dptr,a ; -' (prev is not needed anymore)
0388                      125  
0388  8A 82               126  	mov	dpl,r2  ; leftover
038A  8B 83               127  	mov	dph,r3
038C  05 A2               128  	inc	auxr1	;*switch data pointers
038E  8C 82               129  	mov	dpl,r4	; curr
0390  8D 83               130  	mov	dph,r5
0392  E0                  131  	movx	a,@dptr	; -.
0393  A3                  132  	inc	dptr	;  |
0394  05 A2               133  	inc	auxr1	;* |
0396  F0                  134  	movx	@dptr,a ;  |
0397  A3                  135  	inc	dptr	;  |
0398  05 A2               136  	inc	auxr1	;* |- leftover->next = curr->next
039A  E0                  137  	movx	a,@dptr ;  |
039B  A3                  138  	inc	dptr	;  |
039C  05 A2               139  	inc	auxr1	;* |
039E  F0                  140  	movx	@dptr,a ;  |
039F  A3                  141  	inc	dptr	; -'
03A0                      142  	; data pointers are now &(leftover->size) and &(curr->size)
03A0  05 A2               143  	inc	auxr1	;*-.
03A2  E0                  144  	movx	a,@dptr ;  |
03A3  A3                  145  	inc	dptr	;  |
03A4  C3                  146  	clr	c	;  |
03A5  98                  147  	subb	a,r0	;  |
03A6  05 A2               148  	inc	auxr1	;* |
03A8  F0                  149  	movx	@dptr,a ;  |- leftover->size = curr->size - size
03A9  A3                  150  	inc	dptr	;  |
03AA  05 A2               151  	inc	auxr1	;* |
03AC  E0                  152  	movx	a,@dptr ;  |
03AD  99                  153  	subb	a,r1	;  |
03AE  05 A2               154  	inc	auxr1	;* |
03B0  F0                  155  	movx	@dptr,a ; -'
03B1                      156  
03B1                      157  memory_allocate__success:
03B1  85 38 82            158  	mov	dpl,memory_list
03B4  85 39 83            159  	mov	dph,memory_list+1
03B7  A3                  160  	inc	dptr	; -.
03B8  A3                  161  	inc	dptr	;  |
03B9  E0                  162  	movx	a,@dptr ;  |
03BA  C3                  163  	clr	c	;  |
03BB  98                  164  	subb	a,r0	;  |- memory_list->free -= size
03BC  F0                  165  	movx	@dptr,a ;  |
03BD  A3                  166  	inc	dptr	;  |
03BE  E0                  167  	movx	a,@dptr ;  |
03BF  99                  168  	subb	a,r1	;  |
03C0  F0                  169  	movx	@dptr,a ; -'
03C1                      170  
03C1                      171  	; restore the alternate dptr, then set the main dptr to the
03C1                      172  	; result pointer that's been sitting in r4r5
03C1  D0 83               173  	pop	dph
03C3  D0 82               174  	pop	dpl
03C5  05 A2               175  	inc	auxr1
03C7  8C 82               176  	mov	dpl,r4
03C9  8D 83               177  	mov	dph,r5
03CB                      178  
03CB  D0 07               179  	pop	7
03CD  D0 06               180  	pop	6
03CF  D0 05               181  	pop	5
03D1  D0 04               182  	pop	4
03D3  D0 03               183  	pop	3
03D5  D0 02               184  	pop	2
03D7  D0 01               185  	pop	1
