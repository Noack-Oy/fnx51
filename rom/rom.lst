0000                        6  
0000                        7  ; *** interrupt vectors ***
0000                        8  
0000                        9  .org 0x0000
0000  80 4E                10  	sjmp	main
0050                       11  .org 0x0050
0050                       12  
0050                       13  ; *** main program ***
