0088                       33  .include serial/init.inc
                         ; ==== serial/init.inc ====
0088                        1  
0088                        2  ; *** serial/init.inc ***
0088                        3  
0088                        4  ; >> void serial_init() <<
0088                        5  
0088                        6  ; Initialize serial interface.
0088                        7  ; - assumes 20MHz clock and X2 mode
0088                        8  ; - uses internal baud rate generator
0088                        9  ; - speed: 9600 bits per second
0088                       10  ; Formula: BRL = 256 - (F_clk / (32 * Baud_Rate))
0088                       11  ; ---
0088                       12  ; See datasheet page 52 for details,
0088                       13  ; also note oscillator diagram on page 16!
0088                       14  
0088                       15  serial_init:
0088  75 98 52             16  	mov	SCON,	#0x52	; SM1, REN, TI
008B  75 9A BF             17  	mov	BRL,	#191	; 9600 @20MHz CLK
008E  75 9B 1E             18  	mov	BDRCON, #0x1e	; BRR, RBCK, TBCK, SPD
0091                       19  
0091  90 00 A4             20  	mov	dptr,	#serial_rx
0094  85 82 30             21  	mov	IN,	DPL
0097  85 83 31             22  	mov	IN+1,	DPH
009A                       23  
009A  90 00 AC             24  	mov	dptr,	#serial_tx
009D  85 82 32             25  	mov	OUT,	DPL
00A0  85 83 33             26  	mov	OUT+1,	DPH
00A3                       27  
00A3  22                   28  	ret
00A4                       29  
                         ; ==== rom.asm ====
00A4                       34  .include serial/rx.inc
                         ; ==== serial/rx.inc ====
00A4                        1  
00A4                        2  ; *** serial/rx.inc ***
00A4                        3  
00A4                        4  ; >> char serial_rx <<
00A4                        5  
00A4                        6  ; Receive byte into accumulator.
00A4                        7  
00A4                        8  serial_rx:
00A4  30 98 FD              9  	jnb	RI,	serial_rx
00A7  C2 98                10  	clr	RI
00A9  E5 99                11  	mov	a,	SBUF
00AB  22                   12  	ret
00AC                       13  
                         ; ==== rom.asm ====
00AC                       35  .include serial/tx.inc
                         ; ==== serial/tx.inc ====
00AC                        1  
00AC                        2  ; *** serial/tx.inc ***
00AC                        3  
00AC                        4  ; >> void serial_tx(char a) <<
00AC                        5  
00AC                        6  ; Transmit byte from accumulator.
00AC                        7  
00AC                        8  serial_tx:
00AC  30 99 FD              9  	jnb	TI,	serial_tx
00AF  C2 99                10  	clr	TI
00B1  F5 99                11  	mov	SBUF,	a
00B3  22                   12  	ret
00B4                       13  
                         ; ==== rom.asm ====
00B4                       36  .include print/char.inc
                         ; ==== print/char.inc ====
00B4                        1  
00B4                        2  ; *** print/char.inc ***
00B4                        3  
00B4                        4  ; >> void print_char(char a) <<
00B4                        5  
00B4                        6  ; Print char from accumulator.
00B4                        7  ; Indirect call to function behind OUT pointer.
00B4                        8  
00B4                        9  print_char:
00B4  C0 32                10  	push	OUT
00B6  C0 33                11  	push	OUT+1
00B8  22                   12  	ret
00B9                       13  
                         ; ==== rom.asm ====
00B9                       37  .include print/text.inc
                         ; ==== print/text.inc ====
00B9                        1  
00B9                        2  ; *** print/text.inc ***
00B9                        3  
00B9                        4  ; >> void print_text(char* dptr) <<
00B9                        5  
00B9                        6  ; Print null-terminated string from program code.
00B9                        7  ; Aborts if no null terminator is found after 256 bytes.
00B9                        8  
00B9                        9  print_text:
00B9  C0 E0                10  	push	ACC
00BB  C0 00                11  	push	0
00BD                       12  
00BD  E4                   13  	clr	a
00BE  F8                   14  	mov	r0,	a
00BF                       15  print_text__loop:
00BF  93                   16  	movc	a,	@a+dptr
00C0  60 06                17  	jz	print_text__end
00C2  11 B4                18  	acall	print_char
00C4  08                   19  	inc	r0
00C5  E8                   20  	mov	a,	r0
00C6  70 F7                21  	jnz	print_text__loop
00C8                       22  
00C8                       23  print_text__end:
00C8  D0 00                24  	pop	0
00CA  D0 E0                25  	pop	ACC
00CC  22                   26  	ret
00CD                       27  
