0050                       15  main:
0050                       16  
0050                       17  .include global/init.inc
                         ; ==== global/init.inc ====
0050                        1  
0050                        2  ; *** global/init.inc ***
0050                        3  
0050                        4  ; Initialize stack pointer and global variables.
0050                        5  ; This must be included early in the main program.
0050                        6  
0050                        7  global_init:
0050  75 81 60              8  	mov	SP,#STACK
0053                        9  
0053                       10  ; Select register bank zero, clear processor flags
0053  75 D0 00             11  	mov	PSW,#0
0056                       12  
0056                       13  ; Fill internal RAM with markers for uninitialized data
0056  78 00                14  	mov	r0,#0 ; write pointer
0058                       15  
0058  74 3F                16  	mov	a,#0x3f ; '?' for uninitialized registers
005A                       17  global_init__1:
005A  08                   18  	inc	r0 ; first iteration skips address 0, r0 lives there
005B  F6                   19  	mov	@r0,a
005C  B8 1F FB             20  	cjne	r0,#0x1f,global_init__1
005F                       21  
005F  74 2A                22  	mov	a,#0x2a ; '*' for uninitialized variables
0061                       23  global_init__2:
0061  08                   24  	inc	r0
0062  F6                   25  	mov	@r0,a
0063  B8 5F FB             26  	cjne	r0,#STACK-1,global_init__2
0066                       27  
0066  74 7E                28  	mov	a,#0x7e ; '~' for stack and above
0068                       29  global_init__3:
0068  08                   30  	inc	r0
0069  F6                   31  	mov	@r0,a
006A  B8 FF FB             32  	cjne	r0,#0xff,global_init__3
006D                       33  
